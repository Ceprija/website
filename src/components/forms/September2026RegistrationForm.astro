---
import Button from "../ui/Button.astro";
import {
  MAX_FULL_NAME_LEN,
  TEXT_MAX_LENGTH_BY_NAME,
} from "@lib/validation/formFieldLimits";

const programs = [
  "Maestría en Derecho Internacional de Derechos Humanos y Litigio Estratégico",
  "Especialidad en Criminalística y Ciencias Forenses",
  "Maestría en Derecho Civil y Familiar",
  "Doctorado en Derecho Procesal y Sistemas Contemporáneos",
] as const;

const START_CYCLE = "Septiembre 2026";

const fieldClass =
  "w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all";
const labelClass = "block text-sm font-semibold text-gray-700 mb-2";
---

<div class="bg-white rounded-2xl shadow-lg p-8 md:p-10 border-t-4 border-secondary">
  <h2 class="text-2xl md:text-3xl font-bold text-primary mb-2 font-serif">
    Formulario de registro inicial
  </h2>
  <p class="text-gray-600 mb-8 text-sm md:text-base">
    Completa tus datos y un asesor de CEPRIJA se pondrá en contacto contigo para
    continuar tu proceso de inscripción al ciclo de septiembre 2026.
  </p>

  <form id="septiembre-2026-form" class="space-y-6">
    <input
      type="text"
      name="website"
      autocomplete="off"
      tabindex="-1"
      class="sr-only"
      aria-hidden="true"
    />
    <div>
      <label for="program" class:list={[labelClass]}>Deseo ingresar a *</label>
      <select id="program" name="program" required class:list={[fieldClass]}>
        <option value="" disabled selected>Selecciona un programa</option>
        {
          programs.map((title) => (
            <option value={title}>{title}</option>
          ))
        }
      </select>
    </div>

    <div>
      <label for="name" class:list={[labelClass]}>Nombre completo *</label>
      <input
        type="text"
        id="name"
        name="name"
        required
        autocomplete="name"
        maxlength={MAX_FULL_NAME_LEN}
        class:list={[fieldClass]}
        placeholder="Nombre y apellidos"
      />
    </div>

    <div>
      <label for="startCycle" class:list={[labelClass]}>Ciclo de inicio *</label>
      <select id="startCycle" name="startCycle" required class:list={[fieldClass]}>
        <option value={START_CYCLE} selected>{START_CYCLE}</option>
      </select>
    </div>

    <div>
      <label for="email" class:list={[labelClass]}>Correo electrónico *</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        autocomplete="email"
        maxlength={TEXT_MAX_LENGTH_BY_NAME.email}
        class:list={[fieldClass]}
        placeholder="tu@email.com"
      />
    </div>

    <div>
      <label for="phone" class:list={[labelClass]}>Número de contacto *</label>
      <input
        type="tel"
        id="phone"
        name="phone"
        required
        autocomplete="tel"
        maxlength={TEXT_MAX_LENGTH_BY_NAME.phone}
        inputmode="tel"
        class:list={[fieldClass]}
        placeholder="33 1234 5678"
      />
    </div>

    <div id="septiembre-2026-status" class="hidden p-3 rounded-lg text-sm"></div>

    <Button
      type="submit"
      id="septiembre-2026-submit"
      variant="secondary"
      size="lg"
      class="w-full flex justify-center items-center gap-2"
    >
      <span>Enviar registro</span>
      <svg
        class="animate-spin h-5 w-5 text-primary hidden"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        id="septiembre-2026-spinner"
        aria-hidden="true"
      >
        <circle
          class="opacity-25"
          cx="12"
          cy="12"
          r="10"
          stroke="currentColor"
          stroke-width="4"></circle>
        <path
          class="opacity-75"
          fill="currentColor"
          d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
        ></path>
      </svg>
    </Button>
  </form>
</div>

<script define:vars={{ allowedPrograms: [...programs], startCycle: START_CYCLE }}>
  import {
    reportStepValidationFailure,
    validateStepSection,
  } from "@lib/client/multiStepFormValidation";

  const form = document.getElementById(
    "septiembre-2026-form",
  ) as HTMLFormElement | null;
  const statusDiv = document.getElementById("septiembre-2026-status");
  const submitBtn = document.getElementById(
    "septiembre-2026-submit",
  ) as HTMLButtonElement | null;
  const spinner = document.getElementById("septiembre-2026-spinner");
  const btnText = submitBtn?.querySelector("span");

  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const stepCheck = validateStepSection(form);
      if (!stepCheck.ok) {
        reportStepValidationFailure("Registro septiembre 2026", stepCheck);
        return;
      }

      const startCycleValue = (
        form.querySelector("#startCycle") as HTMLSelectElement | null
      )?.value?.trim();
      const program = (
        form.querySelector("#program") as HTMLSelectElement | null
      )?.value?.trim();
      const name = (form.querySelector("#name") as HTMLInputElement | null)?.value?.trim();
      const email = (form.querySelector("#email") as HTMLInputElement | null)?.value?.trim().toLowerCase();
      const phone = (form.querySelector("#phone") as HTMLInputElement | null)?.value?.trim();
      const website = (form.querySelector('input[name="website"]') as HTMLInputElement | null)?.value?.trim() ?? "";

      if (
        !program ||
        !allowedPrograms.includes(program) ||
        startCycleValue !== startCycle
      ) {
        reportStepValidationFailure("Registro septiembre 2026", {
          ok: false,
          missingLabels: ["Selecciona un programa y ciclo válidos"],
          highlightTargets: [
            form.querySelector("#program"),
            form.querySelector("#startCycle"),
          ].filter(Boolean) as HTMLElement[],
        });
        return;
      }

      if (statusDiv) {
        statusDiv.className = "hidden p-3 rounded-lg text-sm";
        statusDiv.textContent = "";
      }

      if (submitBtn && spinner && btnText) {
        submitBtn.disabled = true;
        spinner.classList.remove("hidden");
        btnText.textContent = "Enviando...";
      }

      try {
        const response = await fetch("/api/inscripciones-septiembre-2026", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            name,
            email,
            phone,
            program,
            startCycle: startCycleValue,
            website,
          }),
        });
        const result = (await response.json().catch(() => null)) as {
          message?: string;
          error?: string;
          code?: string;
        } | null;

        if (response.ok) {
          if (statusDiv) {
            statusDiv.textContent =
              "¡Gracias! Recibimos tu registro. Un asesor de CEPRIJA se comunicará contigo pronto.";
            statusDiv.classList.remove("hidden");
            statusDiv.classList.add(
              "bg-green-100",
              "text-green-800",
              "border",
              "border-green-200",
            );
          }
          form.reset();
          const programSelect = form.querySelector(
            "#program",
          ) as HTMLSelectElement | null;
          if (programSelect) programSelect.selectedIndex = 0;
        } else {
          const serverMessage = result?.message || result?.error;
          throw new Error(
            [serverMessage, result?.code].filter(Boolean).join(" — ") ||
              "Error al enviar el formulario",
          );
        }
      } catch (error) {
        if (statusDiv) {
          statusDiv.textContent =
            error instanceof Error && error.message
              ? error.message
              : "Hubo un error al enviar tu registro. Por favor intenta nuevamente o contáctanos por teléfono.";
          statusDiv.classList.remove("hidden");
          statusDiv.classList.add(
            "bg-red-100",
            "text-red-800",
            "border",
            "border-red-200",
          );
        }
        console.error("Error submitting September 2026 form:", error);
      } finally {
        if (submitBtn && spinner && btnText) {
          submitBtn.disabled = false;
          spinner.classList.add("hidden");
          btnText.textContent = "Enviar registro";
        }
      }
    });
  }
</script>
