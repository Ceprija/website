---
import {
    genres,
    nationalities,
    civilStates,
    states,
    modalitiesStandard,
    modalitiesCivil,
    studyGrades,
    yesNo,
    relatives,
    sources,
} from "../../data/forms/inscription-options.js";

interface Props {
    selectedProgram?: string;
    programList?: string[];
}

const { selectedProgram = "", programList = [] } = Astro.props;

const isCivil = selectedProgram.includes("Civil");
const initialModalities = isCivil ? modalitiesCivil : modalitiesStandard;
---

<!-- Carga de estilos de Flatpickr para el calendario -->
<link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css"
/>
<style>
    /* Personalización adicional para que coincida con la marca */
    .flatpickr-calendar {
        font-family: inherit;
        border: 2px solid #f3f4f6;
        border-radius: 1rem;
        box-shadow:
            0 10px 25px -5px rgba(0, 0, 0, 0.1),
            0 8px 10px -6px rgba(0, 0, 0, 0.1);
    }
    .flatpickr-day.selected,
    .flatpickr-day.startRange,
    .flatpickr-day.endRange,
    .flatpickr-day.selected.inRange,
    .flatpickr-day.startRange.inRange,
    .flatpickr-day.endRange.inRange,
    .flatpickr-day.selected:focus,
    .flatpickr-day.startRange:focus,
    .flatpickr-day.endRange:focus,
    .flatpickr-day.selected:hover,
    .flatpickr-day.startRange:hover,
    .flatpickr-day.endRange:hover,
    .flatpickr-day.selected.prevMonthDay,
    .flatpickr-day.startRange.prevMonthDay,
    .flatpickr-day.endRange.prevMonthDay,
    .flatpickr-day.selected.nextMonthDay,
    .flatpickr-day.startRange.nextMonthDay,
    .flatpickr-day.endRange.nextMonthDay {
        background: #1e3a8a; /* Color primary */
        border-color: #1e3a8a;
    }
</style>

<div
    class="max-w-4xl mx-auto bg-white rounded-3xl shadow-2xl overflow-hidden border border-gray-100"
    id="inscription-container"
>
    <!-- Header / Progress Bar -->
    <div class="bg-primary p-8 text-white">
        <h2 class="text-3xl font-bold font-serif mb-2">
            Formulario de Inscripción
        </h2>
        <p class="text-blue-100 opacity-90">
            Complete todos los campos para procesar su inscripción.
        </p>

        <div class="mt-8 relative">
            <div
                class="overflow-hidden h-2 mb-4 text-xs flex rounded bg-blue-900/30"
            >
                <div
                    id="progress-bar"
                    style="width: 16.66%"
                    class="shadow-none flex flex-col text-center whitespace-nowrap text-white justify-center bg-secondary transition-all duration-500"
                >
                </div>
            </div>
            <div
                class="flex justify-between text-xs font-semibold uppercase tracking-wider text-blue-100"
            >
                <span id="step-label">Paso 1 de 6: Datos Personales</span>
            </div>
        </div>
    </div>

    <form
        id="inscription-form"
        class="p-8 md:p-12 space-y-8"
        enctype="multipart/form-data"
    >
        <input type="hidden" name="origen" value="Web Inicia Inscripción" />

        <!-- SECCIÓN 1: DATOS PERSONALES -->
        <div class="step-section" id="step-1">
            <h3
                class="text-2xl font-bold text-primary mb-6 flex items-center gap-3"
            >
                <span
                    class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center text-sm"
                    >1</span
                >
                Datos Personales
            </h3>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="col-span-1 md:col-span-2">
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Programa Académico *</label
                    >
                    <select
                        name="programTitle"
                        id="program-select"
                        data-standard={JSON.stringify(modalitiesStandard)}
                        data-civil={JSON.stringify(modalitiesCivil)}
                        required
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all uppercase"
                    >
                        <option value="">SELECCIONA UN PROGRAMA</option>
                        {
                            programList.map((p) => (
                                <option
                                    value={p}
                                    selected={p === selectedProgram}
                                >
                                    {p.toUpperCase()}
                                </option>
                            ))
                        }
                    </select>
                </div>

                <div>
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Nombre(s) *</label
                    >
                    <input
                        type="text"
                        name="nombre"
                        required
                        placeholder="Tal como aparece en acta"
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                    />
                </div>

                <div>
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Apellidos *</label
                    >
                    <input
                        type="text"
                        name="apellidos"
                        required
                        placeholder="Paterno y Materno"
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                    />
                </div>

                <div>
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Género *</label
                    >
                    <select
                        name="genero"
                        required
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all uppercase"
                    >
                        <option value="">SELECCIONA...</option>
                        {
                            genres.map((g) => (
                                <option value={g}>{g.toUpperCase()}</option>
                            ))
                        }
                    </select>
                </div>

                <div>
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Teléfono Celular *</label
                    >
                    <input
                        type="tel"
                        name="telefono"
                        required
                        placeholder="10 dígitos"
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                    />
                </div>

                <div class="col-span-1 md:col-span-2">
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Correo Electrónico *</label
                    >
                    <input
                        type="email"
                        name="email"
                        required
                        placeholder="ejemplo@correo.com"
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                    />
                </div>

                <div>
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Fecha de Nacimiento *</label
                    >
                    <input
                        type="text"
                        name="fechaNacimiento"
                        required
                        placeholder="DD/MM/AAAA"
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all date-picker bg-white"
                    />
                </div>

                <div>
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >CURP *</label
                    >
                    <input
                        type="text"
                        name="curp"
                        required
                        maxlength="18"
                        placeholder="18 caracteres"
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all uppercase"
                    />
                </div>

                <div>
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Nacionalidad *</label
                    >
                    <input
                        type="text"
                        name="nacionalidad"
                        required
                        placeholder="Mexicana"
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all uppercase"
                    />
                </div>

                <div>
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Estado Civil *</label
                    >
                    <select
                        name="estadoCivil"
                        required
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all uppercase"
                    >
                        <option value="">SELECCIONA...</option>
                        {
                            civilStates.map((s) => (
                                <option value={s}>{s.toUpperCase()}</option>
                            ))
                        }
                    </select>
                </div>

                <div>
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Entidad de Nacimiento *</label
                    >
                    <select
                        name="entidadNacimiento"
                        required
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all uppercase"
                    >
                        <option value="">SELECCIONA...</option>
                        {
                            states.map((s) => (
                                <option value={s}>{s.toUpperCase()}</option>
                            ))
                        }
                    </select>
                </div>
            </div>
        </div>

        <!-- SECCIÓN 2: DIRECCIÓN -->
        <div class="step-section hidden" id="step-2">
            <h3
                class="text-2xl font-bold text-primary mb-6 flex items-center gap-3"
            >
                <span
                    class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center text-sm"
                    >2</span
                >
                Dirección Particular
            </h3>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="col-span-1 md:col-span-2">
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Calle y Número *</label
                    >
                    <input
                        type="text"
                        name="calle"
                        required
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                    />
                </div>
                <div>
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Colonia *</label
                    >
                    <input
                        type="text"
                        name="colonia"
                        required
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                    />
                </div>
                <div>
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Código Postal *</label
                    >
                    <input
                        type="text"
                        name="cp"
                        required
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                    />
                </div>
                <div>
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Ciudad/Municipio *</label
                    >
                    <input
                        type="text"
                        name="ciudad"
                        required
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                    />
                </div>
                <div>
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Estado *</label
                    >
                    <select
                        name="estadoDireccion"
                        required
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all uppercase"
                    >
                        <option value="">SELECCIONA...</option>
                        {
                            states.map((s) => (
                                <option value={s}>{s.toUpperCase()}</option>
                            ))
                        }
                    </select>
                </div>
            </div>
        </div>

        <!-- SECCIÓN 3: DATOS ACADÉMICOS -->
        <div class="step-section hidden" id="step-3">
            <h3
                class="text-2xl font-bold text-primary mb-6 flex items-center gap-3"
            >
                <span
                    class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center text-sm"
                    >3</span
                >
                Trayectoria Académica
            </h3>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Modalidad de Interés *</label
                    >
                    <select
                        name="modalidadEstudio"
                        id="modalidad-select"
                        required
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all uppercase"
                    >
                        {
                            initialModalities.map((m) => (
                                <option value={m}>{m.toUpperCase()}</option>
                            ))
                        }
                    </select>
                </div>
                <div>
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Último Grado de Estudios *</label
                    >
                    <select
                        name="ultimoGrado"
                        required
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all uppercase"
                    >
                        {
                            studyGrades.map((g) => (
                                <option value={g}>{g.toUpperCase()}</option>
                            ))
                        }
                    </select>
                </div>
                <div class="col-span-1 md:col-span-2">
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Carrera Cursada (Licenciatura) *</label
                    >
                    <input
                        type="text"
                        name="carrera"
                        required
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                    />
                </div>
                <div class="col-span-1 md:col-span-2">
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Institución de Egreso *</label
                    >
                    <input
                        type="text"
                        name="institucion"
                        required
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                    />
                </div>
                <div>
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Fecha Inicio Lic. *</label
                    >
                    <input
                        type="text"
                        name="fechaInicioLic"
                        required
                        placeholder="DD/MM/AAAA"
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all date-picker bg-white"
                    />
                </div>
                <div>
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Fecha Fin Lic. *</label
                    >
                    <input
                        type="text"
                        name="fechaFinLic"
                        required
                        placeholder="DD/MM/AAAA"
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all date-picker bg-white"
                    />
                </div>
                <div>
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Estado donde cursó *</label
                    >
                    <select
                        name="estadoLic"
                        required
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all uppercase"
                    >
                        <option value="">SELECCIONA...</option>
                        {
                            states.map((s) => (
                                <option value={s}>{s.toUpperCase()}</option>
                            ))
                        }
                    </select>
                </div>
                <div>
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Número de Cédula *</label
                    >
                    <input
                        type="text"
                        name="cedulaNum"
                        required
                        placeholder="Número de Cédula"
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                    />
                </div>
                <div class="col-span-1 md:col-span-2">
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Evidencia de Cédula (PDF/Imagen)</label
                    >
                    <div class="relative group cursor-pointer">
                        <input
                            type="file"
                            name="cedulaDoc"
                            accept=".pdf,image/*"
                            class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10 file-input-custom"
                        />
                        <div
                            class="w-full px-4 py-3 rounded-xl border-2 border-dashed border-gray-200 bg-gray-50 flex items-center gap-3 text-gray-500 group-hover:border-primary transition-all"
                        >
                            <span
                                class="px-4 py-2 bg-white border border-gray-200 rounded-lg text-sm font-semibold text-gray-700 shadow-sm"
                                >Seleccionar Archivo</span
                            >
                            <span class="file-name-text text-sm truncate"
                                >Ningún archivo seleccionado</span
                            >
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- SECCIÓN 4: DOCUMENTOS -->
        <div class="step-section hidden" id="step-4">
            <h3
                class="text-2xl font-bold text-primary mb-6 flex items-center gap-3"
            >
                <span
                    class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center text-sm"
                    >4</span
                >
                Carga de Documentación
            </h3>
            <p
                class="text-sm text-gray-600 mb-6 bg-blue-50 p-4 rounded-lg border border-blue-100"
            >
                Por favor, cargue sus archivos en formato PDF o imagen legible
                (Máx 5MB c/u).
            </p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="file-group">
                    <label class="block text-sm font-bold text-gray-700 mb-2"
                        >Acta de Nacimiento *</label
                    >
                    <div class="relative group cursor-pointer mt-2">
                        <input
                            type="file"
                            name="actaNacimiento"
                            required
                            accept=".pdf,image/*"
                            class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10 file-input-custom"
                        />
                        <div
                            class="w-full px-4 py-3 rounded-xl border-2 border-dashed border-gray-200 bg-gray-50 flex items-center gap-3 text-gray-500 group-hover:border-primary transition-all"
                        >
                            <span
                                class="px-4 py-2 bg-white border border-gray-200 rounded-lg text-sm font-semibold text-gray-700 shadow-sm flex-shrink-0"
                                >Seleccionar Archivo</span
                            >
                            <span class="file-name-text text-sm truncate"
                                >Ningún archivo seleccionado</span
                            >
                        </div>
                    </div>
                </div>
                <div class="file-group">
                    <label class="block text-sm font-bold text-gray-700 mb-2"
                        >CURP Actualizada *</label
                    >
                    <div class="relative group cursor-pointer mt-2">
                        <input
                            type="file"
                            name="curpDoc"
                            required
                            accept=".pdf,image/*"
                            class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10 file-input-custom"
                        />
                        <div
                            class="w-full px-4 py-3 rounded-xl border-2 border-dashed border-gray-200 bg-gray-50 flex items-center gap-3 text-gray-500 group-hover:border-primary transition-all"
                        >
                            <span
                                class="px-4 py-2 bg-white border border-gray-200 rounded-lg text-sm font-semibold text-gray-700 shadow-sm flex-shrink-0"
                                >Seleccionar Archivo</span
                            >
                            <span class="file-name-text text-sm truncate"
                                >Ningún archivo seleccionado</span
                            >
                        </div>
                    </div>
                </div>
                <div class="file-group">
                    <label class="block text-sm font-bold text-gray-700 mb-2"
                        >Comprobante Domicilio *</label
                    >
                    <div class="relative group cursor-pointer mt-2">
                        <input
                            type="file"
                            name="comprobanteDom"
                            required
                            accept=".pdf,image/*"
                            class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10 file-input-custom"
                        />
                        <div
                            class="w-full px-4 py-3 rounded-xl border-2 border-dashed border-gray-200 bg-gray-50 flex items-center gap-3 text-gray-500 group-hover:border-primary transition-all"
                        >
                            <span
                                class="px-4 py-2 bg-white border border-gray-200 rounded-lg text-sm font-semibold text-gray-700 shadow-sm flex-shrink-0"
                                >Seleccionar Archivo</span
                            >
                            <span class="file-name-text text-sm truncate"
                                >Ningún archivo seleccionado</span
                            >
                        </div>
                    </div>
                </div>
                <div class="file-group">
                    <label class="block text-sm font-bold text-gray-700 mb-2"
                        >INE (Ambos lados) *</label
                    >
                    <div class="relative group cursor-pointer mt-2">
                        <input
                            type="file"
                            name="ineDoc"
                            required
                            accept=".pdf,image/*"
                            class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10 file-input-custom"
                        />
                        <div
                            class="w-full px-4 py-3 rounded-xl border-2 border-dashed border-gray-200 bg-gray-50 flex items-center gap-3 text-gray-500 group-hover:border-primary transition-all"
                        >
                            <span
                                class="px-4 py-2 bg-white border border-gray-200 rounded-lg text-sm font-semibold text-gray-700 shadow-sm flex-shrink-0"
                                >Seleccionar Archivo</span
                            >
                            <span class="file-name-text text-sm truncate"
                                >Ningún archivo seleccionado</span
                            >
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- SECCIÓN 5: SALUD -->
        <div class="step-section hidden" id="step-5">
            <h3
                class="text-2xl font-bold text-primary mb-6 flex items-center gap-3"
            >
                <span
                    class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center text-sm"
                    >5</span
                >
                Información de Salud
            </h3>

            <div class="space-y-6">
                <!-- Capacidad Diferente -->
                <div class="p-6 bg-gray-50 rounded-2xl border border-gray-100">
                    <label class="block font-semibold text-gray-800 mb-3"
                        >¿Presenta alguna capacidad diferente? *</label
                    >
                    <div class="flex gap-4">
                        {
                            yesNo.map((val) => (
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input
                                        type="radio"
                                        name="capacidadDif"
                                        value={val}
                                        required
                                        class="w-5 h-5 accent-primary"
                                        data-toggle={`capacidad-detail-${val}`}
                                    />
                                    <span>{val}</span>
                                </label>
                            ))
                        }
                    </div>
                    <textarea
                        name="detalleCapacidad"
                        id="capacidad-detail-Sí"
                        placeholder="Especifique cuál(es)..."
                        class="mt-4 w-full p-4 rounded-xl border-2 border-gray-200 hidden outline-none focus:border-primary"
                    ></textarea>
                </div>

                <!-- Enfermedad Crónica -->
                <div class="p-6 bg-gray-50 rounded-2xl border border-gray-100">
                    <label class="block font-semibold text-gray-800 mb-3"
                        >¿Padece alguna enfermedad crónica? *</label
                    >
                    <div class="flex gap-4">
                        {
