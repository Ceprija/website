    document.addEventListener("DOMContentLoaded", () => {
        flatpickr(".date-picker", {
            locale: "es", // Establece español
            dateFormat: "Y-m-d", // Formato para el backend
            altInput: true,
            altFormat: "d/m/Y", // Formato visual para el usuario DD/MM/AAAA
            allowInput: true, // Permite que el usuario escriba
            disableMobile: true, // Forza el calendario estilizado en móvil también si se desea
        });
    });
</script>

