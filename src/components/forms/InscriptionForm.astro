<script>
    import {
        validateRequiredFieldsInContainer,
        reportStepValidationFailure,
    } from "@lib/client/multiStepFormValidation";

    const form = document.getElementById("inscription-form") as HTMLFormElement;

    // Validaciones: Convertir a MAYÚSCULAS
    document
        .querySelectorAll('input[type="text"], textarea, select')
        .forEach((el: any) => {
            if (el.tagName === "INPUT" || el.tagName === "TEXTAREA") {
                el.addEventListener("input", (e: any) => {
                    e.target.value = e.target.value.toUpperCase();
                });
            }
            el.style.textTransform = "uppercase";
        });

    // Validaciones: Solo números
    document
        .querySelectorAll('input[type="tel"], input[name="cp"]')
        .forEach((el: any) => {
            el.addEventListener("input", (e: any) => {
                e.target.value = e.target.value.replace(/[^0-9]/g, "");
            });
        });

    const progress = document.getElementById("progress-bar");
    const stepLabel = document.getElementById("step-label");
    const sections = document.querySelectorAll(".step-section");
    const prevBtn = document.getElementById("prev-btn") as HTMLButtonElement;
    const nextBtn = document.getElementById("next-btn") as HTMLButtonElement;
    const submitBtn = document.getElementById(
        "submit-btn",
    ) as HTMLButtonElement;
    const successMsg = document.getElementById("success-msg");
    const programSelect = document.getElementById(
        "program-select",
    ) as HTMLSelectElement;
    const modalidadSelect = document.getElementById(
        "modalidad-select",
    ) as HTMLSelectElement;

    programSelect?.addEventListener("change", () => {
        const isCivil = programSelect.value.includes("Civil");
        const standard = JSON.parse(programSelect.dataset.standard || "[]");
        const civil = JSON.parse(programSelect.dataset.civil || "[]");
        const options = isCivil ? civil : standard;

        if (modalidadSelect) {
            modalidadSelect.innerHTML = "";
            options.forEach((opt: string) => {
                const option = document.createElement("option");
                option.value = opt;
                option.textContent = opt.toUpperCase();
                modalidadSelect.appendChild(option);
            });
        }
    });

    let currentStep = 1;
    const totalSteps = 6;
    const stepNames = [
        "Datos Personales",
        "Dirección Particular",
        "Trayectoria Académica",
        "Documentación",
        "Salud",
        "Contacto y Finalización",
    ];

    function updateStep() {
        // Update Sections
        sections.forEach((s, i) => {
            s.classList.toggle("hidden", i + 1 !== currentStep);
        });

        // Update Progress
        const percent = (currentStep / totalSteps) * 100;
        if (progress) progress.style.width = `${percent}%`;
        if (stepLabel)
            stepLabel.textContent = `Paso ${currentStep} de ${totalSteps}: ${stepNames[currentStep - 1]}`;

        // Update Buttons
        if (prevBtn) prevBtn.classList.toggle("hidden", currentStep === 1);
        if (nextBtn)
            nextBtn.classList.toggle("hidden", currentStep === totalSteps);
        if (submitBtn)
            submitBtn.classList.toggle("hidden", currentStep !== totalSteps);

        // Scroll to top of form
        document
            .getElementById("inscription-container")
            ?.scrollIntoView({ behavior: "smooth" });
    }

    nextBtn?.addEventListener("click", () => {
        const section = sections[currentStep - 1];
        if (!section) return;
        const result = validateRequiredFieldsInContainer(section);
        if (!result.ok) {
            const title = `Paso ${currentStep} de ${totalSteps}: ${stepNames[currentStep - 1]}`;
            reportStepValidationFailure(title, result);
            return;
        }
        if (currentStep < totalSteps) {
            currentStep++;
            updateStep();
        }
    });

    prevBtn?.addEventListener("click", () => {
        if (currentStep > 1) {
            currentStep--;
            updateStep();
        }
    });

    // Toggle fields logic
    document.querySelectorAll('input[type="radio"]').forEach((radio) => {
        radio.addEventListener("change", (e: any) => {
            const name = e.target.name;
            const value = e.target.value;
            const container = e.target.closest(".p-6");
            const textarea = container?.querySelector("textarea");

            if (textarea) {
                if (value === "Sí") {
                    textarea.classList.remove("hidden");
                    textarea.required = true;
                } else {
                    textarea.classList.add("hidden");
                    textarea.required = false;
                }
            }
        });
    });

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();

        for (let i = 0; i < totalSteps; i++) {
            const r = validateRequiredFieldsInContainer(sections[i]);
            if (!r.ok) {
                currentStep = i + 1;
                updateStep();
                const title = `Paso ${i + 1} de ${totalSteps}: ${stepNames[i]}`;
                reportStepValidationFailure(title, r);
                return;
            }
        }

        const loader = document.getElementById("spinner");
        const btnText = submitBtn.querySelector("span");

        submitBtn.disabled = true;
        loader?.classList.remove("hidden");
        if (btnText) btnText.textContent = "Procesando...";

        try {
            const formData = new FormData(form);
            const res = await fetch("/api/inscription", {
                method: "POST",
                body: formData,
            });

            if (res.ok) {
                form.classList.add("hidden");
                document.querySelector(".bg-primary")?.classList.add("hidden");
                successMsg?.classList.remove("hidden");
            } else {
                const data = await res.json();
                alert(
                    `Error: ${data.message || "No se pudo procesar la inscripción"}`,
                );
                submitBtn.disabled = false;
                loader?.classList.add("hidden");
                if (btnText) btnText.textContent = "Finalizar Inscripción";
            }
        } catch (err) {
            alert("Error de conexión con el servidor");
            submitBtn.disabled = false;
            loader?.classList.add("hidden");
            if (btnText) btnText.textContent = "Finalizar Inscripción";
        }
    });

    // Validaciones: Actualizar texto de archivos seleccionados
    document.querySelectorAll(".file-input-custom").forEach((input: any) => {
        input.addEventListener("change", (e: any) => {
            const fileNameText =
                e.target.parentElement.querySelector(".file-name-text");
            if (e.target.files && e.target.files.length > 0) {
                fileNameText.textContent = e.target.files[0].name;
                fileNameText.classList.add("text-primary", "font-semibold");
                fileNameText.classList.remove("text-gray-500");
            } else {
                fileNameText.textContent = "Ningún archivo seleccionado";
                fileNameText.classList.remove("text-primary", "font-semibold");
                fileNameText.classList.add("text-gray-500");
            }
        });
    });
</script>

