---
import Button from "../ui/Button.astro";

interface Props {
    programTitle?: string;
    /** Dentro de `ProgramEnrollmentAsideCard`: sin segundo contenedor sticky/sombra. */
    embedInAsideCard?: boolean;
}

const {
    programTitle = "General Inquiry",
    embedInAsideCard = false,
} = Astro.props;

const shellClass = embedInAsideCard
    ? "w-full"
    : "bg-white rounded-2xl shadow-lg p-8 sticky top-24 border-t-4 border-secondary";

const fieldClass =
    "w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all";
const labelClass = "block text-sm font-semibold text-gray-700 mb-2";
---

<div class:list={[shellClass]}>
    <h3 class="text-2xl font-bold text-primary mb-2 font-serif">
        Solicita información
    </h3>
    {
        embedInAsideCard && (
            <p class="text-gray-600 mb-6 text-sm">
                Este programa aún no tiene inscripción en línea con pago. Envía
                tus datos y nos pondremos en contacto contigo.
            </p>
        )
    }
    {
        !embedInAsideCard && (
            <p class="text-gray-600 mb-6 text-sm">
                Cuéntanos cómo podemos ayudarte; te responderemos pronto.
            </p>
        )
    }

    <form id="contact-form" class="space-y-5">
        <input type="hidden" name="program" value={programTitle} />
        <input type="hidden" name="type" value="contact" />

        <div>
            <label for="name" class:list={[labelClass]}
                >Nombre completo *</label
            >
            <input
                type="text"
                id="name"
                name="name"
                required
                maxlength="200"
                class:list={[fieldClass]}
                placeholder="Tu nombre"
            />
        </div>

        <div>
            <label for="email" class:list={[labelClass]}
                >Correo electrónico *</label
            >
            <input
                type="email"
                id="email"
                name="email"
                required
                maxlength="254"
                class:list={[fieldClass]}
                placeholder="tu@email.com"
            />
        </div>

        <div>
            <label for="phone" class:list={[labelClass]}>Teléfono *</label>
            <input
                type="tel"
                id="phone"
                name="phone"
                required
                maxlength="18"
                inputmode="tel"
                autocomplete="tel-national"
                class:list={[fieldClass]}
                placeholder="Ej. 5512345678 o +52 55…"
            />
        </div>

        <div>
            <label for="message" class:list={[labelClass]}>Mensaje</label>
            <textarea
                id="message"
                name="message"
                rows="3"
                maxlength="2000"
                class:list={[fieldClass]}
                placeholder="¿Qué te gustaría saber?"></textarea>
        </div>

        <div
            id="form-status"
            role="status"
            aria-live="polite"
            class="hidden mb-4 p-3 rounded-lg text-sm"
        >
        </div>

        <Button
            type="submit"
            id="submit-btn"
            variant="secondary"
            class="w-full flex justify-center items-center gap-2"
        >
            <span>Enviar Solicitud</span>
            <svg
                class="animate-spin h-5 w-5 text-primary hidden"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                id="loading-spinner"
            >
                <circle
                    class="opacity-25"
                    cx="12"
                    cy="12"
                    r="10"
                    stroke="currentColor"
                    stroke-width="4"></circle>
                <path
                    class="opacity-75"
                    fill="currentColor"
                    d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                ></path>
            </svg>
        </Button>
    </form>

    <div class="mt-8 pt-8 border-t border-gray-200">
        <a
            href="/oferta-academica"
            class="inline-flex items-center gap-3 text-gray-600 hover:text-primary font-medium transition-colors group"
        >
            <div
                class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-all duration-300 shadow-sm group-hover:shadow"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-5 w-5 transform group-hover:-translate-x-1 transition-transform"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 19l-7-7 7-7"></path>
                </svg>
            </div>
            <span>Ver todos los programas</span>
        </a>
    </div>
</div>

<script>
    import {
        validateStepSection,
        reportStepValidationFailure,
    } from "@lib/client/multiStepFormValidation";

    const form = document.getElementById("contact-form") as HTMLFormElement;
    const statusDiv = document.getElementById("form-status");
    const submitBtn = document.getElementById(
        "submit-btn",
    ) as HTMLButtonElement;
    const spinner = document.getElementById("loading-spinner");
    const btnText = submitBtn?.querySelector("span");

    document.querySelectorAll('#contact-form input[type="tel"]').forEach((el) => {
        el.addEventListener("input", (e) => {
            const t = e.target as HTMLInputElement;
            t.value = t.value.replace(/\D/g, "").slice(0, 18);
        });
    });

    if (form) {
        form.addEventListener("submit", async (e) => {
            e.preventDefault();

            const stepCheck = validateStepSection(form);
            if (!stepCheck.ok) {
                reportStepValidationFailure("Solicita información", stepCheck);
                return;
            }

            // Reset status
            if (statusDiv) {
                statusDiv.classList.add("hidden");
                statusDiv.className = "hidden mb-4 p-3 rounded-lg text-sm";
            }

            // Loading state
            if (submitBtn && spinner && btnText) {
                submitBtn.disabled = true;
                spinner.classList.remove("hidden");
                btnText.textContent = "Enviando...";
            }

            const formData = new FormData(form);

            try {
                const response = await fetch("/api/register", {
                    method: "POST",
                    body: formData,
                });

                const result = await response.json();

                if (response.ok) {
                    // Success
                    if (statusDiv) {
                        statusDiv.textContent =
                            "¡Gracias! Tu solicitud ha sido enviada correctamente. Nos pondremos en contacto contigo pronto.";
                        statusDiv.classList.remove("hidden");
                        statusDiv.classList.add(
                            "bg-green-100",
                            "text-green-800",
                            "border",
                            "border-green-200",
                        );
                    }
                    form.reset();
                } else {
                    throw new Error(
                        [result.message, result.code].filter(Boolean).join(" — ") ||
                            "Error al enviar el formulario",
                    );
                }
            } catch (error) {
                // Network or other error
                if (statusDiv) {
                    statusDiv.textContent =
                        "Hubo un error al enviar tu solicitud. Por favor intenta nuevamente o contáctanos por teléfono.";
                    statusDiv.classList.remove("hidden");
                    statusDiv.classList.add(
                        "bg-red-100",
                        "text-red-800",
                        "border",
                        "border-red-200",
                    );
                }
                console.error("Error submitting form:", error);
            } finally {
                // Reset button state
                if (submitBtn && spinner && btnText) {
                    submitBtn.disabled = false;
                    spinner.classList.add("hidden");
                    btnText.textContent = "Enviar Solicitud";
                }
            }
        });
    }
</script>
