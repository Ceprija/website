---
import { ecConsentLabels } from "@data/forms/educacion-continua-options";
import bankInfo from "@data/bank-info.json";
import type { PaymentOption } from "@lib/programPayments";
import { formatPrice } from "@lib/programPayments";

interface Props {
    programTitle?: string;
    programId?: string;
    stripePriceIds?: {
        online?: string;
        presencial?: string;
    };
    prices?: {
        Presencial?: string;
        Online?: string;
    };
    /** Varias opciones de pago (inscripción, paquete, cuotas): el usuario elige antes de Stripe. */
    paymentOptions?: PaymentOption[];
    address?: string;
    requiresVerification?: boolean;
    /** Cuando el formulario va dentro de ProgramEnrollmentAsideCard (evita doble “card”). */
    embedInAsideCard?: boolean;
}

const {
    programTitle = "",
    programId = "",
    stripePriceIds,
    prices,
    paymentOptions: paymentOptionsProp,
    address = "Instalaciones de CEPRIJA - Lope de Vega #273, Col. Americana Arcos. C.P. 44500",
    requiresVerification = false,
    embedInAsideCard = false,
} = Astro.props;

const paymentOptions = paymentOptionsProp ?? [];
const showPaymentPlanChoice = paymentOptions.length > 1;

const outerClass = embedInAsideCard ? "w-full" : "max-w-4xl mx-auto overflow-visible";
const formSurfaceClass = embedInAsideCard
    ? "bg-transparent border-0 shadow-none rounded-none overflow-visible"
    : "bg-white rounded-3xl shadow-xl shadow-blue-900/5 border border-gray-100 overflow-visible";
const successSurfaceClass = embedInAsideCard
    ? "rounded-2xl border border-gray-100 shadow-sm"
    : "rounded-3xl shadow-xl border border-gray-100";
const formFooterClass = embedInAsideCard
    ? "bg-white px-0 py-6 border-t border-gray-100 flex items-center justify-between gap-4"
    : "bg-white px-8 py-6 md:px-12 md:py-8 border-t border-gray-100 flex items-center justify-between gap-4 rounded-b-3xl";
---

<div class:list={[outerClass]}>
    <!-- Stepper Header -->
    <div class="mb-12">
        <div
            class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between mb-4"
        >
            <h2
                class="text-xl sm:text-2xl font-bold text-primary font-serif pr-2"
                id="step-label"
            >
                Paso 1 de 3: Datos del Participante
            </h2>
            <span
                class="text-sm font-semibold text-gray-500 shrink-0"
                id="step-number">33% completado</span
            >
        </div>
        <div class="w-full bg-gray-100 h-3 rounded-full overflow-hidden">
            <div
                id="progress-bar"
                class="bg-secondary h-full w-1/3 transition-all duration-500 ease-out shadow-sm shadow-secondary/20"
            >
            </div>
        </div>
    </div>

    <form
        id="ce-inscription-form"
        data-stripe-price-ids={JSON.stringify(stripePriceIds || null)}
        data-prices={JSON.stringify(prices || null)}
        data-payment-options={JSON.stringify(paymentOptions)}
        data-address={address}
        data-bank-info={JSON.stringify(bankInfo)}
        data-requires-verification={requiresVerification ? "1" : "0"}
        class:list={[formSurfaceClass]}
    >
        <input
            type="hidden"
            name="programId"
            id="form-program-id"
            value={programId}
        />
        <input
            type="hidden"
            name="programTitle"
            id="form-program-title"
            value={programTitle}
        />
        <input type="hidden" name="paymentMethod" id="payment-method" value="stripe" />
        <input type="hidden" name="wireReference" id="wire-reference" value="" />
        <input type="hidden" name="enrollmentSessionId" id="ce-enrollment-session-id" value="" />

        <!-- SECCIÓN 1: DATOS PERSONALES -->
        <div class="step-section p-8 md:p-12" id="step-1">
            <div class="mb-10 text-center">
                <div
                    class="inline-block p-4 bg-blue-50 rounded-2xl mb-4 text-primary"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-8 w-8"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                        ></path>
                    </svg>
                </div>
                <h3
                    class="text-2xl font-bold text-gray-900 mb-2 font-serif"
                    id="program-header-title"
                >
                    {programTitle || "Título del Programa"}
                </h3>
                <p class="text-gray-500 text-sm max-w-lg mx-auto">
                    Bienvenido(a) al Centro de Preparación Integral en Materia
                    Jurídica y Administrativa (CEPRIJA). Sus datos serán
                    tratados para fines académicos y administrativos de acuerdo
                    a nuestro Aviso de Privacidad.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="col-span-1 md:col-span-2">
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Nombre completo *</label
                    >
                    <input
                        type="text"
                        name="name"
                        required
                        placeholder="Tu nombre completo"
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all uppercase"
                    />
                </div>
                <div>
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Teléfono *</label
                    >
                    <input
                        type="tel"
                        name="phone"
                        required
                        placeholder="33 0000 0000"
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                    />
                </div>
                <div>
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Correo electrónico *</label
                    >
                    <input
                        type="email"
                        name="email"
                        required
                        placeholder="tu@correo.com"
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                    />
                </div>

                <div class="col-span-1 md:col-span-2" id="modality-section">
                    {/*
                      Modalidad: value Presencial | En línea — alineado con
                      src/lib/validation/enrollment.ts (normalizeWireModality).
                    */}
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-3"
                        >Modalidad *</label
                    >
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <label
                            class="flex items-center gap-3 p-4 border-2 border-gray-100 rounded-2xl cursor-pointer hover:bg-gray-50 transition-all has-[:checked]:border-primary has-[:checked]:bg-blue-50 group"
                        >
                            <input
                                type="radio"
                                name="modality"
                                value="Presencial"
                                required
                                checked
                                class="w-5 h-5 text-primary focus:ring-primary"
                            />
                            <div class="flex flex-col">
                                <span class="font-bold text-gray-900"
                                    >Presencial</span
                                >
                                <span class="text-xs text-gray-500"
                                    >Asistencia en aula</span
                                >
                            </div>
                        </label>
                        <label
                            class="flex items-center gap-3 p-4 border-2 border-gray-100 rounded-2xl cursor-pointer hover:bg-gray-50 transition-all has-[:checked]:border-primary has-[:checked]:bg-blue-50 group"
                        >
                            <input
                                type="radio"
                                name="modality"
                                value="En línea"
                                required
                                class="w-5 h-5 text-primary focus:ring-primary"
                            />
                            <div class="flex flex-col">
                                <span class="font-bold text-gray-900"
                                    >En línea</span
                                >
                                <span class="text-xs text-gray-500"
                                    >Vía videoconferencia</span
                                >
                            </div>
                        </label>
                    </div>
                </div>

                <div
                    class="col-span-1 md:col-span-2 space-y-4 pt-4 border-t border-gray-100 mt-4"
                >
                    <p class="text-xs text-gray-500 italic mb-2">
                        Aviso de privacidad, políticas de uso de imagen y redes
                        sociales.
                    </p>
                    {
                        ecConsentLabels.map((label, i) => (
                            <label class="flex items-start gap-3 cursor-pointer group">
                                <input
                                    type="checkbox"
                                    required
                                    class="mt-1 w-5 h-5 rounded border-gray-300 text-primary focus:ring-primary"
                                />
                                <span class="text-sm text-gray-600 group-hover:text-gray-900 transition-colors">
                                    {label} *
                                </span>
                            </label>
                        ))
                    }
                </div>
            </div>
        </div>

        <!-- SECCIÓN 2: PAGO -->
        <div class="step-section p-8 md:p-12 hidden" id="step-2">
            <div class="mb-10 text-center">
                <div
                    class="inline-block p-4 bg-blue-50 rounded-2xl mb-4 text-primary"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-8 w-8"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"
                        ></path>
                    </svg>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 mb-2 font-serif">
                    Realizar Pago
                </h3>
                <p class="text-gray-500 text-sm">
                    Le recordamos realizar su pago antes de finalizar el
                    registro para garantizar su lugar.
                </p>
            </div>

            {
                showPaymentPlanChoice && (
                    <div class="mb-8" id="payment-plan-section">
                        <label class="block text-sm font-semibold text-gray-700 mb-3">
                            Opción de inversión *
                        </label>
                        <div class="grid grid-cols-1 gap-4">
                            {paymentOptions.map((opt, idx) => (
                                <label class="flex items-start gap-3 p-4 border-2 border-gray-100 rounded-2xl cursor-pointer hover:bg-gray-50 transition-all has-[:checked]:border-primary has-[:checked]:bg-blue-50 group">
                                    <input
                                        type="radio"
                                        name="paymentPlan"
                                        value={opt.id}
                                        required
                                        checked={idx === 0}
                                        class="w-5 h-5 text-primary focus:ring-primary shrink-0 mt-0.5"
                                    />
                                    <div class="flex flex-col gap-0.5 min-w-0">
                                        <span class="font-bold text-gray-900">
                                            {opt.label}
                                        </span>
                                        <span class="text-sm text-gray-600">
                                            {formatPrice(opt.price)}
                                        </span>
                                    </div>
                                </label>
                            ))}
                        </div>
                        {paymentOptions.some((o) => o.id === "diferido") && (
                            <p class="mt-4 text-xs text-amber-900 bg-amber-50 border border-amber-100 rounded-xl px-4 py-3 leading-relaxed">
                                <strong>Plan en cuotas:</strong> no incluye la
                                inscripción. Debes cubrirla por separado
                                eligiendo la opción «Inscripción» en este mismo
                                formulario (u otra indicación de control
                                escolar).
                            </p>
                        )}
                    </div>
                )
            }

            <!-- Método de pago -->
            <div class="mb-8">
                <label class="block text-sm font-semibold text-gray-700 mb-3"
                    >Método de pago *</label
                >
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <label
                        class="flex items-center gap-3 p-4 border-2 border-gray-100 rounded-2xl cursor-pointer hover:bg-gray-50 transition-all has-[:checked]:border-primary has-[:checked]:bg-blue-50"
                    >
                        <input
                            type="radio"
                            name="paymentMethodChoice"
                            value="stripe"
                            checked
                            class="w-5 h-5 text-primary focus:ring-primary"
                        />
                        <div class="flex flex-col">
                            <span class="font-bold text-gray-900"
                                >Pago en línea (Stripe)</span
                            >
                            <span class="text-xs text-gray-500"
                                >Confirmación automática</span
                            >
                        </div>
                    </label>
                    <label
                        class="flex items-center gap-3 p-4 border-2 border-gray-100 rounded-2xl cursor-pointer hover:bg-gray-50 transition-all has-[:checked]:border-primary has-[:checked]:bg-blue-50"
                    >
                        <input
                            type="radio"
                            name="paymentMethodChoice"
                            value="wire"
                            class="w-5 h-5 text-primary focus:ring-primary"
                        />
                        <div class="flex flex-col">
                            <span class="font-bold text-gray-900"
                                >Transferencia bancaria</span
                            >
                            <span class="text-xs text-gray-500"
                                >Sube tu comprobante (pago en revisión)</span
                            >
                        </div>
                    </label>
                </div>
            </div>

            <!-- Métodos de Pago UI -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-10">
                <div
                    class="p-6 bg-gradient-to-br from-white to-gray-50 border border-gray-200 rounded-2xl shadow-sm"
                    id="wire-panel"
                >
                    <div class="flex items-center gap-3 mb-4 text-primary">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-6 w-6"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"
                            ></path>
                        </svg>
                        <h4 class="font-bold text-sm uppercase tracking-wider">
                            Transferencia
                        </h4>
                    </div>
                    <div class="space-y-2 text-xs text-gray-600">
                        <div class="flex items-center justify-between gap-3">
                            <p class="truncate">
                                <strong>Banco:</strong> {bankInfo.bankName}
                            </p>
                            <button
                                type="button"
                                class="text-primary font-bold hover:underline"
                                data-copy={bankInfo.bankName}
                            >
                                Copiar
                            </button>
                        </div>
                        <div class="flex items-center justify-between gap-3">
                            <p class="truncate">
                                <strong>Titular:</strong> {bankInfo.accountHolder}
                            </p>
                            <button
                                type="button"
                                class="text-primary font-bold hover:underline"
                                data-copy={bankInfo.accountHolder}
                            >
                                Copiar
                            </button>
                        </div>
                        <div class="flex items-center justify-between gap-3">
                            <p class="truncate">
                                <strong>No. Cuenta:</strong> {bankInfo.accountNumber}
                            </p>
                            <button
                                type="button"
                                class="text-primary font-bold hover:underline"
                                data-copy={bankInfo.accountNumber}
                            >
                                Copiar
                            </button>
                        </div>
                        <div class="flex items-center justify-between gap-3">
                            <p class="truncate">
                                <strong>CLABE:</strong> {bankInfo.clabe}
                            </p>
                            <button
                                type="button"
                                class="text-primary font-bold hover:underline"
                                data-copy={bankInfo.clabe}
                            >
                                Copiar
                            </button>
                        </div>
                        {bankInfo.swiftCode && (
                            <div class="flex items-center justify-between gap-3">
                                <p class="truncate">
                                    <strong>SWIFT:</strong> {bankInfo.swiftCode}
                                </p>
                                <button
                                    type="button"
                                    class="text-primary font-bold hover:underline"
                                    data-copy={bankInfo.swiftCode}
                                >
                                    Copiar
                                </button>
                            </div>
                        )}
                        <div class="pt-3 mt-3 border-t border-gray-200">
                            <p class="text-xs text-gray-600">
                                <strong>Referencia:</strong>
                                <span id="wire-reference-preview"></span>
                            </p>
                        </div>
                    </div>
                </div>

                <div
                    class="p-8 bg-gradient-to-br from-blue-50 to-white border-2 border-primary/20 rounded-2xl"
                    id="stripe-panel"
                >
                    <div class="flex items-center gap-3 mb-4 text-primary">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-8 w-8"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"
                            ></path>
                        </svg>
                        <h4 class="text-xl font-bold">Proceder al Pago</h4>
                    </div>
                    <p class="text-gray-600 mb-6 leading-relaxed">
                        Serás redirigido a Stripe para completar tu pago de forma segura. 
                        Tu información está protegida con encriptación de nivel bancario.
                    </p>
                    <button
                        type="button"
                        id="stripe-checkout-btn"
                        class="w-full bg-primary text-white font-bold py-4 px-6 rounded-xl hover:bg-blue-900 transition-all shadow-lg hover:shadow-xl flex items-center justify-center gap-2"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" />
                        </svg>
                        <span>Continuar al Pago Seguro →</span>
                    </button>
                    <p class="text-xs text-gray-500 mt-4 text-center">
                        🔒 Pago procesado por Stripe
                    </p>
                </div>

                <!-- <div
                    class="p-6 bg-gradient-to-br from-white to-gray-50 border border-gray-200 rounded-2xl shadow-sm"
                >
                    <div class="flex items-center gap-3 mb-4 text-primary">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-6 w-6"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                            ></path>
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                        <h4 class="font-bold text-sm uppercase tracking-wider">
                            Efectivo
                        </h4>
                    </div>
                    <p class="text-xs text-gray-600 leading-tight">
                        En nuestras oficinas:<br />
                        <span
                            id="form-address-display"
                            class="text-gray-400 font-medium">{address}</span
                        >
                    </p>
                </div> -->
            </div>

            <!-- Wire proof upload (required when wire selected) -->
            <div id="wire-proof-section" class="hidden">
                <div class="p-6 bg-white rounded-2xl border border-gray-200 mb-10">
                    <h4 class="font-bold text-gray-900 mb-2">Comprobante de pago</h4>
                    <p class="text-xs text-gray-600 mb-4">
                        Sube tu comprobante de transferencia. Tu pago quedará en revisión.
                    </p>
                    <input
                        type="file"
                        id="payment-proof-input"
                        name="paymentProof"
                        accept=".pdf,image/*"
                        class="w-full text-sm"
                    />
                </div>
            </div>

            <div class="p-4 bg-white rounded-xl border border-gray-100">
                <label class="block text-sm font-bold text-primary mb-3"
                    >¿Requiere factura? *</label
                >
                <div class="flex flex-wrap gap-6">
                    <label class="flex items-center gap-2 cursor-pointer group">
                        <input
                            type="radio"
                            name="requiresInvoice"
                            value="Sí"
                            required
                            class="w-5 h-5 text-primary focus:ring-primary"
                        />
                        <span
                            class="font-medium text-gray-900 group-hover:text-primary transition-colors"
                            >Sí</span
                        >
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer group">
                        <input
                            type="radio"
                            name="requiresInvoice"
                            value="No"
                            required
                            checked
                            class="w-5 h-5 text-primary focus:ring-primary"
                        />
                        <span
                            class="font-medium text-gray-900 group-hover:text-primary transition-colors"
                            >No</span
                        >
                    </label>
                </div>
            </div>

            <div id="invoice-fields" class="space-y-4 mt-6 hidden">
                <div
                    class="p-4 bg-white rounded-xl border border-gray-200 space-y-4"
                >
                    <p class="text-xs text-gray-600">
                        Sube tu <strong>CSF</strong> (constancia de situación
                        fiscal) y el correo para facturación.
                    </p>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label
                            class="block text-sm font-semibold text-gray-700 mb-2"
                            >Constancia de Situación Fiscal *</label
                        >
                        <div class="relative group">
                            <input
                                type="file"
                                id="csf-input"
                                name="fiscalConstancy"
                                accept=".pdf,image/*"
                                class="hidden"
                            />
                            <label
                                for="csf-input"
                                class="flex items-center gap-3 px-4 py-3 border-2 border-gray-100 rounded-xl cursor-pointer hover:bg-gray-50 transition-all group-hover:border-primary"
                            >
                                <div
                                    class="bg-primary text-white p-2 rounded-lg"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-5 w-5"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"
                                        ></path>
                                    </svg>
                                </div>
                                <span
                                    class="text-sm font-bold text-gray-600 truncate"
                                    id="csf-file-label">Subir CSF</span
                                >
                            </label>
                        </div>
                    </div>

                    <div>
                        <label
                            class="block text-sm font-semibold text-gray-700 mb-2"
                            >Correo para recibir factura *</label
                        >
                        <input
                            type="email"
                            name="invoiceEmail"
                            placeholder="correo@facturacion.com"
                            class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                        />
                    </div>
                </div>
            </div>
        </div>
        </div>

        <!-- SECCIÓN 3: DECLARACIÓN Y ENVÍO -->
        <div class="step-section p-8 md:p-12 hidden" id="step-3">
            <!-- Este encabezado cambiará dinámicamente según si requiere factura o no -->
            <div id="invoice-header" class="mb-10 text-center">
                <div
                    class="inline-block p-4 bg-primary rounded-2xl mb-4 text-white"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-8 w-8"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                        ></path>
                    </svg>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 mb-2 font-serif">
                    Finalizar Inscripción
                </h3>
                <p class="text-gray-500 text-sm">
                    Verifique que toda la información sea correcta antes de
                    enviar.
                </p>
            </div>

            <div
                class="mt-8 p-6 bg-yellow-50 rounded-2xl border border-yellow-200 flex gap-4"
            >
                <input
                    type="checkbox"
                    required
                    class="w-6 h-6 mt-1 accent-primary"
                />
                <p class="text-sm text-gray-700">
                    Declaro bajo protesta de decir verdad que los datos aquí
                    asentados son ciertos y que cuento con la documentación
                    original para su cotejo. Acepto los términos del aviso de
                    privacidad.
                </p>
            </div>
        </div>

        <!-- Footer: flujo normal (como origin/main). Evitar position:fixed dentro
             de secciones con data-animate/transform: el botón queda fuera de vista.
             Cuando embedInAsideCard, usar px-0 para evitar overflow del card parent. -->
        <div class:list={[formFooterClass]}>
            <button
                type="button"
                id="prev-btn"
                class="hidden shrink-0 px-8 py-3 rounded-xl font-bold bg-white text-gray-600 border-2 border-gray-100 hover:border-gray-200 hover:bg-gray-100 transition-all"
            >
                Anterior
            </button>
            <div class="min-w-2 flex-grow"></div>
            <button
                type="button"
                id="next-btn"
                class="shrink-0 px-12 py-3 rounded-xl font-bold bg-secondary text-primary hover:bg-yellow-400 shadow-lg shadow-secondary/20 transition-all"
            >
                Siguiente
            </button>
            <button
                type="submit"
                id="submit-btn"
                class="hidden shrink-0 px-12 py-3 rounded-xl font-bold bg-primary text-white hover:bg-blue-900 shadow-lg shadow-primary/20 transition-all flex items-center gap-3"
            >
                <span>Finalizar</span>
                <svg
                    id="spinner"
                    class="animate-spin h-5 w-5 hidden"
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                >
                    <circle
                        class="opacity-25"
                        cx="12"
                        cy="12"
                        r="10"
                        stroke="currentColor"
                        stroke-width="4"></circle>
                    <path
                        class="opacity-75"
                        fill="currentColor"
                        d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                    ></path>
                </svg>
            </button>
        </div>
    </form>

    <!-- Success Message -->
    <div
        id="success-msg"
        class:list={[
            "hidden text-center py-20 bg-white animate-fade-up",
            successSurfaceClass,
        ]}
    >
        <div
            class="w-24 h-24 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-8 scale-110"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-12 w-12"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="3"
                    d="M5 13l4 4L19 7"></path>
            </svg>
        </div>
        <h3 class="text-3xl font-bold text-gray-900 mb-4 font-serif">
            ¡Inscripción Recibida!
        </h3>
        <p class="text-xl text-gray-600 max-w-lg mx-auto mb-10 leading-relaxed">
            Tu registro se ha procesado con éxito. Hemos enviado una
            confirmación a tu correo electrónico con los detalles del programa.
        </p>
        <a
            href="/"
            class="inline-block px-12 py-4 bg-primary text-white rounded-2xl font-bold hover:scale-105 transition-transform shadow-xl shadow-primary/20"
        >
            Volver al Inicio
        </a>
    </div>
</div>

<script>
    import {
        validateStepSection,
        reportStepValidationFailure,
    } from "@lib/client/multiStepFormValidation";
    import { wireReferenceFromSessionId } from "@lib/wireReference";

    const form = document.getElementById("ce-inscription-form") as HTMLFormElement | null;
    const enrollmentSessionIdEl = form?.querySelector(
        "#ce-enrollment-session-id",
    ) as HTMLInputElement | null;
    if (enrollmentSessionIdEl && !enrollmentSessionIdEl.value.trim()) {
        enrollmentSessionIdEl.value = crypto.randomUUID();
    }
    // Wrapper = parent of <form> (stepper header + form live in the same root).
    const outer = form?.parentElement ?? null;
    const progress = outer?.querySelector("#progress-bar") as HTMLElement | null;
    const stepLabel = outer?.querySelector("#step-label") as HTMLElement | null;
    const stepNumberLabel = outer?.querySelector("#step-number") as HTMLElement | null;
    const sections = form?.querySelectorAll<HTMLElement>(".step-section") ?? [];
    const prevBtn = form?.querySelector("#prev-btn") as HTMLButtonElement | null;
    const nextBtn = form?.querySelector("#next-btn") as HTMLButtonElement | null;
    const submitBtn = form?.querySelector("#submit-btn") as HTMLButtonElement | null;
    const successMsg = outer?.querySelector("#success-msg") as HTMLElement | null;

    // Facturación Logic
    const invoiceRadios =
        form?.querySelectorAll<HTMLInputElement>('input[name="requiresInvoice"]') ?? [];
    const invoiceFields = form?.querySelector("#invoice-fields");
    const fiscalInputs =
        invoiceFields?.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>(
            "input, textarea",
        ) ?? [];

    // Modality selection
    const paymentMethodRadios =
        form?.querySelectorAll<HTMLInputElement>('input[name="paymentMethodChoice"]') ?? [];
    const paymentMethodHidden = form?.querySelector(
        "#payment-method",
    ) as HTMLInputElement | null;
    const wireReferenceHidden = form?.querySelector(
        "#wire-reference",
    ) as HTMLInputElement | null;
    const wireReferencePreview = form?.querySelector("#wire-reference-preview");
    const wireProofSection = form?.querySelector("#wire-proof-section");
    const paymentProofInput = form?.querySelector(
        "#payment-proof-input",
    ) as HTMLInputElement | null;
    const stripePanel = form?.querySelector("#stripe-panel");
    const wirePanel = form?.querySelector("#wire-panel");

    // Modality UI: some programs encode modality as `paymentOptions` (e.g. "Presencial" vs "Online")
    // with distinct Stripe price IDs. In that case, we must not ask for modality twice.
    const modalitySection = form?.querySelector("#modality-section") as HTMLElement | null;
    const modalityRadios =
        form?.querySelectorAll<HTMLInputElement>('input[name="modality"]') ?? [];
    const paymentPlanSection = form?.querySelector(
        "#payment-plan-section",
    ) as HTMLElement | null;
    const paymentPlanRadios = Array.from(
        form?.querySelectorAll<HTMLInputElement>('input[name="paymentPlan"]') ?? [],
    );

    function paymentOptionsLookLikeModalityChoices(opts: PaymentOptionRow[]): boolean {
        if (opts.length < 1) return false;
        const ids = new Set(opts.map((o) => String(o.id).toLowerCase()));
        const labels = new Set(opts.map((o) => String(o.label).toLowerCase()));
        const allowed = new Set(["presencial", "online", "en línea", "en linea"]);
        // If every option is clearly a modality choice, treat it as such.
        return [...ids].every((id) => allowed.has(id)) || [...labels].every((l) => allowed.has(l));
    }

    function setModalityValue(value: "Presencial" | "En línea") {
        modalityRadios.forEach((r) => {
            r.checked = r.value === value;
        });
    }

    function ensureModalityIsSingleSourceOfTruth() {
        const opts = readPaymentOptionsFromForm();
        const prices = (() => {
            try {
                const raw = form?.dataset.prices ?? "{}";
                const parsed = JSON.parse(raw === "null" ? "{}" : raw);
                return parsed && typeof parsed === "object" ? (parsed as Record<string, unknown>) : {};
            } catch {
                return {};
            }
        })();

        // Case A: paymentOptions are actually modality choices → keep modality radios in step 1
        // and hide the redundant paymentPlan chooser in step 2. We still map modality → paymentPlan
        // internally to resolve the correct Stripe price id.
        if (paymentOptionsLookLikeModalityChoices(opts)) {
            modalitySection?.classList.remove("hidden");
            modalityRadios.forEach((r) => (r.required = true));

            paymentPlanSection?.classList.add("hidden");
            paymentPlanRadios.forEach((r) => (r.required = false));

            const selectedModality = (
                form?.querySelector('input[name="modality"]:checked') as HTMLInputElement | null
            )?.value;
            const normalized = String(selectedModality ?? "Presencial").toLowerCase();
            const want = normalized.includes("línea") || normalized.includes("linea")
                ? "online"
                : "presencial";
            const plan = paymentPlanRadios.find(
                (radio: HTMLInputElement) => String(radio.value).toLowerCase() === want,
            );
            if (plan) plan.checked = true;
            return;
        }

        // Case B: only one modality exists (either `prices` or `stripePriceIds` has one side) → hide choice.
        const hasOnline =
            typeof (prices as any).Online === "string" ||
            typeof (prices as any)["En línea"] === "string" ||
            typeof (readStripePriceIdsFromForm().online) === "string";
        const hasPresencial =
            typeof (prices as any).Presencial === "string" ||
            typeof (readStripePriceIdsFromForm().presencial) === "string";

        if (hasOnline !== hasPresencial) {
            modalitySection?.classList.add("hidden");
            modalityRadios.forEach((r) => (r.required = false));
            setModalityValue(hasOnline ? "En línea" : "Presencial");
            paymentPlanSection?.classList.remove("hidden");
            paymentPlanRadios.forEach((r) => (r.required = true));
            return;
        }

        // Default: two modalities exist and they are not encoded as paymentOptions → show choice.
        modalitySection?.classList.remove("hidden");
        modalityRadios.forEach((r) => (r.required = true));
        paymentPlanSection?.classList.remove("hidden");
        paymentPlanRadios.forEach((r) => (r.required = true));
    }

    let currentStep = 1;

    function selectedPaymentMethod(): "stripe" | "wire" {
        const value = (
            form?.querySelector(
                'input[name="paymentMethodChoice"]:checked',
            ) as HTMLInputElement | null
        )?.value;
        return value === "wire" ? "wire" : "stripe";
    }

    function activeStepNames(): string[] {
        // Stripe flow completes on `/pago-exitoso` after redirect, so we only
        // show 2 steps in the UI. Wire transfer requires the final step (proof).
        return selectedPaymentMethod() === "wire"
            ? ["Datos del Participante", "Método de Pago", "Finalizar Inscripción"]
            : ["Datos del Participante", "Pago en línea (Stripe)"];
    }

    function activeTotalSteps(): number {
        return activeStepNames().length;
    }

    function updateStep() {
        // If the user switched payment method, clamp the current step.
        const totalSteps = activeTotalSteps();
        if (currentStep > totalSteps) currentStep = totalSteps;

        sections.forEach((s, i) => {
            // Step 3 is only reachable/visible for wire transfers.
            if (i === 2 && selectedPaymentMethod() !== "wire") {
                s.classList.add("hidden");
                return;
            }
            s.classList.toggle("hidden", i + 1 !== currentStep);
        });

        const stepNames = activeStepNames();
        const percent = (currentStep / totalSteps) * 100;
        if (progress) progress.style.width = `${percent}%`;
        if (stepLabel)
            stepLabel.textContent = `Paso ${currentStep} de ${totalSteps}: ${stepNames[currentStep - 1]}`;
        if (stepNumberLabel)
            stepNumberLabel.textContent = `${Math.round(percent)}% completado`;

        if (prevBtn) prevBtn.classList.toggle("hidden", currentStep === 1);
        if (nextBtn) {
            // Stripe is a redirect flow: on the payment step (step 2) the user should
            // click the dedicated Stripe button, not “Siguiente”.
            const hideNextForStripePaymentStep =
                selectedPaymentMethod() === "stripe" && currentStep === 2;
            nextBtn.classList.toggle(
                "hidden",
                currentStep === totalSteps || hideNextForStripePaymentStep,
            );
        }
        if (submitBtn) {
            // Stripe is a redirect flow: users should never submit from inside the
            // wizard; they must complete payment on Stripe and return via /pago-exitoso.
            const hideSubmitForStripe = selectedPaymentMethod() === "stripe";
            submitBtn.classList.toggle(
                "hidden",
                hideSubmitForStripe || currentStep !== totalSteps,
            );
        }
    }

    nextBtn?.addEventListener("click", () => {
        const totalSteps = activeTotalSteps();
        const stepNames = activeStepNames();
        const section = sections[currentStep - 1];
        if (!section || !form) return;
        // Check formats (phone, email) in addition to required-ness so users
        // can't advance past a step with a bad value only to find out at the
        // server-side validation that their phone was rejected.
        const result = validateStepSection(section);
        if (!result.ok) {
            const title = `Paso ${currentStep} de ${totalSteps}: ${stepNames[currentStep - 1]}`;
            reportStepValidationFailure(title, result);
            return;
        }
        // Step 2 is the payment step. For Stripe, users must use the dedicated
        // Stripe Checkout button (redirect) and cannot proceed to the next step
        // without paying.
        if (currentStep === 2) {
            if (selectedPaymentMethod() === "stripe") {
                alert(
                    "Para pago en línea (Stripe), usa el botón «Continuar al Pago Seguro» en este paso. No puedes continuar sin completar el pago en Stripe.",
                );
                stripeCheckoutBtn?.scrollIntoView({
                    behavior: "smooth",
                    block: "center",
                });
                return;
            }
        }
        if (currentStep < totalSteps) {
            currentStep++;
            updateStep();
            window.scrollTo({ top: form.offsetTop - 100, behavior: "smooth" });
        }
    });

    prevBtn?.addEventListener("click", () => {
        if (currentStep > 1) {
            currentStep--;
            updateStep();
            window.scrollTo({
                top: (form?.offsetTop ?? 0) - 100,
                behavior: "smooth",
            });
        }
    });

    // Invoice Toggle
    invoiceRadios.forEach((radio) => {
        radio.addEventListener("change", (e) => {
            const t = e.target as HTMLInputElement;
            const isYes = t.value === "Sí";
            invoiceFields?.classList.toggle("hidden", !isYes);
            fiscalInputs.forEach((input) => {
                input.required = isYes;
            });
        });
    });

    // Stripe Checkout Logic
    const stripeCheckoutBtn = form?.querySelector(
        "#stripe-checkout-btn",
    ) as HTMLButtonElement | null;

    function readStripePriceIdsFromForm(): Record<string, string> {
        try {
            const raw = form?.dataset.stripePriceIds ?? "{}";
            const parsed = JSON.parse(raw === "null" ? "{}" : raw);
            if (parsed && typeof parsed === "object" && !Array.isArray(parsed)) {
                return parsed as Record<string, string>;
            }
        } catch {
            /* invalid JSON */
        }
        return {};
    }

    type PaymentOptionRow = {
        id: string;
        label: string;
        price: number;
        stripePriceId: string;
        type: string;
    };

    function readPaymentOptionsFromForm(): PaymentOptionRow[] {
        try {
            const raw = form?.dataset.paymentOptions ?? "[]";
            const parsed = JSON.parse(raw);
            if (Array.isArray(parsed)) return parsed as PaymentOptionRow[];
        } catch {
            /* invalid JSON */
        }
        return [];
    }

    function resolveStripePriceId(): string | null {
        const opts = readPaymentOptionsFromForm();
        if (opts.length > 1) {
            // If paymentOptions are actually modality choices (presencial/online),
            // derive the selection from modality instead of asking twice.
            if (paymentOptionsLookLikeModalityChoices(opts)) {
                const modality = (
                    form?.querySelector(
                        'input[name="modality"]:checked',
                    ) as HTMLInputElement | null
                )?.value;
                const want =
                    String(modality ?? "Presencial")
                        .toLowerCase()
                        .includes("línea") ||
                    String(modality ?? "Presencial")
                        .toLowerCase()
                        .includes("linea")
                        ? "online"
                        : "presencial";
                return opts.find((o) => String(o.id).toLowerCase() === want)?.stripePriceId ?? null;
            }

            const selected = (
                form?.querySelector(
                    'input[name="paymentPlan"]:checked',
                ) as HTMLInputElement | null
            )?.value;
            if (!selected) return null;
            return opts.find((o) => o.id === selected)?.stripePriceId ?? null;
        }
        if (opts.length === 1) return opts[0].stripePriceId;
        const modality = (
            form?.querySelector(
                'input[name="modality"]:checked',
            ) as HTMLInputElement | null
        )?.value;
        if (!modality) return null;
        const stripePriceIds = readStripePriceIdsFromForm();
        return modality === "Presencial"
            ? stripePriceIds.presencial ?? null
            : stripePriceIds.online ?? null;
    }

    stripeCheckoutBtn?.addEventListener("click", async () => {
        if (!stripeCheckoutBtn || !form) return;
        const method =
            (
                form.querySelector(
                    'input[name="paymentMethodChoice"]:checked',
                ) as HTMLInputElement | null
            )?.value || "stripe";
        if (method !== "stripe") {
            alert("Selecciona 'Pago en línea (Stripe)' para pagar en línea.");
            return;
        }

        const modality = (
            form.querySelector(
                'input[name="modality"]:checked',
            ) as HTMLInputElement | null
        )?.value;
        if (!modality) {
            alert("Por favor selecciona una modalidad (Presencial o En línea)");
            return;
        }

        const priceId = resolveStripePriceId();

        if (!priceId) {
            const opts = readPaymentOptionsFromForm();
            if (opts.length > 1) {
                alert(
                    "Selecciona una opción de inversión (inscripción, pago completo o plan en cuotas).",
                );
            } else {
                alert(
                    "Precio no configurado para esta modalidad. Por favor contacta al administrador.",
                );
            }
            return;
        }

        const priceOk =
            typeof priceId === "string" &&
            /^price_[a-zA-Z0-9]+$/.test(priceId);
        if (!priceOk) {
            alert(
                "Este programa no tiene un Price ID de Stripe válido. Crea precios en el Dashboard de Stripe y agrégalos al archivo del programa en content/programas (stripePriceIds).",
            );
            return;
        }

        const stepNames = activeStepNames();
        const totalSteps = activeTotalSteps();

        // Pasos 1 y 2 deben estar completos antes de Stripe (el botón vive en el paso 2)
        for (let s = 0; s <= 1; s++) {
            const stepResult = validateStepSection(sections[s]);
            if (!stepResult.ok) {
                const title = `Paso ${s + 1} de ${totalSteps}: ${stepNames[s]}`;
                reportStepValidationFailure(title, stepResult);
                currentStep = s + 1;
                updateStep();
                window.scrollTo({ top: form.offsetTop - 100, behavior: "smooth" });
                return;
            }
        }

        // Get user data for pre-filling Stripe
        const formData = new FormData(form);
        const email = formData.get("email");
        const programSlug = formData.get("programId");
        const programTitle = String(formData.get("programTitle") ?? "").trim();
        const participantName = String(formData.get("name") ?? "").trim();
        const participantPhone = String(formData.get("phone") ?? "").trim();
        const needsInvoice =
            (
                form.querySelector(
                    'input[name="requiresInvoice"]:checked',
                ) as HTMLInputElement | null
            )?.value === "Sí";
        const invoiceEmail = String(formData.get("invoiceEmail") ?? "").trim();
        const csfInput = form.querySelector("#csf-input") as HTMLInputElement | null;

        if (needsInvoice) {
            if (!invoiceEmail) {
                alert("Indicaste que requieres factura: escribe el correo para factura.");
                return;
            }
            const f = csfInput?.files?.[0];
            if (!f) {
                alert("Indicaste que requieres factura: adjunta tu CSF (PDF o imagen).");
                return;
            }
        }

        // Call our Stripe checkout endpoint
        try {
            stripeCheckoutBtn.disabled = true;
            const stripeSpan = stripeCheckoutBtn.querySelector("span");
            if (stripeSpan) stripeSpan.textContent = "Redirigiendo a Stripe...";

            const csfFile = csfInput?.files?.[0];
            if (needsInvoice && csfFile) {
                const preFd = new FormData();
                preFd.append("invoiceEmail", invoiceEmail);
                preFd.append("programSlug", String(programSlug ?? ""));
                preFd.append("programTitle", programTitle);
                preFd.append("participantName", participantName);
                preFd.append("participantPhone", participantPhone);
                preFd.append("modality", modality);
                preFd.append("customerEmail", String(email ?? ""));
                preFd.append("fiscalConstancy", csfFile);
                const pre = await fetch("/api/stripe/fiscal-preflight", {
                    method: "POST",
                    body: preFd,
                });
                const preJson = await pre.json().catch(() => ({}));
                if (!pre.ok) {
                    throw new Error(
                        typeof preJson.error === "string"
                            ? preJson.error
                            : "No se pudo enviar la CSF",
                    );
                }
            }

            const response = await fetch("/api/stripe/create-checkout-session", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    priceId,
                    customerEmail: email,
                    programSlug,
                    participantName,
                    participantPhone,
                    modality,
                    requiresInvoice: needsInvoice ? "Sí" : "No",
                    invoiceEmail: needsInvoice ? invoiceEmail : "",
                })
            });

            const data = await response.json();
            if (data.url) {
                window.location.href = data.url;
            } else {
                throw new Error(data.error || "Error al crear sesión de pago");
            }
        } catch (error) {
            console.error("Stripe error:", error);
            const msg = error instanceof Error ? error.message : String(error);
            alert(
                "Error al procesar el pago: " +
                    msg +
                    ". Por favor intenta de nuevo o contacta soporte.",
            );
            stripeCheckoutBtn.disabled = false;
            const sp = stripeCheckoutBtn.querySelector("span");
            if (sp) sp.textContent = "Continuar al Pago Seguro →";
        }
    });

    // When modality is encoded as paymentOptions (e.g. presencial vs online),
    // keep the hidden `modality` radios in sync with that selection.
    form?.querySelectorAll<HTMLInputElement>('input[name="paymentPlan"]').forEach((r) =>
        r.addEventListener("change", () => {
            ensureModalityIsSingleSourceOfTruth();
        }),
    );

    modalityRadios.forEach((r) =>
        r.addEventListener("change", () => {
            ensureModalityIsSingleSourceOfTruth();
        }),
    );

    function generateWireReference() {
        const sid = enrollmentSessionIdEl?.value?.trim();
        if (sid) return wireReferenceFromSessionId(sid);
        return "CEPRIJA-PENDING";
    }

    function applyPaymentMethodUI() {
        const method =
            (
                form?.querySelector(
                    'input[name="paymentMethodChoice"]:checked',
                ) as HTMLInputElement | null
            )?.value || "stripe";
        if (paymentMethodHidden) paymentMethodHidden.value = method;

        const isWire = method === "wire";
        wireProofSection?.classList.toggle("hidden", !isWire);
        stripePanel?.classList.toggle("hidden", isWire);
        wirePanel?.classList.toggle("hidden", !isWire);

        if (isWire) {
            const ref = generateWireReference();
            if (wireReferenceHidden) wireReferenceHidden.value = ref;
            if (wireReferencePreview) wireReferencePreview.textContent = ref;
            if (paymentProofInput) paymentProofInput.required = true;
        } else {
            if (wireReferenceHidden) wireReferenceHidden.value = "";
            if (wireReferencePreview) wireReferencePreview.textContent = "";
            if (paymentProofInput) paymentProofInput.required = false;
        }
    }

    paymentMethodRadios.forEach((r) =>
        r.addEventListener("change", () => {
            applyPaymentMethodUI();
            ensureModalityIsSingleSourceOfTruth();
            updateStep();
        }),
    );
    applyPaymentMethodUI();
    ensureModalityIsSingleSourceOfTruth();
    updateStep();

    // Copy-to-clipboard for bank fields
    form?.querySelectorAll("[data-copy]").forEach((btn) => {
        btn.addEventListener("click", async () => {
            const value = btn.getAttribute("data-copy") || "";
            try {
                await navigator.clipboard.writeText(value);
            } catch {
                const ta = document.createElement("textarea");
                ta.value = value;
                document.body.appendChild(ta);
                ta.select();
                document.execCommand("copy");
                ta.remove();
            }
        });
    });

    // Uppercase & Number validations (already in HTML but reinforced)
    form?.querySelectorAll('input[type="text"], textarea').forEach((el) => {
        el.addEventListener("input", (e) => {
            const t = e.target as HTMLInputElement | HTMLTextAreaElement;
            t.value = t.value.toUpperCase();
        });
    });

    form?.querySelectorAll('input[type="tel"]').forEach((el) => {
        el.addEventListener("input", (e) => {
            const t = e.target as HTMLInputElement;
            t.value = t.value.replace(/[^0-9]/g, "");
        });
    });

    // File Label logic (for CSF file only, payment proof removed)

    form?.querySelector("#csf-input")?.addEventListener("change", (e) => {
        const label = form?.querySelector("#csf-file-label");
        const input = e.target as HTMLInputElement;
        const f = input.files?.[0];
        if (f && label) {
            label.textContent = f.name;
            label.classList.add("text-primary");
        }
    });

    // Form submission
    form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!submitBtn || !form) return;

        const stepNames = activeStepNames();
        const totalSteps = activeTotalSteps();

        for (let i = 0; i < totalSteps; i++) {
            const r = validateStepSection(sections[i]);
            if (!r.ok) {
                currentStep = i + 1;
                updateStep();
                const title = `Paso ${i + 1} de ${totalSteps}: ${stepNames[i]}`;
                reportStepValidationFailure(title, r);
                window.scrollTo({ top: form.offsetTop - 100, behavior: "smooth" });
                return;
            }
        }

        const paymentChoice = (
            form.querySelector(
                'input[name="paymentMethodChoice"]:checked',
            ) as HTMLInputElement | null
        )?.value;
        if (paymentChoice === "stripe") {
            alert(
                "Con pago en línea (Stripe) debes usar el botón «Continuar al Pago Seguro» en el paso 2. No puedes finalizar aquí sin completar el pago en Stripe.",
            );
            currentStep = 2;
            updateStep();
            stripeCheckoutBtn?.scrollIntoView({
                behavior: "smooth",
                block: "center",
            });
            return;
        }

        const spinner = form.querySelector("#spinner");
        const btnText = submitBtn.querySelector("span");

        submitBtn.disabled = true;
        spinner?.classList.remove("hidden");
        if (btnText) btnText.textContent = "Enviando...";

        try {
            const formData = new FormData(form);
            const method = String(formData.get("paymentMethod") || "stripe");
            const endpoint =
                method === "wire"
                    ? "/api/payments/wire-proof"
                    : "/api/educacion-continua-inscription";

            const response = await fetch(endpoint, { method: "POST", body: formData });

            if (response.ok) {
                form.classList.add("hidden");
                successMsg?.classList.remove("hidden");
                window.scrollTo({
                    top: (successMsg?.offsetTop ?? 0) - 100,
                    behavior: "smooth",
                });
            } else {
                throw new Error("Error en el servidor");
            }
        } catch (error) {
            console.error(error);
            alert(
                "Hubo un error al procesar tu inscripción. Por favor intenta de nuevo o contáctanos por WhatsApp.",
            );
        } finally {
            submitBtn.disabled = false;
            spinner?.classList.add("hidden");
            if (btnText) btnText.textContent = "Finalizar";
        }
    });

    // Sync button visibility with the initial DOM (and recover if markup changes).
    updateStep();
</script>
