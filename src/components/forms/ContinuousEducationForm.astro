---
import Button from "@components/ui/Button.astro";
import { ecConsentLabels } from "@data/forms/educacion-continua-options";

interface Props {
    programTitle?: string;
    programId?: string;
    stripePriceIds?: {
        online?: string;
        presencial?: string;
    };
    prices?: {
        Presencial?: string;
        Online?: string;
    };
    address?: string;
}

const {
    programTitle = "",
    programId = "",
    stripePriceIds,
    prices,
    address = "Instalaciones de CEPRIJA - Lope de Vega #273, Col. Americana Arcos. C.P. 44500",
} = Astro.props;
---

<div class="max-w-4xl mx-auto">
    <!-- Stepper Header -->
    <div class="mb-12">
        <div class="flex items-center justify-between mb-4">
            <h2
                class="text-2xl font-bold text-primary font-serif"
                id="step-label"
            >
                Paso 1 de 3: Datos del Participante
            </h2>
            <span class="text-sm font-semibold text-gray-500" id="step-number"
                >33% completado</span
            >
        </div>
        <div class="w-full bg-gray-100 h-3 rounded-full overflow-hidden">
            <div
                id="progress-bar"
                class="bg-secondary h-full w-1/3 transition-all duration-500 ease-out shadow-sm shadow-secondary/20"
            >
            </div>
        </div>
    </div>

    <form
        id="ce-inscription-form"
        data-stripe-price-ids={JSON.stringify(stripePriceIds || null)}
        data-prices={JSON.stringify(prices || null)}
        data-address={address}
        class="bg-white rounded-3xl shadow-xl shadow-blue-900/5 border border-gray-100 overflow-hidden"
    >
        <input
            type="hidden"
            name="programId"
            id="form-program-id"
            value={programId}
        />
        <input
            type="hidden"
            name="programTitle"
            id="form-program-title"
            value={programTitle}
        />

        <!-- SECCIÓN 1: DATOS PERSONALES -->
        <div class="step-section p-8 md:p-12" id="step-1">
            <div class="mb-10 text-center">
                <div
                    class="inline-block p-4 bg-blue-50 rounded-2xl mb-4 text-primary"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-8 w-8"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                        ></path>
                    </svg>
                </div>
                <h3
                    class="text-2xl font-bold text-gray-900 mb-2 font-serif"
                    id="program-header-title"
                >
                    {programTitle || "Título del Programa"}
                </h3>
                <p class="text-gray-500 text-sm max-w-lg mx-auto">
                    Bienvenido(a) al Centro de Preparación Integral en Materia
                    Jurídica y Administrativa (CEPRIJA). Sus datos serán
                    tratados para fines académicos y administrativos de acuerdo
                    a nuestro Aviso de Privacidad.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="col-span-1 md:col-span-2">
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Nombre completo *</label
                    >
                    <input
                        type="text"
                        name="name"
                        required
                        placeholder="Tu nombre completo"
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all uppercase"
                    />
                </div>
                <div>
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Teléfono *</label
                    >
                    <input
                        type="tel"
                        name="phone"
                        required
                        placeholder="33 0000 0000"
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                    />
                </div>
                <div>
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        >Correo electrónico *</label
                    >
                    <input
                        type="email"
                        name="email"
                        required
                        placeholder="tu@correo.com"
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                    />
                </div>

                <div class="col-span-1 md:col-span-2">
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-3"
                        >Modalidad *</label
                    >
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <label
                            class="flex items-center gap-3 p-4 border-2 border-gray-100 rounded-2xl cursor-pointer hover:bg-gray-50 transition-all has-[:checked]:border-primary has-[:checked]:bg-blue-50 group"
                        >
                            <input
                                type="radio"
                                name="modality"
                                value="Presencial"
                                required
                                checked
                                class="w-5 h-5 text-primary focus:ring-primary"
                            />
                            <div class="flex flex-col">
                                <span class="font-bold text-gray-900"
                                    >Presencial</span
                                >
                                <span class="text-xs text-gray-500"
                                    >Asistencia en aula</span
                                >
                            </div>
                        </label>
                        <label
                            class="flex items-center gap-3 p-4 border-2 border-gray-100 rounded-2xl cursor-pointer hover:bg-gray-50 transition-all has-[:checked]:border-primary has-[:checked]:bg-blue-50 group"
                        >
                            <input
                                type="radio"
                                name="modality"
                                value="En línea"
                                required
                                class="w-5 h-5 text-primary focus:ring-primary"
                            />
                            <div class="flex flex-col">
                                <span class="font-bold text-gray-900"
                                    >En línea</span
                                >
                                <span class="text-xs text-gray-500"
                                    >Vía videoconferencia</span
                                >
                            </div>
                        </label>
                    </div>
                </div>

                <div
                    class="col-span-1 md:col-span-2 space-y-4 pt-4 border-t border-gray-100 mt-4"
                >
                    <p class="text-xs text-gray-500 italic mb-2">
                        Aviso de privacidad, políticas de uso de imagen y redes
                        sociales.
                    </p>
                    {
                        ecConsentLabels.map((label, i) => (
                            <label class="flex items-start gap-3 cursor-pointer group">
                                <input
                                    type="checkbox"
                                    required
                                    class="mt-1 w-5 h-5 rounded border-gray-300 text-primary focus:ring-primary"
                                />
                                <span class="text-sm text-gray-600 group-hover:text-gray-900 transition-colors">
                                    {label} *
                                </span>
                            </label>
                        ))
                    }
                </div>
            </div>
        </div>

        <!-- SECCIÓN 2: PAGO -->
        <div class="step-section p-8 md:p-12 hidden" id="step-2">
            <div class="mb-10 text-center">
                <div
                    class="inline-block p-4 bg-yellow-50 rounded-2xl mb-4 text-yellow-600"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-8 w-8"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"
                        ></path>
                    </svg>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 mb-2 font-serif">
                    Realizar Pago
                </h3>
                <p class="text-gray-500 text-sm">
                    Le recordamos realizar su pago antes de finalizar el
                    registro para garantizar su lugar.
                </p>
            </div>

            <!-- Métodos de Pago UI -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-10">
                <div
                    class="p-6 bg-gradient-to-br from-white to-gray-50 border border-gray-200 rounded-2xl shadow-sm"
                >
                    <div class="flex items-center gap-3 mb-4 text-primary">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-6 w-6"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"
                            ></path>
                        </svg>
                        <h4 class="font-bold text-sm uppercase tracking-wider">
                            Transferencia
                        </h4>
                    </div>
                    <div class="space-y-1 text-xs text-gray-600">
                        <p><strong>Banco:</strong> Santander</p>
                        <p><strong>No. Cuenta:</strong> 65-51080859-3</p>
                        <p><strong>CLABE:</strong> 014320655108085938</p>
                        <p><strong>Titular:</strong> CEPRIJA AC.</p>
                    </div>
                </div>

                <div
                    class="p-8 bg-gradient-to-br from-blue-50 to-white border-2 border-primary/20 rounded-2xl lg:scale-105"
                >
                    <div class="flex items-center gap-3 mb-4 text-primary">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-8 w-8"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"
                            ></path>
                        </svg>
                        <h4 class="text-xl font-bold">Proceder al Pago</h4>
                    </div>
                    <p class="text-gray-600 mb-6 leading-relaxed">
                        Serás redirigido a Stripe para completar tu pago de forma segura. 
                        Tu información está protegida con encriptación de nivel bancario.
                    </p>
                    <button
                        type="button"
                        id="stripe-checkout-btn"
                        class="w-full bg-primary text-white font-bold py-4 px-6 rounded-xl hover:bg-blue-900 transition-all shadow-lg hover:shadow-xl flex items-center justify-center gap-2"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" />
                        </svg>
                        <span>Continuar al Pago Seguro →</span>
                    </button>
                    <p class="text-xs text-gray-500 mt-4 text-center">
                        🔒 Pago procesado por Stripe
                    </p>
                </div>

                <!-- <div
                    class="p-6 bg-gradient-to-br from-white to-gray-50 border border-gray-200 rounded-2xl shadow-sm"
                >
                    <div class="flex items-center gap-3 mb-4 text-primary">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-6 w-6"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                            ></path>
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                        <h4 class="font-bold text-sm uppercase tracking-wider">
                            Efectivo
                        </h4>
                    </div>
                    <p class="text-xs text-gray-600 leading-tight">
                        En nuestras oficinas:<br />
                        <span
                            id="form-address-display"
                            class="text-gray-400 font-medium">{address}</span
                        >
                    </p>
                </div> -->
            </div>

            <div class="grid grid-cols-1 gap-8 items-center">

                <div
                    class="p-6 bg-blue-50/50 rounded-2xl border border-blue-100 h-full flex flex-col justify-center"
                >
                    <label
                        class="block text-sm font-bold text-primary mb-4 italic"
                        >¿Requiere factura? *</label
                    >
                    <div class="flex gap-6">
                        <label
                            class="flex items-center gap-2 cursor-pointer group"
                        >
                            <input
                                type="radio"
                                name="requiresInvoice"
                                value="Sí"
                                required
                                class="w-5 h-5 text-primary focus:ring-primary"
                            />
                            <span
                                class="font-bold text-gray-700 group-hover:text-primary transition-colors"
                                >Sí</span
                            >
                        </label>
                        <label
                            class="flex items-center gap-2 cursor-pointer group"
                        >
                            <input
                                type="radio"
                                name="requiresInvoice"
                                value="No"
                                required
                                checked
                                class="w-5 h-5 text-primary focus:ring-primary"
                            />
                            <span
                                class="font-bold text-gray-700 group-hover:text-primary transition-colors"
                                >No</span
                            >
                        </label>
                    </div>
                </div>
            </div>
        </div>

        <!-- SECCIÓN 3: FACTURACIÓN -->
        <div class="step-section p-8 md:p-12 hidden" id="step-3">
            <!-- Este encabezado cambiará dinámicamente según si requiere factura o no -->
            <div id="invoice-header" class="mb-10 text-center">
                <div
                    class="inline-block p-4 bg-primary rounded-2xl mb-4 text-white"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-8 w-8"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                        ></path>
                    </svg>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 mb-2 font-serif">
                    Finalizar Inscripción
                </h3>
                <p class="text-gray-500 text-sm">
                    Verifique que toda la información sea correcta antes de
                    enviar.
                </p>
            </div>

            <div id="invoice-fields" class="space-y-8 hidden">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div>
                        <label
                            class="block text-sm font-semibold text-gray-700 mb-2"
                            >Constancia de Situación Fiscal *</label
                        >
                        <div class="relative group">
                            <input
                                type="file"
                                id="csf-input"
                                name="fiscalConstancy"
                                accept=".pdf,image/*"
                                class="hidden"
                            />
                            <label
                                for="csf-input"
                                class="flex items-center gap-3 px-4 py-3 border-2 border-gray-100 rounded-xl cursor-pointer hover:bg-gray-50 transition-all group-hover:border-primary"
                            >
                                <div
                                    class="bg-primary text-white p-2 rounded-lg"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-5 w-5"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"
                                        ></path>
                                    </svg>
                                </div>
                                <span
                                    class="text-sm font-bold text-gray-600 truncate"
                                    id="csf-file-label">Subir CSF</span
                                >
                            </label>
                        </div>
                    </div>

                    <div>
                        <label
                            class="block text-sm font-semibold text-gray-700 mb-2"
                            >Correo para recibir factura *</label
                        >
                        <input
                            type="email"
                            name="invoiceEmail"
                            placeholder="correo@facturacion.com"
                            class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                        />
                    </div>
                </div>
            </div>

            <div
                class="mt-8 p-6 bg-yellow-50 rounded-2xl border border-yellow-200 flex gap-4"
            >
                <input
                    type="checkbox"
                    required
                    class="w-6 h-6 mt-1 accent-primary"
                />
                <p class="text-sm text-gray-700">
                    Declaro bajo protesta de decir verdad que los datos aquí
                    asentados son ciertos y que cuento con la documentación
                    original para su cotejo. Acepto los términos del aviso de
                    privacidad.
                </p>
            </div>
        </div>

        <!-- Footer: Botones -->
        <div
            class="bg-gray-50 px-8 py-6 md:px-12 md:py-8 border-t border-gray-100 flex items-center justify-between gap-4"
        >
            <button
                type="button"
                id="prev-btn"
                class="hidden px-8 py-3 rounded-xl font-bold bg-white text-gray-600 border-2 border-gray-100 hover:border-gray-200 hover:bg-gray-100 transition-all"
            >
                Anterior
            </button>
            <div class="flex-grow"></div>
            <button
                type="button"
                id="next-btn"
                class="px-12 py-3 rounded-xl font-bold bg-secondary text-primary hover:bg-yellow-400 shadow-lg shadow-secondary/20 transition-all"
            >
                Siguiente
            </button>
            <button
                type="submit"
                id="submit-btn"
                class="hidden px-12 py-3 rounded-xl font-bold bg-primary text-white hover:bg-blue-900 shadow-lg shadow-primary/20 transition-all flex items-center gap-3"
            >
                <span>Finalizar</span>
                <svg
                    id="spinner"
                    class="animate-spin h-5 w-5 hidden"
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                >
                    <circle
                        class="opacity-25"
                        cx="12"
                        cy="12"
                        r="10"
                        stroke="currentColor"
                        stroke-width="4"></circle>
                    <path
                        class="opacity-75"
                        fill="currentColor"
                        d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                    ></path>
                </svg>
            </button>
        </div>
    </form>

    <!-- Success Message -->
    <div
        id="success-msg"
        class="hidden text-center py-20 bg-white rounded-3xl shadow-xl border border-gray-100 animate-fade-up"
    >
        <div
            class="w-24 h-24 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-8 scale-110"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-12 w-12"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="3"
                    d="M5 13l4 4L19 7"></path>
            </svg>
        </div>
        <h3 class="text-3xl font-bold text-gray-900 mb-4 font-serif">
            ¡Inscripción Recibida!
        </h3>
        <p class="text-xl text-gray-600 max-w-lg mx-auto mb-10 leading-relaxed">
            Tu registro se ha procesado con éxito. Hemos enviado una
            confirmación a tu correo electrónico con los detalles del programa.
        </p>
        <a
            href="/"
            class="inline-block px-12 py-4 bg-primary text-white rounded-2xl font-bold hover:scale-105 transition-transform shadow-xl shadow-primary/20"
        >
            Volver al Inicio
        </a>
    </div>
</div>

<script is:inline>
    const form = document.getElementById("ce-inscription-form");
    const progress = document.getElementById("progress-bar");
    const stepLabel = document.getElementById("step-label");
    const stepNumberLabel = document.getElementById("step-number");
    const sections = document.querySelectorAll(".step-section");
    const prevBtn = document.getElementById("prev-btn");
    const nextBtn = document.getElementById("next-btn");
    const submitBtn = document.getElementById("submit-btn");
    const successMsg = document.getElementById("success-msg");

    function getPrices() {
        return JSON.parse(form.dataset.prices || "{}");
    }

    // Facturación Logic
    const invoiceRadios = document.querySelectorAll(
        'input[name="requiresInvoice"]',
    );
    const invoiceFields = document.getElementById("invoice-fields");
    const fiscalInputs = invoiceFields.querySelectorAll("input, textarea");

    // Modality selection
    const modalityRadios = document.querySelectorAll('input[name="modality"]');

    let currentStep = 1;
    const totalSteps = 3;
    const stepNames = [
        "Datos del Participante",
        "Realizar Pago",
        "Finalizar Inscripción",
    ];

    function updateStep() {
        sections.forEach((s, i) => {
            s.classList.toggle("hidden", i + 1 !== currentStep);
        });

        const percent = (currentStep / totalSteps) * 100;
        if (progress) progress.style.width = `${percent}%`;
        if (stepLabel)
            stepLabel.textContent = `Paso ${currentStep} de ${totalSteps}: ${stepNames[currentStep - 1]}`;
        if (stepNumberLabel)
            stepNumberLabel.textContent = `${Math.round(percent)}% completado`;

        if (prevBtn) prevBtn.classList.toggle("hidden", currentStep === 1);
        if (nextBtn)
            nextBtn.classList.toggle("hidden", currentStep === totalSteps);
        if (submitBtn)
            submitBtn.classList.toggle("hidden", currentStep !== totalSteps);
    }

    nextBtn?.addEventListener("click", () => {
        // Simple validation check before jumping steps
        const currentInputs = sections[currentStep - 1].querySelectorAll(
            "input[required], select[required], textarea[required]",
        );
        let valid = true;
        currentInputs.forEach((input) => {
            if (!input.value || (input.type === "checkbox" && !input.checked)) {
                valid = false;
                input.classList.add("border-red-400");
                setTimeout(
                    () => input.classList.remove("border-red-400"),
                    3000,
                );
            }
        });

        if (valid && currentStep < totalSteps) {
            currentStep++;
            updateStep();
            window.scrollTo({ top: form.offsetTop - 100, behavior: "smooth" });
        } else if (!valid) {
            alert("Por favor complete todos los campos obligatorios.");
        }
    });

    prevBtn?.addEventListener("click", () => {
        if (currentStep > 1) {
            currentStep--;
            updateStep();
            window.scrollTo({ top: form.offsetTop - 100, behavior: "smooth" });
        }
    });

    // Invoice Toggle
    invoiceRadios.forEach((radio) => {
        radio.addEventListener("change", (e) => {
            const isYes = e.target.value === "Sí";
            invoiceFields.classList.toggle("hidden", !isYes);
            fiscalInputs.forEach((input) => {
                input.required = isYes;
            });
        });
    });

    // Stripe Checkout Logic
    const stripeCheckoutBtn = document.getElementById("stripe-checkout-btn");
    let stripePriceIds = {};
    try {
        const parsed = JSON.parse(form.dataset.stripePriceIds || "{}");
        if (parsed && typeof parsed === "object" && !Array.isArray(parsed)) {
            stripePriceIds = parsed;
        }
    } catch {
        /* invalid JSON → treat as no prices */
    }

    stripeCheckoutBtn?.addEventListener("click", async () => {
        const modality = document.querySelector('input[name="modality"]:checked')?.value;
        if (!modality) {
            alert("Por favor selecciona una modalidad (Presencial o En línea)");
            return;
        }

        const priceId = modality === "Presencial"
            ? stripePriceIds.presencial
            : stripePriceIds.online;

        if (!priceId) {
            alert("Precio no configurado para esta modalidad. Por favor contacta al administrador.");
            return;
        }

        const priceOk =
            typeof priceId === "string" &&
            /^price_[a-zA-Z0-9]+$/.test(priceId) &&
            !/PLACEHOLDER|REPLACE/i.test(priceId);
        if (!priceOk) {
            alert(
                "Este programa no tiene un Price ID de Stripe válido. Crea precios en el Dashboard de Stripe y agrégalos al archivo del programa en content/programas (stripePriceIds).",
            );
            return;
        }

        // Validate Step 1 is complete before proceeding to payment
        const step1Inputs = sections[0].querySelectorAll("input[required], select[required]");
        let allValid = true;
        step1Inputs.forEach((input) => {
            if (!input.value || (input.type === "checkbox" && !input.checked)) {
                allValid = false;
                input.classList.add("border-red-400");
                setTimeout(() => input.classList.remove("border-red-400"), 3000);
            }
        });

        if (!allValid) {
            alert("Por favor completa todos los campos obligatorios del Paso 1");
            currentStep = 1;
            updateStep();
            window.scrollTo({ top: form.offsetTop - 100, behavior: "smooth" });
            return;
        }

        // Get user data for pre-filling Stripe
        const formData = new FormData(form);
        const email = formData.get("email");
        const programSlug = formData.get("programId");
        const participantName = String(formData.get("name") ?? "").trim();
        const participantPhone = String(formData.get("phone") ?? "").trim();

        // Call our Stripe checkout endpoint
        try {
            stripeCheckoutBtn.disabled = true;
            stripeCheckoutBtn.querySelector("span").textContent = "Redirigiendo a Stripe...";

            const response = await fetch("/api/stripe/create-checkout-session", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    priceId,
                    customerEmail: email,
                    programSlug,
                    participantName,
                    participantPhone,
                    modality,
                })
            });

            const data = await response.json();
            if (data.url) {
                window.location.href = data.url;
            } else {
                throw new Error(data.error || "Error al crear sesión de pago");
            }
        } catch (error) {
            console.error("Stripe error:", error);
            alert("Error al procesar el pago: " + error.message + ". Por favor intenta de nuevo o contacta soporte.");
            stripeCheckoutBtn.disabled = false;
            stripeCheckoutBtn.querySelector("span").textContent = "Continuar al Pago Seguro →";
        }
    });

    // Uppercase & Number validations (already in HTML but reinforced)
    document.querySelectorAll('input[type="text"], textarea').forEach((el) => {
        el.addEventListener("input", (e) => {
            e.target.value = e.target.value.toUpperCase();
        });
    });

    document.querySelectorAll('input[type="tel"]').forEach((el) => {
        el.addEventListener("input", (e) => {
            e.target.value = e.target.value.replace(/[^0-9]/g, "");
        });
    });

    // File Label logic (for CSF file only, payment proof removed)

    document.getElementById("csf-input")?.addEventListener("change", (e) => {
        const label = document.getElementById("csf-file-label");
        if (e.target.files?.[0]) {
            label.textContent = e.target.files[0].name;
            label.classList.add("text-primary");
        }
    });

    // Form submission
    form?.addEventListener("submit", async (e) => {
        e.preventDefault();

        const spinner = document.getElementById("spinner");
        const btnText = submitBtn.querySelector("span");

        submitBtn.disabled = true;
        spinner.classList.remove("hidden");
        btnText.textContent = "Enviando...";

        try {
            const formData = new FormData(form);
            const response = await fetch(
                "/api/educacion-continua-inscription",
                {
                    method: "POST",
                    body: formData,
                },
            );

            if (response.ok) {
                form.classList.add("hidden");
                successMsg.classList.remove("hidden");
                window.scrollTo({
                    top: successMsg.offsetTop - 100,
                    behavior: "smooth",
                });
            } else {
                throw new Error("Error en el servidor");
            }
        } catch (error) {
            console.error(error);
            alert(
                "Hubo un error al procesar tu inscripción. Por favor intenta de nuevo o contáctanos por WhatsApp.",
            );
        } finally {
            submitBtn.disabled = false;
            spinner.classList.add("hidden");
            btnText.textContent = "Finalizar";
        }
    });
</script>
