---
import { getCollection } from "astro:content";
import Button from "@components/ui/Button.astro";
import ProgramOfferCard from "@components/program/ProgramOfferCard.astro";
import type { ProgramaNivel } from "@lib/programNiveles";
import {
    filterCatalogPrograms,
    filterPastPrograms,
    getEffectiveProgramStatus,
} from "@lib/programPublished";
import { getProgramPathSlug } from "@lib/programPaths";

interface SectionGroup {
    title: string;
    niveles?: ProgramaNivel[];
    subsections?: ProgramSubsection[];
}

interface ProgramSubsection {
    title: string;
    niveles: ProgramaNivel[];
    titleIncludes?: string[];
    excludeTitleIncludes?: string[];
}

interface Props {
    escuela: "integral" | "economica" | "juridica";
    emptyHint: string;
    emptyTitle?: string;
    /** Si es true, oculta programas waitlist/disabled y muestra solo activos. */
    activeOnly?: boolean;
    /** Si se define, divide la cuadrícula en secciones (p. ej. Formación Jurídica: continua vs postgrado). */
    sectionGroups?: SectionGroup[];
}

const {
    escuela,
    emptyHint,
    emptyTitle = "Próximamente",
    activeOnly = false,
    sectionGroups,
} = Astro.props as Props;

const collection = await getCollection("programas");

const programs = filterCatalogPrograms(collection)
    .filter((p) => p.data.escuela === escuela)
    .filter((p) => !activeOnly || getEffectiveProgramStatus(p) === "active")
    .sort((a, b) => {
        const statusA = getEffectiveProgramStatus(a) === "active" ? 0 : 1;
        const statusB = getEffectiveProgramStatus(b) === "active" ? 0 : 1;
        if (statusA !== statusB) return statusA - statusB;
        return a.data.title.localeCompare(b.data.title, "es", {
            sensitivity: "base",
        });
    });

const pastPrograms = filterPastPrograms(collection)
    .filter((p) => p.data.escuela === escuela)
    .sort((a, b) =>
        a.data.title.localeCompare(b.data.title, "es", {
            sensitivity: "base",
        }),
    );

const useGroups =
    Array.isArray(sectionGroups) &&
    sectionGroups.length > 0 &&
    programs.length > 0;

const showEmptyCatalog = programs.length === 0 && pastPrograms.length === 0;

function normalizedProgramText(program: (typeof programs)[number]) {
    return `${program.data.title} ${getProgramPathSlug(program)}`.toLocaleLowerCase("es");
}

function matchesSubsection(
    program: (typeof programs)[number],
    subsection: ProgramSubsection,
) {
    const text = normalizedProgramText(program);
    const includesTitle =
        !subsection.titleIncludes ||
        subsection.titleIncludes.some((needle) =>
            text.includes(needle.toLocaleLowerCase("es")),
        );
    const excludesTitle =
        subsection.excludeTitleIncludes?.some((needle) =>
            text.includes(needle.toLocaleLowerCase("es")),
        ) ?? false;

    return (
        subsection.niveles.includes(program.data.nivel as ProgramaNivel) &&
        includesTitle &&
        !excludesTitle
    );
}

function programsForGroup(group: SectionGroup) {
    if (!group.niveles || group.niveles.length === 0) return [];
    return programs.filter((p) =>
        group.niveles?.includes(p.data.nivel as ProgramaNivel),
    );
}

function programsForSubsection(subsection: ProgramSubsection) {
    return programs.filter((p) => matchesSubsection(p, subsection));
}
---

{
    showEmptyCatalog ? (
        <div class="col-span-full text-center py-20 bg-white rounded-xl shadow-sm">
            <div class="mb-6 mx-auto w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-8 w-8 text-gray-400"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    aria-hidden="true"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"
                    />
                </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-2">{emptyTitle}</h3>
            <p class="text-gray-600 max-w-md mx-auto">{emptyHint}</p>
            <div class="mt-8">
                <Button href="/contacto" variant="primary">
                    Solicitar información
                </Button>
            </div>
        </div>
    ) : (
        <>
            {useGroups && sectionGroups ? (
                <>
                    {sectionGroups.map((group) => {
                        const subsections = group.subsections ?? [];
                        const groupPrograms =
                            subsections.length > 0
                                ? subsections.flatMap((subsection) =>
                                      programsForSubsection(subsection),
                                  )
                                : programsForGroup(group);
                        const uniqueGroupProgramCount = new Set(
                            groupPrograms.map((program) => program.id),
                        ).size;
                        if (uniqueGroupProgramCount === 0) return null;
                        return (
                            <div class="mt-10">
                                <h2 class="text-3xl font-bold text-primary mb-6 font-serif">
                                    {group.title}
                                </h2>
                                {subsections.length > 0 ? (
                                    <div class="space-y-5 border-l-2 border-transparent pl-4 md:pl-6">
                                        {subsections
                                            .map((subsection) => ({
                                                subsection,
                                                programs:
                                                    programsForSubsection(
                                                        subsection,
                                                    ),
                                            }))
                                            .filter(
                                                ({ programs }) =>
                                                    programs.length > 0,
                                            )
                                            .map(
                                                (
                                                    {
                                                        subsection,
                                                        programs:
                                                            subsectionPrograms,
                                                    },
                                                    subsectionIndex,
                                                ) => (
                                                    <details
                                                        class="group border border-gray-200 rounded-xl bg-gray-50/80 shadow-sm overflow-hidden open:shadow-md transition-shadow"
                                                        open={
                                                            subsectionIndex ===
                                                            0
                                                        }
                                                        data-program-subsection
                                                    >
                                                        <summary class="cursor-pointer list-none flex items-center justify-between gap-4 px-5 py-4 font-serif text-xl md:text-2xl font-bold text-gray-800 hover:bg-white/80 transition-colors [&::-webkit-details-marker]:hidden">
                                                            <span class="text-left">
                                                                {
                                                                    subsection.title
                                                                }
                                                            </span>
                                                            <svg
                                                                xmlns="http://www.w3.org/2000/svg"
                                                                class="h-6 w-6 text-secondary shrink-0 transition-transform duration-200 group-open:rotate-180"
                                                                fill="none"
                                                                viewBox="0 0 24 24"
                                                                stroke="currentColor"
                                                                aria-hidden="true"
                                                            >
                                                                <path
                                                                    stroke-linecap="round"
                                                                    stroke-linejoin="round"
                                                                    stroke-width="2"
                                                                    d="M19 9l-7 7-7-7"
                                                                />
                                                            </svg>
                                                        </summary>
                                                        <div class="px-5 pb-5 pt-5 border-t border-gray-200/80 bg-white">
                                                            <div
                                                                class="grid md:grid-cols-2 lg:grid-cols-3 gap-8"
                                                                data-program-card-grid
                                                            >
                                                                {subsectionPrograms.map(
                                                                    (
                                                                        program,
                                                                        index,
                                                                    ) => (
                                                                        <ProgramOfferCard
                                                                            program={
                                                                                program
                                                                            }
                                                                            index={
                                                                                index
                                                                            }
                                                                        />
                                                                    ),
                                                                )}
                                                            </div>
                                                        </div>
                                                    </details>
                                                ),
                                            )}
                                    </div>
                                ) : (
                                    <div
                                        class="grid md:grid-cols-2 lg:grid-cols-3 gap-8"
                                        data-program-card-grid
                                    >
                                        {groupPrograms.map((program, index) => (
                                            <ProgramOfferCard
                                                program={program}
                                                index={index}
                                            />
                                        ))}
                                    </div>
                                )}
                            </div>
                        );
                    })}
                </>
            ) : programs.length > 0 ? (
                <div
                    class="grid md:grid-cols-2 lg:grid-cols-3 gap-8"
                    data-program-card-grid
                >
                    {programs.map((program, index) => (
                        <ProgramOfferCard program={program} index={index} />
                    ))}
                </div>
            ) : null}

            {pastPrograms.length > 0 ? (
                <div class="mt-16 border-t border-gray-200 pt-12">
                    <h2 class="text-3xl font-bold text-primary mb-3 font-serif">
                        Cursos pasados
                    </h2>
                    <p class="text-gray-600 mb-8 max-w-2xl">
                        Ediciones anteriores. Ya no están abiertas a inscripción.
                    </p>
                    {pastPrograms.length <= 3 ? (
                        <div
                            class="grid md:grid-cols-2 lg:grid-cols-3 gap-8"
                            data-program-card-grid
                        >
                            {pastPrograms.map((program, index) => (
                                <ProgramOfferCard
                                    program={program}
                                    index={index}
                                />
                            ))}
                        </div>
                    ) : (
                        <div class="relative">
                            <div class="swiper past-programs-swiper !pb-12">
                                <div class="swiper-wrapper">
                                    {pastPrograms.map((program, index) => (
                                        <div class="swiper-slide !h-auto">
                                            <div
                                                class="h-full px-1"
                                                data-program-card-grid
                                            >
                                                <ProgramOfferCard
                                                    program={program}
                                                    index={index}
                                                />
                                            </div>
                                        </div>
                                    ))}
                                </div>
                                <div class="swiper-pagination past-programs-pagination" />
                            </div>
                            <button
                                type="button"
                                class="past-programs-prev absolute left-0 top-1/2 z-10 -translate-x-1/2 -translate-y-1/2 rounded-full bg-white p-2.5 text-primary shadow-md ring-1 ring-gray-200 transition hover:bg-gray-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary md:-translate-x-full"
                                aria-label="Programas anteriores"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-5 w-5"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    aria-hidden="true"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M15 19l-7-7 7-7"
                                    />
                                </svg>
                            </button>
                            <button
                                type="button"
                                class="past-programs-next absolute right-0 top-1/2 z-10 translate-x-1/2 -translate-y-1/2 rounded-full bg-white p-2.5 text-primary shadow-md ring-1 ring-gray-200 transition hover:bg-gray-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary md:translate-x-full"
                                aria-label="Programas siguientes"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-5 w-5"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    aria-hidden="true"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9 5l7 7-7 7"
                                    />
                                </svg>
                            </button>
                        </div>
                    )}
                </div>
            ) : null}
        </>
    )
}

{
    pastPrograms.length > 3 ? (
        <>
            <link
                rel="stylesheet"
                href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
            />
            <script
                is:inline
                src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"
            />
            <script is:inline>
                function initPastProgramsSlider() {
                    const swiperEl = document.querySelector(
                        ".past-programs-swiper",
                    );
                    if (
                        !swiperEl ||
                        typeof Swiper === "undefined" ||
                        swiperEl.dataset.swiperReady === "1"
                    ) {
                        return;
                    }
                    swiperEl.dataset.swiperReady = "1";

                    new Swiper(".past-programs-swiper", {
                        slidesPerView: 1,
                        spaceBetween: 24,
                        // At the end, jump back to the first — no cloned/empty slides.
                        rewind: true,
                        watchOverflow: true,
                        navigation: {
                            prevEl: ".past-programs-prev",
                            nextEl: ".past-programs-next",
                        },
                        pagination: {
                            el: ".past-programs-pagination",
                            clickable: true,
                        },
                        breakpoints: {
                            768: { slidesPerView: 2 },
                            1024: { slidesPerView: 3 },
                        },
                    });
                }

                document.addEventListener(
                    "DOMContentLoaded",
                    initPastProgramsSlider,
                );
                document.addEventListener(
                    "astro:page-load",
                    initPastProgramsSlider,
                );
            </script>
            <style>
                .past-programs-swiper :global(.swiper-pagination-bullet-active) {
                    background: theme("colors.primary");
                }
            </style>
        </>
    ) : null
}

<script>
    function alignProgramCardBlocks() {
        const grids = document.querySelectorAll<HTMLElement>(
            "[data-program-card-grid]",
        );

        grids.forEach((grid) => {
            grid.querySelectorAll<HTMLElement>(
                "[data-program-card-title]",
            ).forEach((el) => {
                el.style.minHeight = "";
            });
            grid.querySelectorAll<HTMLElement>(
                "[data-program-card-excerpt]",
            ).forEach((el) => {
                el.style.minHeight = "";
            });
        });

        grids.forEach((grid) => {
            const titles = grid.querySelectorAll<HTMLElement>(
                "[data-program-card-title]",
            );
            let maxTitle = 0;
            titles.forEach((t) => {
                maxTitle = Math.max(maxTitle, t.getBoundingClientRect().height);
            });
            if (maxTitle > 0) {
                titles.forEach((t) => {
                    t.style.minHeight = `${Math.ceil(maxTitle)}px`;
                });
            }
        });

        requestAnimationFrame(() => {
            grids.forEach((grid) => {
                const excerpts = grid.querySelectorAll<HTMLElement>(
                    "[data-program-card-excerpt]",
                );
                let maxEx = 0;
                excerpts.forEach((e) => {
                    maxEx = Math.max(maxEx, e.getBoundingClientRect().height);
                });
                if (maxEx > 0) {
                    excerpts.forEach((e) => {
                        e.style.minHeight = `${Math.ceil(maxEx)}px`;
                    });
                }
            });
        });
    }

    alignProgramCardBlocks();

    if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(alignProgramCardBlocks);
    }

    document
        .querySelectorAll<HTMLDetailsElement>("[data-program-subsection]")
        .forEach((details) => {
            details.addEventListener("toggle", () => {
                requestAnimationFrame(alignProgramCardBlocks);
            });
        });

    let resizeTimer: number | undefined;
    window.addEventListener("resize", () => {
        if (resizeTimer !== undefined) {
            window.clearTimeout(resizeTimer);
        }
        resizeTimer = window.setTimeout(alignProgramCardBlocks, 100);
    });
</script>
