---
interface Props {
  title: string;
  items: string[];
  delay?: number;
}

const { title, items, delay = 300 } = Astro.props;
---

<div data-animate="fade-up" data-delay={delay}>
    <h2
        class="text-lg font-bold text-gray-800 mb-3 border-b pb-2 font-serif"
    >
        {title}
    </h2>
    <ul class="space-y-3">
        {
            items.map((item) => (
                <li class="flex items-start gap-3 text-gray-600">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-6 w-6 text-secondary flex-shrink-0"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        aria-hidden="true"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 14l9-5-9-5-9 5 9 5z"
                        />
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"
                        />
                    </svg>
                    <span>{item}</span>
                </li>
            ))
        }
    </ul>
</div>
