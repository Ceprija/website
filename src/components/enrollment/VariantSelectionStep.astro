---
import type { VariantOptions } from "@lib/programVariants";

interface Props {
    variants: VariantOptions;
    /** ID del contenedor del paso. El script de la página lo usa para mostrar/ocultar la sección. */
    stepId?: string;
}

const { variants, stepId = "step-variant" } = Astro.props;

const moduleSel = variants.moduleSelection;
const dateSel = variants.dateSelection;
const moduleRequired = moduleSel?.required !== false;
const dateRequired = dateSel?.required !== false;

/**
 * Each option's full payload is serialized into `data-variant-options` on the
 * enrollment form. The variant step itself only needs to render the dropdowns
 * and surface the user's choice via two hidden inputs (`selectedModule`,
 * `selectedDate`). Live previews under each select read the same dataset.
 */
---

<section class="step-section p-8 md:p-12" id={stepId}>
    <div class="mb-8 text-center">
        <div
            class="inline-block p-4 bg-blue-50 rounded-2xl mb-4 text-primary"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-8 w-8"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"
                ></path>
            </svg>
        </div>
        <p class="text-gray-600 text-sm max-w-2xl mx-auto">
            Personaliza tu inscripción seleccionando el formato y la fecha de inicio.
        </p>
    </div>

    <div class="grid grid-cols-1 gap-6 max-w-4xl mx-auto">
        {
            moduleSel && (
                <div>
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        for="variant-module-select"
                    >
                        {moduleSel.label}
                        {moduleRequired ? " *" : ""}
                    </label>
                    <select
                        id="variant-module-select"
                        name="selectedModule"
                        required={moduleRequired}
                        data-variant-kind="module"
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                    >
                        <option value="">Selecciona una opción…</option>
                        {moduleSel.options.map((opt) => (
                            <option
                                value={opt.id}
                                data-description={opt.description ?? ""}
                                data-label={opt.label}
                            >
                                {opt.label}
                            </option>
                        ))}
                    </select>
                    <p
                        id="variant-module-description"
                        class="mt-2 text-sm text-gray-500 hidden"
                        aria-live="polite"
                    />
                </div>
            )
        }

        {
            dateSel && (
                <div>
                    <label
                        class="block text-sm font-semibold text-gray-700 mb-2"
                        for="variant-date-select"
                    >
                        {dateSel.label}
                        {dateRequired ? " *" : ""}
                    </label>
                    <select
                        id="variant-date-select"
                        name="selectedDate"
                        required={dateRequired}
                        data-variant-kind="date"
                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                    >
                        <option value="">Selecciona una fecha…</option>
                        {dateSel.options.map((opt) => (
                            <option
                                value={opt.id}
                                data-description={opt.description ?? ""}
                                data-label={opt.label}
                            >
                                {opt.label}
                            </option>
                        ))}
                    </select>
                    <p
                        id="variant-date-description"
                        class="mt-2 text-sm text-gray-500 hidden"
                        aria-live="polite"
                    />
                </div>
            )
        }
    </div>

    <div class="flex justify-end mt-8 max-w-4xl mx-auto">
        <button
            type="button"
            id="next-step-variant"
            class="px-8 py-3 bg-secondary hover:bg-secondary/90 text-white font-bold rounded-xl transition-all shadow-lg hover:shadow-xl"
        >
            Siguiente
        </button>
    </div>
</section>

<script>
    /**
     * Dropdown live preview: when the user picks a module/date, render the option's
     * `description` (price/duration, schedule, etc.) right below it. Avoids cluttering
     * the parent enrollment script with cosmetic logic and works in isolation.
     */
    function bindVariantPreview(selectId: string, descriptionId: string) {
        const select = document.getElementById(selectId) as HTMLSelectElement | null;
        const desc = document.getElementById(descriptionId);
        if (!select || !desc) return;
        const update = () => {
            const opt = select.options[select.selectedIndex];
            const text = (opt?.dataset.description ?? "").trim();
            if (text) {
                desc.textContent = text;
                desc.classList.remove("hidden");
            } else {
                desc.textContent = "";
                desc.classList.add("hidden");
            }
        };
        select.addEventListener("change", update);
        update();
    }
    bindVariantPreview("variant-module-select", "variant-module-description");
    bindVariantPreview("variant-date-select", "variant-date-description");
</script>
