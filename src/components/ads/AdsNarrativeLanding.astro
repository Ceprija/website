---
import AdsLandingLayout from "../../layouts/AdsLandingLayout.astro";
import AdsLandingCta from "./AdsLandingCta.astro";
import BrochureLeadModal from "../forms/BrochureLeadModal.astro";
import { images } from "@lib/assets";
import { buildSeptiembre2026CtaHref } from "@lib/septiembre2026Programs";
import {
  adsProse,
  adsProseClosing,
  adsProseHero,
} from "@lib/adsLandingStyles";
import type { CollectionEntry } from "astro:content";

interface Props {
  landing: CollectionEntry<"landings">;
}

const { landing } = Astro.props;
const data = landing.data;
const narrative = data.narrative;
if (!narrative) {
  throw new Error(
    `AdsNarrativeLanding requires landing.data.narrative (landing id: ${landing.id})`,
  );
}

const programSlug = data.programSlug;
const title = data.title;
const ctaHref = buildSeptiembre2026CtaHref(programSlug);
const stickyCtaLabel = narrative.stickyCtaLabel || "Quiero apartar mi lugar";
const brochure =
  typeof data.brochure === "string" && data.brochure.trim()
    ? data.brochure.trim()
    : "";

const sections = narrative.sections.map((section, index) => {
  const tone = index % 3 === 1 ? "dark" : index % 3 === 2 ? "muted" : "light";
  return { ...section, tone };
});
---

<AdsLandingLayout
  title={data.seoTitle || `${title} | Inicio ${data.startDate} | CEPRIJA`}
  description={data.seoDescription || data.excerpt || data.description}
  image={data.image}
>
  <div class="sticky top-0 z-40 border-b border-gray-200 bg-white shadow-sm">
    <div
      class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-3 sm:px-6"
    >
      <img src={images.logosvg} alt="CEPRIJA" class="h-9 w-auto sm:h-10" />
      <a
        href={ctaHref}
        data-utm="true"
        class="shrink-0 rounded-full bg-secondary px-4 py-2 text-sm font-bold text-primary transition hover:bg-yellow-400 sm:px-5"
      >
        {stickyCtaLabel} →
      </a>
    </div>
  </div>

  <section class="relative min-h-[88vh] overflow-hidden text-white">
    <img
      src={data.image}
      alt=""
      class="absolute inset-0 h-full w-full object-cover"
      fetchpriority="high"
    />
    <div
      class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/45 to-black/60"
    >
    </div>
    <div
      class="relative z-10 mx-auto flex min-h-[88vh] max-w-6xl flex-col items-center justify-center px-4 py-20 text-center sm:px-6"
    >
      <p
        class="mb-4 font-serif text-2xl font-bold tracking-tight text-secondary sm:text-3xl"
        data-animate="fade-up"
        data-delay="50"
      >
        CEPRIJA
      </p>
      <h1
        class="max-w-4xl font-serif text-4xl font-bold leading-tight sm:text-5xl lg:text-6xl"
        data-animate="fade-up"
        data-delay="100"
      >
        {narrative.heroHeadline}
      </h1>
      <p
        class="mt-5 max-w-3xl text-lg font-semibold text-white sm:text-xl"
        data-animate="fade-up"
        data-delay="150"
      >
        {title}
      </p>
      <p
        class:list={["mt-6 max-w-2xl", adsProseHero]}
        data-animate="fade-up"
        data-delay="200"
      >
        {narrative.heroSupport}
      </p>
      <div
        class="mt-10 flex flex-wrap items-center justify-center gap-4"
        data-animate="fade-up"
        data-delay="250"
      >
        <AdsLandingCta programa={programSlug} label={stickyCtaLabel} />
      </div>
    </div>
  </section>

  {
    sections.map((section) => {
      const isDark = section.tone === "dark";
      const isMuted = section.tone === "muted";
      const sectionClass = isDark
        ? "bg-primary py-20 text-white"
        : isMuted
          ? "bg-gray-50 py-20"
          : "bg-white py-20";
      const titleClass = isDark
        ? "font-serif text-3xl font-bold sm:text-4xl"
        : "font-serif text-3xl font-bold text-primary sm:text-4xl";
      const bodyClass = isDark
        ? "mt-6 text-base md:text-lg leading-relaxed text-white/90"
        : `mt-6 ${adsProse}`;
      const brochureOutlineClass = isDark
        ? "inline-flex items-center justify-center rounded-full border-2 border-white/40 px-8 py-4 text-lg font-bold text-white transition hover:border-white hover:bg-white/10"
        : "inline-flex items-center justify-center rounded-full border-2 border-primary/30 px-8 py-4 text-lg font-bold text-primary transition hover:border-primary hover:bg-primary/5";
      const brochureSolidClass =
        "inline-flex items-center justify-center rounded-full bg-secondary px-8 py-4 text-lg font-bold text-primary transition hover:bg-yellow-400";

      return (
        <section id={section.id} class={sectionClass}>
          <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
            <h2 class={titleClass} data-animate="fade-up">
              {section.title}
            </h2>
            <p class={bodyClass} data-animate="fade-up">
              {section.body}
            </p>
            {(section.primaryCta || section.secondaryCta) && (
              <div
                class="mt-10 flex flex-wrap items-center justify-center gap-4"
                data-animate="fade-up"
              >
                {section.primaryCta?.action === "septiembre" ? (
                  <AdsLandingCta
                    programa={programSlug}
                    label={section.primaryCta.label}
                    variant="secondary"
                  />
                ) : null}
                {section.primaryCta?.action === "brochure" && brochure ? (
                  <button
                    type="button"
                    data-brochure-open
                    class={brochureSolidClass}
                  >
                    {section.primaryCta.label}
                  </button>
                ) : null}
                {section.secondaryCta?.action === "septiembre" ? (
                  <AdsLandingCta
                    programa={programSlug}
                    label={section.secondaryCta.label}
                    variant={isDark ? "outline" : "outline"}
                    class={
                      isDark
                        ? "border-white/50 text-white hover:bg-white/10"
                        : ""
                    }
                  />
                ) : null}
                {section.secondaryCta?.action === "brochure" && brochure ? (
                  <button
                    type="button"
                    data-brochure-open
                    class={brochureOutlineClass}
                  >
                    {section.secondaryCta.label}
                  </button>
                ) : null}
              </div>
            )}
          </div>
        </section>
      );
    })
  }

  <footer class="border-t border-gray-200 bg-white py-10">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <p class="font-serif text-lg font-bold text-primary">CEPRIJA</p>
      <p class:list={[adsProseClosing]}>
        {data.nivelLabel} · Inicio {data.startDate}
        {data.rvoe ? ` · RVOE ${data.rvoe}` : ""}
      </p>
      <div class="mt-6 flex justify-center">
        <AdsLandingCta
          programa={programSlug}
          label={stickyCtaLabel}
          size="md"
        />
      </div>
    </div>
  </footer>

  {
    brochure ? (
      <BrochureLeadModal
        programSlug={programSlug}
        programTitle={title}
        brochure={brochure}
        landingSlug={landing.id}
      />
    ) : null
  }
</AdsLandingLayout>
