---
import { getCollection } from "astro:content";
import ProgramOfferCard from "@components/program/ProgramOfferCard.astro";
import {
  sectionMuted,
  containerWide,
  headingSection,
  rowHeader,
  linkSecondary,
} from "@lib/landingSectionStyles";
import { filterPublishedPrograms } from "@lib/programPublished";
import {
  POSGRADO_NIVELES,
  EDUCACION_CONTINUA_NIVELES,
  pickHomePrograms,
} from "@lib/programNiveles";

const programas = filterPublishedPrograms(await getCollection("programas"));
const posgrado = pickHomePrograms(programas, POSGRADO_NIVELES);
const edContinua = pickHomePrograms(programas, EDUCACION_CONTINUA_NIVELES);

const blocks = [
  {
    id: "posgrado",
    title: "Posgrado",
    programs: posgrado,
    ctaHref: "/oferta-academica",
    ctaLabel: "Ver toda la oferta",
  },
  {
    id: "educacion-continua",
    title: "Educación Continua",
    programs: edContinua,
    ctaHref: "/oferta-academica",
    ctaLabel: "Ver toda la oferta",
  },
].filter((s) => s.programs.length > 0);
---

{
  blocks.length > 0 ? (
    <section
      class={sectionMuted}
      aria-labelledby="home-oferta-academica-heading"
    >
      <div class={containerWide}>
        <h2
          id="home-oferta-academica-heading"
          class={headingSection}
          data-animate="fade-up"
        >
          Nuestra Oferta Académica
        </h2>

        <div class="space-y-14">
          {blocks.map((block) => (
            <div aria-labelledby={`home-${block.id}-heading`}>
              <div class={rowHeader} data-animate="fade-up">
                <h3
                  id={`home-${block.id}-heading`}
                  class="text-2xl font-bold text-primary font-serif"
                >
                  {block.title}
                </h3>
                <a
                  href={block.ctaHref}
                  class={`${linkSecondary} shrink-0 text-sm`}
                >
                  {block.ctaLabel}
                </a>
              </div>

              <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4 lg:gap-8">
                {block.programs.map((program, index) => (
                  <ProgramOfferCard
                    program={program}
                    index={index}
                    showDescription={false}
                    compact={true}
                  />
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  ) : null
}
