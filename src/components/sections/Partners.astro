---
import { partners } from "@data/partners";
import {
  sectionPartners,
  containerNarrow,
  gridPartners,
  partnerLogoImg,
  partnerLogoSlot,
  partnerLogoSlotOnDark,
} from "@lib/landingSectionStyles";

const visiblePartners = partners.filter((p) => p.active !== false);
---

{
  visiblePartners.length > 0 ? (
    <section class={sectionPartners} aria-label="Convenios y alianzas">
      <div class={containerNarrow}>
        <p
          class="mx-auto mb-6 max-w-3xl text-center text-sm text-gray-500 sm:mb-8 sm:text-base"
          data-animate="fade-up"
        >
          CEPRIJA colabora con instituciones y organismos para fortalecer la
          formación profesional.
        </p>

        <div class={gridPartners} data-animate="fade-up" data-delay="80">
          {visiblePartners.map((p) => {
            const slot = p.onDark ? partnerLogoSlotOnDark : partnerLogoSlot;
            return p.url ? (
              <a
                href={p.url}
                target="_blank"
                rel="noopener noreferrer"
                class={slot}
                title={p.name}
              >
                <img
                  src={p.logo}
                  alt={p.name}
                  class={partnerLogoImg}
                  loading="lazy"
                  width="192"
                  height="192"
                />
              </a>
            ) : (
              <span class={slot} title={p.name}>
                <img
                  src={p.logo}
                  alt={p.name}
                  class={partnerLogoImg}
                  loading="lazy"
                  width="192"
                  height="192"
                />
              </span>
            );
          })}
        </div>
      </div>
    </section>
  ) : null
}
