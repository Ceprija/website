---
import {
    sectionSurfaceOverflow,
    containerNarrow,
    headingSectionCompact,
    lead,
} from "@lib/landingSectionStyles";
import { getFacultyMembers } from "../../lib/faculty";
import FacultyCard from "../faculty/FacultyCard.astro";

interface Props {
    limit?: number;
    showTitle?: boolean;
    isSlider?: boolean;
}

const { limit, showTitle = true, isSlider = false } = Astro.props;

const allFaculty = await getFacultyMembers();
// Sliders show the full roster; only the static grid honors `limit`.
const visibleFaculty =
    limit && !isSlider ? allFaculty.slice(0, limit) : allFaculty;
---

<section class={sectionSurfaceOverflow}>
    <div class={containerNarrow}>
        {
            showTitle && (
                <>
                    <h2
                        class={headingSectionCompact}
                        data-animate="fade-up"
                    >
                        Claustro Docente
                    </h2>
                    <p class={lead}>
                        Nuestro cuerpo académico está formado por expertos con
                        amplia trayectoria profesional y docente, comprometidos
                        con tu formación.
                    </p>
                </>
            )
        }

        {
            isSlider ? (
                <div class="swiper faculty-swiper !pb-12">
                    <div class="swiper-wrapper">
                        {visibleFaculty.map((member) => (
                            <div class="swiper-slide !h-auto">
                                <div class="px-2 h-full">
                                    <FacultyCard member={member} lazy />
                                </div>
                            </div>
                        ))}
                    </div>
                    <div class="swiper-pagination" />
                </div>
            ) : (
                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                    {visibleFaculty.map((member, index) => (
                        <div
                            class="max-w-[80%] mx-auto h-full"
                            data-animate="zoom-in"
                            data-delay={index * 100}
                        >
                            <FacultyCard member={member} />
                        </div>
                    ))}
                </div>
            )
        }

        {
            !isSlider && limit && allFaculty.length > limit && (
                <div class="text-center mt-12">
                    <a
                        href="/docentes"
                        class="inline-block bg-primary text-white font-bold py-3 px-8 rounded-full hover:bg-blue-900 transition-colors shadow-lg hover:shadow-xl"
                    >
                        Ver todo el claustro
                    </a>
                </div>
            )
        }
    </div>
</section>

{
    isSlider && (
        <>
            <link
                rel="stylesheet"
                href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
            />
            <script
                is:inline
                src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"
            />
            <script is:inline>
                function initFacultySlider() {
                    const swiperEl = document.querySelector(".faculty-swiper");
                    if (swiperEl && typeof Swiper !== "undefined") {
                        new Swiper(".faculty-swiper", {
                            slidesPerView: 1,
                            spaceBetween: 20,
                            loop: true,
                            autoplay: {
                                delay: 3000,
                                disableOnInteraction: false,
                            },
                            pagination: {
                                el: ".swiper-pagination",
                                clickable: true,
                            },
                            breakpoints: {
                                640: { slidesPerView: 2 },
                                1024: { slidesPerView: 3 },
                            },
                        });
                    }
                }

                document.addEventListener("DOMContentLoaded", initFacultySlider);
                document.addEventListener("astro:page-load", initFacultySlider);
            </script>
        </>
    )
}

<style>
    .faculty-swiper :global(.swiper-pagination-bullet-active) {
        background: theme("colors.primary");
    }
</style>
