---
import Button from '../ui/Button.astro';
import { heroContainer } from '@lib/landingSectionStyles';

/** Image-only hero slides (full artwork + optional CTA). */
type HeroImageOnlySlide = {
  image: string;
  /** Optional smaller/cropped asset for narrow viewports (<picture>). */
  imageMobile?: string;
  alt?: string;
  imageOnly: true;
  /** object-position on md+ when using object-cover (e.g. "50% 30%"). */
  objectPosition?: string;
  /** object-position below md when using object-contain. */
  objectPositionMobile?: string;
  cta?: string;
  link?: string;
  /** Desktop/tablet: CTA placed on the artwork (percent of slide). */
  ctaPosition?: { left: number; top: number };
};

type HeroTextSlide = {
  image: string;
  title: string;
  subtitle: string;
  cta: string;
  link: string;
  imageOnly?: false;
};

type HeroSlide = HeroTextSlide | HeroImageOnlySlide;

function isImageOnlySlide(slide: HeroSlide): slide is HeroImageOnlySlide {
  return slide.imageOnly === true;
}

const slides: HeroSlide[] = [
  {
    image: "images/branding/site/ceprija_02.webp",
    title: "Formando Líderes con Excelencia",
    subtitle: "Licenciaturas, Maestrías y Doctorados con validez oficial. Tu futuro comienza aquí.",
    cta: "Ver Oferta Académica",
    link: "/oferta-academica"
  },
  {
    image: "images/branding/site/ceprija_01.webp",
    title: "Educación Flexible y Moderna",
    subtitle: "Estudia a tu ritmo con nuestros modelos presenciales y en línea.",
    cta: "Conoce Más",
    link: "/nosotros"
  },
  {
    image: "images/branding/site/ceprija_03.webp",
    title: "Alcanza tus Metas Profesionales",
    subtitle: "Únete a una comunidad de egresados exitosos en el sector público y privado.",
    cta: "Inscríbete Hoy",
    link: "/admisiones"
  },
  {
    image: "images/hero/reforma-laboral.webp",
    imageMobile: "images/hero/reforma-laboral-mobile.webp",
    alt: "Webinar Reforma Laboral en México — CEPRIJA",
    imageOnly: true,
    objectPosition: "42% 48%",
    objectPositionMobile: "center",
    cta: "Regístrate al webinar",
    link: "/oferta-academica/webinar-reforma-laboral",
    ctaPosition: { left: 4.5, top: 69 },
  },
];
---

<div class="relative min-h-screen w-full overflow-hidden bg-gray-900" id="hero-slider">
  <!-- Slides -->
  {slides.map((slide, index) => (
    <div class={`absolute inset-0 transition-opacity duration-1000 ease-in-out ${index === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0'} slide-item`} data-index={index}>
      <!-- Background Image with Overlay -->
      <div class="absolute inset-0">
        {isImageOnlySlide(slide) ? (
          <>
            <picture class="hero-image-only-picture block h-full w-full">
              {slide.imageMobile && (
                <source media="(max-width: 767px)" srcset={slide.imageMobile} />
              )}
              <img
                src={slide.image}
                alt={slide.alt ?? ''}
                class="hero-image-only-img h-full w-full"
                style={{
                  '--hero-object-pos': slide.objectPosition ?? 'center',
                  '--hero-object-pos-mobile': slide.objectPositionMobile ?? 'center',
                }}
              />
            </picture>
            {slide.cta && slide.link && slide.ctaPosition && (
              <div
                class="absolute z-20 hidden md:block"
                style={`left: ${slide.ctaPosition.left}%; top: ${slide.ctaPosition.top}%`}
              >
                <Button
                  href={slide.link}
                  variant="secondary"
                  size="lg"
                  class="transform shadow-lg hover:scale-105"
                >
                  {slide.cta}
                </Button>
              </div>
            )}
            {slide.cta && slide.link && (
              <div class="absolute bottom-24 left-0 right-0 z-20 flex justify-center px-6 md:hidden">
                <Button
                  href={slide.link}
                  variant="secondary"
                  size="lg"
                  class="w-full max-w-sm shadow-lg"
                >
                  {slide.cta}
                </Button>
              </div>
            )}
          </>
        ) : (
          <>
            <img
              src={slide.image}
              alt={slide.title}
              class="h-full w-full object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-r from-primary/90 to-primary/40"></div>
          </>
        )}
      </div>
      
      {!isImageOnlySlide(slide) && (
        <div class={heroContainer}>
          <div class="max-w-3xl text-white" data-animate="fade-up">
            <h1 class="text-5xl md:text-7xl font-semi-bold mb-6 font-serif leading-tight">
              {slide.title}
            </h1>
            <p class="text-xl md:text-2xl mb-8 text-gray-200 font-light">
              {slide.subtitle}
            </p>
              <div class="flex flex-col sm:flex-row gap-4">
                <Button href={slide.link} variant="secondary" size="lg" class="w-full sm:w-auto transform hover:scale-105 shadow-lg">
                  {slide.cta}
                </Button>
              </div>
          </div>
        </div>
      )}
    </div>
  ))}

  <!-- Navigation Dots -->
  <div class="absolute bottom-8 left-0 right-0 z-30 flex justify-center gap-3">
    {slides.map((_, index) => (
      <button 
        class={`w-3 h-3 rounded-full transition-all duration-300 ${index === 0 ? 'bg-secondary w-8' : 'bg-white/50 hover:bg-white'}`}
        data-slide={index}
        aria-label={`Ir a diapositiva ${index + 1}`}
      ></button>
    ))}
  </div>

  <!-- Arrows -->
  <button id="prev-slide" aria-label="Ver diapositiva anterior" class="absolute left-4 top-1/2 transform -translate-y-1/2 z-30 bg-white/10 hover:bg-white/20 text-white p-3 rounded-full backdrop-blur-sm transition-colors">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
    </svg>
  </button>
  <button id="next-slide" aria-label="Ver siguiente diapositiva" class="absolute right-4 top-1/2 transform -translate-y-1/2 z-30 bg-white/10 hover:bg-white/20 text-white p-3 rounded-full backdrop-blur-sm transition-colors">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </button>
</div>

<style>
  /*
   * Image-only slides: marketing artwork is 16:9. On phones, object-cover crops
   * text/CTAs; object-contain shows the full graphic. Desktop uses cover + focal point.
   */
  .hero-image-only-img {
    object-fit: contain;
    object-position: var(--hero-object-pos-mobile, center);
  }

  @media (min-width: 768px) {
    .hero-image-only-img {
      object-fit: cover;
      object-position: var(--hero-object-pos, center);
    }
  }
</style>

<script>
  const slider = document.getElementById('hero-slider');
  const slides = slider?.querySelectorAll('.slide-item');
  const dots = slider?.querySelectorAll('[data-slide]');
  const prevBtn = document.getElementById('prev-slide');
  const nextBtn = document.getElementById('next-slide');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  let currentSlide = 0;
  let interval: number | undefined;

  function showSlide(index: number) {
    if (!slides || !dots) return;
    
    // Handle wrapping
    if (index >= slides.length) index = 0;
    if (index < 0) index = slides.length - 1;

    currentSlide = index;

    // Update slides
    slides.forEach((slide, i) => {
      if (i === currentSlide) {
        slide.classList.remove('opacity-0', 'z-0');
        slide.classList.add('opacity-100', 'z-10');
      } else {
        slide.classList.remove('opacity-100', 'z-10');
        slide.classList.add('opacity-0', 'z-0');
      }
    });

    // Update dots
    dots.forEach((dot, i) => {
      if (i === currentSlide) {
        dot.classList.remove('bg-white/50');
        dot.classList.add('bg-secondary', 'w-8');
      } else {
        dot.classList.remove('bg-secondary', 'w-8');
        dot.classList.add('bg-white/50');
      }
    });
  }

  function nextSlide() {
    showSlide(currentSlide + 1);
  }

  function prevSlide() {
    showSlide(currentSlide - 1);
  }

  function startAutoPlay() {
    if (prefersReducedMotion.matches) return;
    stopAutoPlay();
    interval = window.setInterval(nextSlide, 8000);
  }

  function stopAutoPlay() {
    if (interval) window.clearInterval(interval);
    interval = undefined;
  }

  // Event Listeners
  prevBtn?.addEventListener('click', () => {
    prevSlide();
    stopAutoPlay();
    startAutoPlay();
  });

  nextBtn?.addEventListener('click', () => {
    nextSlide();
    stopAutoPlay();
    startAutoPlay();
  });

  dots?.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      showSlide(index);
      stopAutoPlay();
      startAutoPlay();
    });
  });

  slider?.addEventListener('mouseenter', stopAutoPlay);
  slider?.addEventListener('mouseleave', startAutoPlay);
  slider?.addEventListener('focusin', stopAutoPlay);
  slider?.addEventListener('focusout', startAutoPlay);
  prefersReducedMotion.addEventListener('change', () => {
    if (prefersReducedMotion.matches) stopAutoPlay();
    else startAutoPlay();
  });

  // Start
  startAutoPlay();
</script>
