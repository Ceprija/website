---
import Button from '../ui/Button.astro';
import { heroContainer } from '@lib/landingSectionStyles';

type HeroTextSlide = {
  image: string;
  ctaHeader?: string;
  title: string;
  subtitle: string;
  /** Optional small line rendered above the CTA button. */
  ctaNote?: string;
  cta: string;
  link: string;
};

const slides: HeroTextSlide[] = [
  {
    image: "images/hero/reforma-laboral.webp",
    ctaHeader: "Webinar | Julio 2026",
    title: "Reforma Laboral en México",
    subtitle: "Jornada de 40 horas, implementación estratégica y desafíos empresariales.",
    ctaNote: "Anticípate a los cambios laborales en México",
    cta: "Inscríbete Hoy",
    link: "/oferta-academica/webinar-reforma-laboral",
  },
  {
    image: "images/hero/especialidad-criminalistica.webp",
    title: "Especialidad en Criminalística y Ciencias Forenses",
    subtitle: "La evidencia habla. Aprende a interpretarla",
    cta: "Inscríbete Hoy",
    link: "/oferta-academica/especialidad-en-criminalistica-y-ciencias-forenses",
  },
  {
    image: "images/hero/maestria-derecho-civil-familiar.webp",
    title: "Maestría en Derecho Civil y Familiar",
    subtitle: "Domina el nuevo sistema en oralidad.",
    cta: "Inscríbete Hoy",
    link: "/oferta-academica/maestria-en-derecho-civil-y-familiar",
  },
  {
    image: "images/hero/maestria-derecho-internacional.webp",
    title: "Maestría en Derecho Internacional de Derechos Humanos y Litigio Estratégico",
    subtitle: "Haz que tu voz trascienda fronteras",
    cta: "Inscríbete Hoy",
    link: "/oferta-academica/maestria-en-derecho-internacional-derechos-humanos-y-litigio-estrategico",
  },
  {
    image: "images/hero/doctorado-derecho-procesal.webp",
    title: "Doctorado en Derecho Procesal y Sistemas Contemporáneos",
    subtitle: "Eleva tu perfil con una formación que conecta todas las ramas del Derecho",
    cta: "Inscríbete Hoy",
    link: "/oferta-academica/doctorado-en-derecho-procesal-y-sistemas-contemporaneos",
  },
  {
    image: "images/hero/taller-simulacion-audiencias.webp",
    title: "Taller Práctico de Simulación de las Principales Audiencias",
    subtitle: "Practica antes de que tu caso sea real",
    cta: "Inscríbete Hoy",
    link: "/oferta-academica/taller-practico-simulacion-principales-audiencias",
  },
  {
    image: "images/hero/taller-tecnicas-litigacion-oral.webp",
    title: "Taller en Técnicas de Litigacion Oral",
    subtitle: "Haz que cada argumento cuente",
    cta: "Inscríbete Hoy",
    link: "/oferta-academica/taller-tecnicas-litigacion-oral",
  },
  {
    image: "images/hero/diplomado-civil-familiar.webp",
    title: "Diplomado Civil y Familiar: Adaptación Transversal a la Oralidad",
    subtitle: "Especialización jurídica para afrontar los retos del nuevo modelo de oralidad",
    cta: "Inscríbete Hoy",
    link: "/oferta-academica/diplomado-en-derecho-civil-y-familiar"
  },
];
---

<div class="relative min-h-screen w-full overflow-hidden bg-gray-900" id="hero-slider">
  <!-- Slides -->
  {slides.map((slide, index) => (
    <div class={`absolute inset-0 transition-opacity duration-1000 ease-in-out ${index === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0'} slide-item`} data-index={index}>
      <!-- Background Image with Overlay -->
      <div class="absolute inset-0">
        <img
          src={slide.image}
          alt={slide.title}
          class="h-full w-full object-cover"
        />
      </div>
      
      <div class={heroContainer}>
        <div class="max-w-3xl text-white" data-animate="fade-up">
          <div class="flex flex-col space-y-4 md:space-y-6">
            {slide.ctaHeader && (
              <p class="inline-flex w-fit rounded-full px-4 py-2 text-sm font-semibold" style="background:#202c35;color:#de0405;">
                {slide.ctaHeader}
              </p>
            )}
            <h1 class="text-5xl font-semi-bold font-serif leading-tight md:text-7xl">
              {slide.title}
            </h1>
            <p class="text-xl font-light text-gray-200 md:text-2xl">
              {slide.subtitle}
            </p>
            <div class="flex flex-col space-y-3 sm:items-start">
              <Button href={slide.link} variant="secondary" size="lg" class="w-full sm:w-auto transform hover:scale-105 shadow-lg">
                {slide.cta}
              </Button>
              {slide.ctaNote && (
                <p class="text-sm font-medium md:text-base" style="color:#c09418;">
                  {slide.ctaNote}
                </p>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  ))}

  <!-- Navigation Dots -->
  <div class="absolute bottom-8 left-0 right-0 z-30 flex justify-center gap-3">
    {slides.map((_, index) => (
      <button 
        class={`w-3 h-3 rounded-full transition-all duration-300 ${index === 0 ? 'bg-secondary w-8' : 'bg-white/50 hover:bg-white'}`}
        data-slide={index}
        aria-label={`Ir a diapositiva ${index + 1}`}
      ></button>
    ))}
  </div>

  <!-- Arrows -->
  <button id="prev-slide" aria-label="Ver diapositiva anterior" class="absolute left-4 top-1/2 transform -translate-y-1/2 z-30 bg-white/10 hover:bg-white/20 text-white p-3 rounded-full backdrop-blur-sm transition-colors">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
    </svg>
  </button>
  <button id="next-slide" aria-label="Ver siguiente diapositiva" class="absolute right-4 top-1/2 transform -translate-y-1/2 z-30 bg-white/10 hover:bg-white/20 text-white p-3 rounded-full backdrop-blur-sm transition-colors">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </button>
</div>

<script>
  const slider = document.getElementById('hero-slider');
  const slides = slider?.querySelectorAll('.slide-item');
  const dots = slider?.querySelectorAll('[data-slide]');
  const prevBtn = document.getElementById('prev-slide');
  const nextBtn = document.getElementById('next-slide');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  let currentSlide = 0;
  let interval: number | undefined;

  function showSlide(index: number) {
    if (!slides || !dots) return;
    
    // Handle wrapping
    if (index >= slides.length) index = 0;
    if (index < 0) index = slides.length - 1;

    currentSlide = index;

    // Update slides
    slides.forEach((slide, i) => {
      if (i === currentSlide) {
        slide.classList.remove('opacity-0', 'z-0');
        slide.classList.add('opacity-100', 'z-10');
      } else {
        slide.classList.remove('opacity-100', 'z-10');
        slide.classList.add('opacity-0', 'z-0');
      }
    });

    // Update dots
    dots.forEach((dot, i) => {
      if (i === currentSlide) {
        dot.classList.remove('bg-white/50');
        dot.classList.add('bg-secondary', 'w-8');
      } else {
        dot.classList.remove('bg-secondary', 'w-8');
        dot.classList.add('bg-white/50');
      }
    });
  }

  function nextSlide() {
    showSlide(currentSlide + 1);
  }

  function prevSlide() {
    showSlide(currentSlide - 1);
  }

  function startAutoPlay() {
    if (prefersReducedMotion.matches) return;
    stopAutoPlay();
    interval = window.setInterval(nextSlide, 8000);
  }

  function stopAutoPlay() {
    if (interval) window.clearInterval(interval);
    interval = undefined;
  }

  // Event Listeners
  prevBtn?.addEventListener('click', () => {
    prevSlide();
    stopAutoPlay();
    startAutoPlay();
  });

  nextBtn?.addEventListener('click', () => {
    nextSlide();
    stopAutoPlay();
    startAutoPlay();
  });

  dots?.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      showSlide(index);
      stopAutoPlay();
      startAutoPlay();
    });
  });

  slider?.addEventListener('mouseenter', stopAutoPlay);
  slider?.addEventListener('mouseleave', startAutoPlay);
  slider?.addEventListener('focusin', stopAutoPlay);
  slider?.addEventListener('focusout', startAutoPlay);
  prefersReducedMotion.addEventListener('change', () => {
    if (prefersReducedMotion.matches) stopAutoPlay();
    else startAutoPlay();
  });

  // Start
  startAutoPlay();
</script>
