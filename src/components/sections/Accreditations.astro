---
const accreditations = [
    {
        title: "Programas con RVOE",
        description:
            "Cada uno de nuestros programas cuenta con Reconocimiento de Validez Oficial de Estudios (RVOE) otorgado por la Secretaría de Innovación, Ciencia y Tecnología (SICYT).",
        image: "/images/branding/accreditations/rvoe.svg",
        imageAlt: "Icono RVOE — Reconocimiento de Validez Oficial de Estudios",
    },
    {
        title: "Cédula Estatal y Federal",
        description:
            "Al egresar, obtendrás tu titulación oficial con Clave de Centro de Trabajo (14PSU0495P), permitiéndote ejercer profesionalmente en todo el territorio nacional.",
        image: "/images/branding/accreditations/cedula.svg",
        imageAlt: "Icono cédula profesional estatal y federal",
    },
];
---

<section class="py-14">
    <div class="container mx-auto px-6">
        <div class="grid md:grid-cols-2 gap-6 max-w-5xl mx-auto">
            {
                accreditations.map((item) => (
                    <div class="relative group overflow-hidden rounded-2xl bg-[#A6A1A1] p-8 shadow-lg border-l-4 border-secondary hover:shadow-xl transition-all duration-300">
                        <div class="absolute top-0 right-0 -mt-4 -mr-4 w-24 h-24 bg-secondary/10 rounded-full blur-2xl group-hover:bg-secondary/20 transition-colors" />

                        <div class="relative z-10 flex items-start gap-6">
                            <div class="flex-shrink-0">
                                <div
                                    class="w-14 h-14 bg-primary text-secondary rounded-xl flex items-center justify-center shadow-md transform group-hover:scale-110 transition-transform duration-300 overflow-hidden p-1.5"
                                    style={`background-color: white`}
                                >
                                    <img
                                        src={item.image}
                                        alt={item.imageAlt}
                                        class="w-full h-full object-contain"
                                        width="56"
                                        height="56"
                                        loading="lazy"
                                        decoding="async"
                                    />
                                </div>
                            </div>
                            <div>
                                <h3 class="text-xl font-bold text-primary mb-3 font-serif group-hover:text-blue-900 transition-colors">
                                    {item.title}
                                </h3>
                                <p class="text-white leading-relaxed text-sm">
                                    {item.description}
                                </p>
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
