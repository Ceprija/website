---
import { cookieConfig } from "../data/cookies.js";
---

<div
    id="cookie-banner"
    class="fixed bottom-0 left-0 w-full bg-white border-t border-gray-200 shadow-2xl z-50 transform translate-y-full transition-transform duration-500 hidden"
>
    <div class="container mx-auto px-6 py-6 text-sm font-sans">
        <div
            class="flex flex-col md:flex-row items-center justify-between gap-6"
        >
            <div class="flex-1">
                <h3 class="font-bold text-primary text-lg mb-2 font-serif">
                    {cookieConfig.title}
                </h3>
                <p class="text-gray-600 leading-relaxed">
                    {cookieConfig.message}
                    <a
                        href={cookieConfig.privacyLinkUrl}
                        class="text-secondary hover:underline font-medium ml-1"
                        target="_blank"
                    >
                        {cookieConfig.privacyLinkText}
                    </a>.
                </p>
            </div>
            <div class="flex items-center gap-4 shrink-0">
                <button
                    id="cookie-decline"
                    class="px-6 py-2.5 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50 transition-colors font-medium"
                >
                    {cookieConfig.declineButton}
                </button>
                <button
                    id="cookie-accept"
                    class="px-6 py-2.5 rounded-lg bg-primary text-white hover:bg-blue-900 transition-colors font-bold shadow-md hover:shadow-lg"
                >
                    {cookieConfig.acceptButton}
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    const banner = document.getElementById("cookie-banner");
    const acceptBtn = document.getElementById("cookie-accept");
    const declineBtn = document.getElementById("cookie-decline");
    const storageKey = "ceprija-cookie-consent";

    // Check if user has already made a choice
    const hasConsent = localStorage.getItem(storageKey);

    if (!hasConsent) {
        // Show banner with a slight delay for smooth entrance
        if (banner) {
            banner.classList.remove("hidden");
            // Use setTimeout to allow the 'hidden' removal to process before animating translate
            setTimeout(() => {
                banner.classList.remove("translate-y-full");
            }, 100);
        }
    }

    // Accept Logic
    acceptBtn?.addEventListener("click", () => {
        localStorage.setItem(storageKey, "accepted");
        hideBanner();
        // Optional: Trigger your analytics init here if not already handled
    });

    // Decline Logic
    declineBtn?.addEventListener("click", () => {
        localStorage.setItem(storageKey, "declined");
        hideBanner();
    });

    function hideBanner() {
        if (banner) {
            banner.classList.add("translate-y-full");
            setTimeout(() => {
                banner.classList.add("hidden");
            }, 500); // Wait for transition
        }
    }
</script>
