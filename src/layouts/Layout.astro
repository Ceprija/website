---
interface Props {
	title?: string;
	description?: string;
	image?: string;
	pageId?: string; // Key from seoConfig.pages (e.g., 'home', 'about')
	seo?: {
		// Manual override object
		title?: string;
		description?: string;
		image?: string;
	};
	breadcrumbs?: { label: string; path: string }[];
}

import Header from '../components/layout/Header.astro';
import Footer from "../components/layout/Footer.astro";
import WhatsAppButton from "../components/integrations/WhatsAppButton.astro";
import AnalyticsHead from "../components/integrations/AnalyticsHead.astro";
import AnalyticsBody from "../components/integrations/AnalyticsBody.astro";
import CookieBanner from "../components/integrations/CookieBanner.astro";
import SeoHead from "../components/SeoHead.astro";
import UtmTracker from "../components/integrations/UtmTracker.astro";
import { seoConfig } from "../data/config/seo";
import "../styles/animations.css";
import "@fontsource/ibm-plex-sans/100.css";
import "@fontsource/ibm-plex-sans/200.css";
import "@fontsource/ibm-plex-sans/300.css";
import "@fontsource/ibm-plex-sans/400.css";
import "@fontsource/ibm-plex-sans/500.css";
import "@fontsource/ibm-plex-sans/600.css";
import "@fontsource/ibm-plex-sans/700.css";
import "@fontsource/merriweather/300.css";
import "@fontsource/merriweather/400.css";
import "@fontsource/merriweather/700.css";
import "@fontsource/merriweather/900.css";
import "@fontsource/merriweather/300-italic.css";
import "@fontsource/merriweather/400-italic.css";
import "@fontsource/merriweather/700-italic.css";
import "@fontsource/merriweather/900-italic.css";

const {
	title: propTitle,
	description: propDesc,
	image: propImage,
	pageId,
	seo: propSeo,
	breadcrumbs,
} = Astro.props;

// 1. Get Base Defaults
const defaults = seoConfig.default;

// 2. Get Page Specific Config (if pageId exists)
// 2. Get Page Specific Config (if pageId exists)
const pageConfig = pageId
	? seoConfig.pages[pageId as keyof typeof seoConfig.pages]
	: ({} as any);

// 3. Merge: Manual Override > Page Config > Defaults
const title =
	propTitle || propSeo?.title || pageConfig?.title || defaults.title;
const description =
	propDesc ||
	propSeo?.description ||
	pageConfig?.description ||
	defaults.description;
const image =
	propImage || propSeo?.image || pageConfig?.image || defaults.image;
const absoluteImage = new URL(image, Astro.site).toString();
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="facebook-domain-verification"
			content="17ldzfe9plshw9doccg4mxgywf0e9o"
		/>
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="images/branding/logos/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={absoluteImage} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={absoluteImage} />

		<SeoHead
			title={title}
			description={description}
			image={image}
			breadcrumbs={breadcrumbs}
		/>

		<AnalyticsHead />
	</head>
	<body
		class="bg-white text-gray-900 font-sans antialiased flex flex-col min-h-screen"
	>
		<AnalyticsBody />
		<Header />
		<div class="flex-grow">
			<slot />
		</div>
		<Footer />
		<WhatsAppButton />
		<CookieBanner />
		<UtmTracker />
		<script>
			// Zero-dependency Scroll Animations
			const observerOptions = {
				root: null,
				rootMargin: "0px",
				threshold: 0.1,
			};

			const observer = new IntersectionObserver((entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add("is-visible");
						observer.unobserve(entry.target); // Run once
					}
				});
			}, observerOptions);

			document.querySelectorAll("[data-animate]").forEach((el) => {
				observer.observe(el);
			});
		</script>
	</body>
</html>
