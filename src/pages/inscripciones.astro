---
import Layout from "../layouts/Layout.astro";
import InscriptionForm from "../components/forms/InscriptionForm.astro";
import { getCollection } from "astro:content";

const program = Astro.url.searchParams.get("programa") || "";

// Get juridic programs from content collection instead of legacy data
const allPrograms = await getCollection("programas");
const juridicPrograms = allPrograms
    .filter(p => ["maestria", "doctorado", "especialidad"].includes(p.data.nivel))
    .map(p => p.data.title)
    .sort();
---

<Layout
    title="Inscripción en Línea | CEPRIJA"
    description="Portal oficial de inscripciones para programas jurídicos de CEPRIJA. Inicie su trayectoria académica hoy mismo."
>
    <!-- Background Accents -->
    <div
        class="absolute top-0 left-0 w-full h-96 bg-gradient-to-b from-blue-50 to-white -z-10"
    >
    </div>

    <main class="container mx-auto px-4 py-20">
        <!-- IMPORTANT NOTICE: Redirect to New Enrollment Flow -->
        <div class="max-w-4xl mx-auto mb-12">
            <div class="bg-amber-50 border-2 border-amber-300 rounded-2xl p-6 md:p-8 shadow-lg">
                <div class="flex items-start gap-4">
                    <div class="flex-shrink-0 mt-1">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                    </div>
                    <div class="flex-1">
                        <h2 class="text-xl md:text-2xl font-bold text-amber-900 mb-3">
                            Nuevo Proceso de Inscripción Disponible
                        </h2>
                        <p class="text-amber-800 mb-4 leading-relaxed">
                            Hemos actualizado nuestro proceso de inscripción para brindarte una mejor experiencia. 
                            Te recomendamos usar el nuevo flujo específico por programa en nuestra página de oferta académica.
                        </p>
                        <a 
                            href="/oferta-academica" 
                            class="inline-flex items-center gap-2 px-6 py-3 bg-secondary hover:bg-secondary/90 text-white font-bold rounded-xl transition-all shadow-md hover:shadow-lg"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                                <path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z" />
                            </svg>
                            Ir a Oferta Académica
                        </a>
                        <p class="text-sm text-amber-700 mt-4">
                            Esta página permanece disponible por compatibilidad, pero recomendamos fuertemente usar el nuevo flujo.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="text-center max-w-3xl mx-auto mb-16">
            <h1
                class="text-4xl md:text-5xl font-bold text-primary font-serif mb-6 leading-tight"
                data-animate="fade-up"
            >
                Proceso de Inscripción
            </h1>
            <p
                class="text-lg text-gray-600 leading-relaxed text-justify"
                data-animate="fade-up"
                data-delay="100"
            >
                Este formulario es el primer paso para integrar su expediente
                académico y garantizar la validez oficial de su inscripción. En
                CEPRIJA tratamos su información con la máxima seriedad. Todos
                los datos que nos proporcione serán utilizados únicamente para
                fines académicos, administrativos y de comunicación
                institucional, conforme a nuestro Aviso de Privacidad.
            </p>
        </div>
        <div
            class="text-left max-w-3xl mx-auto text-gray-600 leading-relaxed mb-10"
            data-animate="fade-up"
            data-delay="200"
        >
            <p><strong>Documentos requeridos:</strong></p>
            <ol class="mt-2">
                <li>
                    1.- Acta de Nacimiento (expedida en los últimos 3 meses)
                </li>
                <li>2.- CURP Actualizada</li>
                <li>3.- Identificación oficial vigente (INE)</li>
                <li>4.- Comprobante de domicilio (no mayor a 3 meses)</li>
                <li>5.- Cédula profesional</li>
                <li>6.- Título profesional</li>
            </ol>
        </div>
        <div
            class="text-left max-w-3xl mx-auto text-gray-600 leading-relaxed mb-10"
            data-animate="fade-up"
            data-delay="200"
        >
            <p>Nota: Solo se aceptan documentos originales.</p>
            <ul class="mt-2">
                <li>Descargados en línea o escaneados</li>

                <li>
                    <i>
                        Fotos de documentos o escaneos de copias no serán
                        aceptados.
                    </i>
                </li>
            </ul>
        </div>
        <div data-animate="fade-up" data-delay="200">
            <InscriptionForm selectedProgram={program} programList={juridicPrograms} />
        </div>

        <div
            class="mt-20 grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto"
            data-animate="fade-up"
            data-delay="300"
        >
            <div
                class="bg-white p-8 rounded-2xl border border-gray-100 shadow-sm text-center"
            >
                <div
                    class="w-12 h-12 bg-blue-100 text-primary rounded-full flex items-center justify-center mx-auto mb-4"
                >
                    <svg
                        class="w-6 h-6"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                        ></path></svg
                    >
                </div>
                <h4 class="font-bold text-gray-900 mb-2">Conexión Segura</h4>
                <p class="text-sm text-gray-500">
                    Sus datos personales y documentos están protegidos bajo
                    protocolos de seguridad.
                </p>
            </div>
            <div
                class="bg-white p-8 rounded-2xl border border-gray-100 shadow-sm text-center"
            >
                <div
                    class="w-12 h-12 bg-yellow-100 text-yellow-700 rounded-full flex items-center justify-center mx-auto mb-4"
                >
                    <svg
                        class="w-6 h-6"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                        ></path></svg
                    >
                </div>
                <h4 class="font-bold text-gray-900 mb-2">
                    Asistencia Continua
                </h4>
                <p class="text-sm text-gray-500">
                    Si tiene dudas, nuestro equipo de soporte está listo para
                    ayudarle vía WhatsApp.
                </p>
            </div>
            <div
                class="bg-white p-8 rounded-2xl border border-gray-100 shadow-sm text-center"
            >
                <div
                    class="w-12 h-12 bg-green-100 text-green-700 rounded-full flex items-center justify-center mx-auto mb-4"
                >
                    <svg
                        class="w-6 h-6"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                        ></path></svg
                    >
                </div>
                <h4 class="font-bold text-gray-900 mb-2">Registro Digital</h4>
                <p class="text-sm text-gray-500">
                    Ahorre tiempo completando su expediente de forma 100%
                    digital y transparente.
                </p>
            </div>
        </div>
    </main>
</Layout>
