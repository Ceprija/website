---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { getProgramPathSlug, validateUniqueSlugs } from "@lib/programPaths";
import { getEnrollmentFlow } from "@lib/enrollmentRouting";
import bankInfo from "../../data/bank-info.json";

export async function getStaticPaths() {
    const programs = await getCollection("programas");
    validateUniqueSlugs(programs);
    // Only generate pages for programs requiring application flow
    return programs
        .filter((program) => getEnrollmentFlow(program) === "application")
        .map((program) => ({
            params: { slug: getProgramPathSlug(program) },
            props: { program },
        }));
}

const { program } = Astro.props;
const programSlug = getProgramPathSlug(program);

const rawStripe = program.data.stripePriceIds;
const stripePriceIdsForClient =
    rawStripe &&
    typeof rawStripe === "object" &&
    !Array.isArray(rawStripe)
        ? rawStripe
        : null;

const seo = {
    title: `Solicitud de Admisión - ${program.data.title} | CEPRIJA`,
    description: `Complete su solicitud de admisión para ${program.data.title} en CEPRIJA.`,
};
---

<Layout seo={seo}>
    <main class="bg-gray-50 min-h-screen pb-20">
        <!-- Header -->
        <section class="bg-primary text-white py-12">
            <div class="container mx-auto px-6">
                <a
                    href={`/oferta-academica/${programSlug}`}
                    class="inline-flex items-center text-blue-100 hover:text-white mb-6 transition-colors"
                >
                    <svg
                        class="w-5 h-5 mr-2"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M15 19l-7-7 7-7"></path>
                    </svg>
                    Volver al programa
                </a>
                <h1 class="text-3xl md:text-4xl font-bold font-serif mb-2">
                    Solicitud de Admisión
                </h1>
                <p class="text-xl text-blue-100">{program.data.title}</p>
            </div>
        </section>

        <!-- Progress Stepper -->
        <section class="container mx-auto px-6 -mt-6 relative z-20">
            <div
                id="enrollment-stepper-card"
                class="bg-white rounded-2xl shadow-xl p-6 md:p-8 mb-8"
            >
                <div class="flex items-center justify-between mb-4">
                    <h2
                        class="text-xl font-bold text-primary font-serif"
                        id="step-label"
                    >
                        Paso 1 de 3: Información Personal
                    </h2>
                    <span class="text-sm font-semibold text-gray-500" id="step-number"
                        >33% completado</span
                    >
                </div>
                <div class="w-full bg-gray-100 h-3 rounded-full overflow-hidden">
                    <div
                        id="progress-bar"
                        class="bg-secondary h-full w-1/3 transition-all duration-500 ease-out shadow-sm"
                    >
                    </div>
                </div>
            </div>

            <!-- Form Container -->
            <form
                id="enrollment-form"
                class="bg-white rounded-2xl shadow-xl overflow-hidden"
                data-program-slug={programSlug}
                data-program-title={String(program.data.title)}
                data-stripe-price-ids={JSON.stringify(stripePriceIdsForClient)}
            >
                <!-- Hidden fields -->
                <input type="hidden" name="programSlug" value={programSlug} />
                <input type="hidden" name="programTitle" value={String(program.data.title)} />

                <!-- Step 1: Personal Information -->
                <div class="step-section p-8 md:p-12" id="step-1">
                    <div class="mb-8 text-center">
                        <div
                            class="inline-block p-4 bg-blue-50 rounded-2xl mb-4 text-primary"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-8 w-8"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                                ></path>
                            </svg>
                        </div>
                        <p class="text-gray-600 text-sm max-w-2xl mx-auto">
                            Complete su información personal para iniciar el proceso de admisión.
                        </p>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">
                                Nombre(s) *
                            </label>
                            <input
                                type="text"
                                name="nombre"
                                required
                                class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                placeholder="Tu nombre"
                            />
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">
                                Apellidos *
                            </label>
                            <input
                                type="text"
                                name="apellidos"
                                required
                                class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                placeholder="Tus apellidos"
                            />
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">
                                Correo Electrónico *
                            </label>
                            <input
                                type="email"
                                name="email"
                                required
                                class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                placeholder="tu@email.com"
                            />
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">
                                Teléfono / WhatsApp *
                            </label>
                            <input
                                type="tel"
                                name="telefono"
                                required
                                class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                placeholder="33 1234 5678"
                            />
                        </div>

                        <div class="md:col-span-2">
                            <label class="block text-sm font-semibold text-gray-700 mb-2">
                                Modalidad de Estudio *
                            </label>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <label class="flex items-center gap-3 p-4 border-2 border-gray-100 rounded-2xl cursor-pointer hover:bg-gray-50 transition-all has-[:checked]:border-primary has-[:checked]:bg-blue-50">
                                    <input
                                        type="radio"
                                        name="modality"
                                        value="Presencial"
                                        required
                                        checked
                                        class="w-5 h-5 text-primary focus:ring-primary"
                                    />
                                    <div class="flex flex-col">
                                        <span class="font-bold text-gray-900">Presencial</span>
                                        <span class="text-xs text-gray-500">Asistencia en campus</span>
                                    </div>
                                </label>
                                <label class="flex items-center gap-3 p-4 border-2 border-gray-100 rounded-2xl cursor-pointer hover:bg-gray-50 transition-all has-[:checked]:border-primary has-[:checked]:bg-blue-50">
                                    <input
                                        type="radio"
                                        name="modality"
                                        value="En línea"
                                        required
                                        class="w-5 h-5 text-primary focus:ring-primary"
                                    />
                                    <div class="flex flex-col">
                                        <span class="font-bold text-gray-900">En línea</span>
                                        <span class="text-xs text-gray-500">Vía videoconferencia</span>
                                    </div>
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="flex justify-end mt-8 max-w-4xl mx-auto">
                        <button
                            type="button"
                            id="next-step-1"
                            class="px-8 py-3 bg-secondary hover:bg-secondary/90 text-white font-bold rounded-xl transition-all shadow-lg hover:shadow-xl"
                        >
                            Siguiente
                        </button>
                    </div>
                </div>

                <!-- Step 2: Academic Background -->
                <div class="step-section p-8 md:p-12 hidden" id="step-2">
                    <div class="mb-8 text-center">
                        <div
                            class="inline-block p-4 bg-blue-50 rounded-2xl mb-4 text-primary"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-8 w-8"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    d="M12 14l9-5-9-5-9 5 9 5z"></path>
                                <path
                                    d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"
                                ></path>
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"
                                ></path>
                            </svg>
                        </div>
                        <p class="text-gray-600 text-sm max-w-2xl mx-auto">
                            Información sobre su formación académica previa.
                        </p>
                    </div>

                    <div class="grid grid-cols-1 gap-6 max-w-4xl mx-auto">
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">
                                Grado Académico Previo *
                            </label>
                            <select
                                name="ultimoGrado"
                                required
                                class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                            >
                                <option value="">Seleccione...</option>
                                <option value="Licenciatura">Licenciatura</option>
                                <option value="Maestría">Maestría</option>
                                <option value="Especialidad">Especialidad</option>
                                <option value="Doctorado">Doctorado</option>
                            </select>
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">
                                Carrera o Programa de Estudios *
                            </label>
                            <input
                                type="text"
                                name="carrera"
                                required
                                class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                placeholder="Ej: Derecho, Administración..."
                            />
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">
                                Institución de Egreso *
                            </label>
                            <input
                                type="text"
                                name="institucion"
                                required
                                class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                placeholder="Nombre de la universidad"
                            />
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">
                                Número de Cédula Profesional
                            </label>
                            <input
                                type="text"
                                name="cedulaNum"
                                class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                placeholder="Número de cédula (opcional)"
                            />
                        </div>
                    </div>

                    <div class="flex justify-between mt-8 max-w-4xl mx-auto">
                        <button
                            type="button"
                            id="prev-step-2"
                            class="px-8 py-3 bg-gray-200 hover:bg-gray-300 text-gray-700 font-bold rounded-xl transition-all"
                        >
                            Anterior
                        </button>
                        <button
                            type="button"
                            id="next-step-2"
                            class="px-8 py-3 bg-secondary hover:bg-secondary/90 text-white font-bold rounded-xl transition-all shadow-lg hover:shadow-xl"
                        >
                            Siguiente
                        </button>
                    </div>
                </div>

                <!-- Step 3: Documents Upload -->
                <div class="step-section p-8 md:p-12 hidden" id="step-3">
                    <div class="mb-8 text-center">
                        <div
                            class="inline-block p-4 bg-blue-50 rounded-2xl mb-4 text-primary"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-8 w-8"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                                ></path>
                            </svg>
                        </div>
                        <p class="text-gray-600 text-sm max-w-2xl mx-auto">
                            Adjunte los documentos requeridos. Solo se aceptan archivos PDF o imágenes (máx. 10 MB cada uno).
                        </p>
                    </div>

                    <div class="grid grid-cols-1 gap-6 max-w-4xl mx-auto">
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">
                                Curriculum Vitae (CV) *
                            </label>
                            <input
                                type="file"
                                name="cv"
                                required
                                accept=".pdf,.jpg,.jpeg,.png"
                                class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-primary hover:file:bg-blue-100"
                            />
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">
                                Historial Académico (Kardex) *
                            </label>
                            <input
                                type="file"
                                name="kardex"
                                required
                                accept=".pdf,.jpg,.jpeg,.png"
                                class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-primary hover:file:bg-blue-100"
                            />
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">
                                Título Profesional *
                            </label>
                            <input
                                type="file"
                                name="titulo"
                                required
                                accept=".pdf,.jpg,.jpeg,.png"
                                class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-primary hover:file:bg-blue-100"
                            />
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">
                                Cédula Profesional
                            </label>
                            <input
                                type="file"
                                name="cedula"
                                accept=".pdf,.jpg,.jpeg,.png"
                                class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-primary hover:file:bg-blue-100"
                            />
                            <p class="text-xs text-gray-500 mt-1">Opcional si aún no cuenta con ella</p>
                        </div>
                    </div>

                    <div id="form-status" class="hidden mt-6 p-4 rounded-xl text-sm max-w-4xl mx-auto"></div>

                    <div class="flex justify-between mt-8 max-w-4xl mx-auto">
                        <button
                            type="button"
                            id="prev-step-3"
                            class="px-8 py-3 bg-gray-200 hover:bg-gray-300 text-gray-700 font-bold rounded-xl transition-all"
                        >
                            Anterior
                        </button>
                        <button
                            type="submit"
                            id="submit-btn"
                            class="px-8 py-3 bg-secondary hover:bg-secondary/90 text-white font-bold rounded-xl transition-all shadow-lg hover:shadow-xl flex items-center gap-2"
                        >
                            <span>Enviar Solicitud</span>
                            <svg
                                class="animate-spin h-5 w-5 text-white hidden"
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                id="loading-spinner"
                            >
                                <circle
                                    class="opacity-25"
                                    cx="12"
                                    cy="12"
                                    r="10"
                                    stroke="currentColor"
                                    stroke-width="4"></circle>
                                <path
                                    class="opacity-75"
                                    fill="currentColor"
                                    d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                                ></path>
                            </svg>
                        </button>
                    </div>
                </div>
            </form>

            <div
                id="post-submit-panel"
                class="hidden bg-white rounded-2xl shadow-xl p-8 md:p-12 border-t-4 border-secondary"
                data-program-title={String(program.data.title)}
                data-bank-info={JSON.stringify(bankInfo)}
            >
                <div class="max-w-3xl mx-auto text-center">
                    <div
                        class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-green-100 text-green-700 mb-6"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-8 w-8"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"></path>
                        </svg>
                    </div>
                    <h2 class="text-2xl font-bold text-primary font-serif mb-2">
                        Solicitud recibida
                    </h2>
                    <p class="text-gray-600 mb-2" id="post-submit-summary">
                        Tu documentación fue enviada. Revisa tu correo para la
                        confirmación.
                    </p>
                    <p
                        class="text-sm text-gray-500 mb-8"
                        id="post-submit-application-id"
                    >
                    </p>

                    <div
                        id="post-submit-payment-section"
                        class="hidden text-left max-w-3xl mx-auto mb-8 w-full"
                    >
                        <h3 class="font-bold text-primary font-serif text-lg mb-4 text-center">
                            Elige cómo pagar (opcional)
                        </h3>
                        <p class="text-sm text-gray-600 mb-4 text-center">
                            Puedes pagar ahora o más tarde. Conserva tu ID de
                            solicitud.
                        </p>

                        <div
                            class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6"
                        >
                            <label
                                id="post-pay-stripe-label"
                                class="flex items-center gap-3 p-4 border-2 border-gray-100 rounded-2xl cursor-pointer hover:bg-gray-50 has-[:checked]:border-primary has-[:checked]:bg-blue-50"
                            >
                                <input
                                    type="radio"
                                    name="postPaymentMethod"
                                    value="stripe"
                                    id="post-pay-stripe"
                                    class="w-5 h-5 text-primary"
                                />
                                <div class="flex flex-col">
                                    <span class="font-bold text-gray-900"
                                        >Pago en línea (Stripe)</span
                                    >
                                    <span class="text-xs text-gray-500"
                                        >Confirmación automática</span
                                    >
                                </div>
                            </label>
                            <label
                                class="flex items-center gap-3 p-4 border-2 border-gray-100 rounded-2xl cursor-pointer hover:bg-gray-50 has-[:checked]:border-primary has-[:checked]:bg-blue-50"
                            >
                                <input
                                    type="radio"
                                    name="postPaymentMethod"
                                    value="wire"
                                    id="post-pay-wire"
                                    class="w-5 h-5 text-primary"
                                />
                                <div class="flex flex-col">
                                    <span class="font-bold text-gray-900"
                                        >Transferencia bancaria</span
                                    >
                                    <span class="text-xs text-gray-500"
                                        >Sube tu comprobante (pago en revisión)</span
                                    >
                                </div>
                            </label>
                        </div>

                        <p
                            id="post-pay-stripe-unavailable"
                            class="hidden text-xs text-amber-800 bg-amber-50 border border-amber-200 rounded-xl p-3 mb-4"
                        >
                            El pago con tarjeta no está disponible para esta
                            modalidad. Usa transferencia o consulta la página del
                            programa.
                        </p>

                        <div
                            id="post-submit-stripe-block"
                            class="hidden p-8 bg-gradient-to-br from-blue-50 to-white border-2 border-primary/20 rounded-2xl mb-6 space-y-6"
                        >
                            <p class="text-sm text-gray-700 leading-relaxed">
                                Serás redirigido a Stripe de forma segura. La
                                factura fiscal (CFDI) la emite CEPRIJA ante el
                                SAT; Stripe no sustituye ese trámite.
                            </p>

                            <div class="p-4 bg-white rounded-xl border border-gray-100">
                                <label
                                    class="block text-sm font-bold text-primary mb-3"
                                    >¿Requiere factura? *</label
                                >
                                <div class="flex flex-wrap gap-6">
                                    <label
                                        class="flex items-center gap-2 cursor-pointer"
                                    >
                                        <input
                                            type="radio"
                                            name="stripeRequiresInvoice"
                                            value="Sí"
                                            class="w-5 h-5 text-primary"
                                        />
                                        <span class="font-medium">Sí</span>
                                    </label>
                                    <label
                                        class="flex items-center gap-2 cursor-pointer"
                                    >
                                        <input
                                            type="radio"
                                            name="stripeRequiresInvoice"
                                            value="No"
                                            checked
                                            class="w-5 h-5 text-primary"
                                        />
                                        <span class="font-medium">No</span>
                                    </label>
                                </div>
                            </div>

                            <div
                                id="post-stripe-invoice-fields"
                                class="hidden space-y-4 p-4 bg-white rounded-xl border border-gray-200"
                            >
                                <p class="text-xs text-gray-600">
                                    Sube tu <strong>CSF</strong> (constancia de
                                    situación fiscal) para agilizar la
                                    facturación tras el pago.
                                </p>
                                <div
                                    class="grid grid-cols-1 md:grid-cols-2 gap-6"
                                >
                                    <div>
                                        <label
                                            class="block text-sm font-semibold text-gray-700 mb-2"
                                            >Constancia de situación fiscal (CSF)
                                            *</label
                                        >
                                        <input
                                            type="file"
                                            id="post-stripe-fiscal"
                                            accept=".pdf,image/*"
                                            class="w-full text-sm"
                                        />
                                    </div>
                                    <div>
                                        <label
                                            class="block text-sm font-semibold text-gray-700 mb-2"
                                            >Correo para recibir factura *</label
                                        >
                                        <input
                                            type="email"
                                            id="post-stripe-invoice-email"
                                            class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                            placeholder="facturacion@empresa.com"
                                        />
                                    </div>
                                </div>
                            </div>

                            <button
                                type="button"
                                id="stripe-after-enrollment-btn"
                                class="w-full bg-primary text-white font-bold py-4 px-6 rounded-xl hover:bg-blue-900 transition-all shadow-lg hover:shadow-xl flex items-center justify-center gap-2"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-5 w-5"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"
                                    ></path>
                                </svg>
                                Continuar al pago seguro (Stripe)
                            </button>
                            <p class="text-xs text-gray-500 text-center">
                                Pago procesado por Stripe
                            </p>
                        </div>

                        <form
                            id="post-submit-wire-form"
                            class="hidden space-y-6"
                        >
                            <input type="hidden" name="name" id="post-wire-name" />
                            <input type="hidden" name="email" id="post-wire-email" />
                            <input type="hidden" name="phone" id="post-wire-phone" />
                            <input
                                type="hidden"
                                name="programTitle"
                                id="post-wire-program-title"
                            />
                            <input
                                type="hidden"
                                name="programId"
                                id="post-wire-program-id"
                            />
                            <input
                                type="hidden"
                                name="modality"
                                id="post-wire-modality"
                            />
                            <input
                                type="hidden"
                                name="applicationId"
                                id="post-wire-application-id"
                            />
                            <input
                                type="hidden"
                                name="wireReference"
                                id="post-wire-reference"
                            />

                            <div
                                class="p-6 bg-gradient-to-br from-white to-gray-50 border border-gray-200 rounded-2xl shadow-sm"
                            >
                                <div class="flex items-center gap-3 mb-4 text-primary">
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-6 w-6"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"
                                        ></path>
                                    </svg>
                                    <h4
                                        class="font-bold text-sm uppercase tracking-wider"
                                    >
                                        Transferencia
                                    </h4>
                                </div>
                                <div class="space-y-2 text-xs text-gray-600">
                                    <div
                                        class="flex items-center justify-between gap-3"
                                    >
                                        <p class="truncate">
                                            <strong>Banco:</strong> {
                                                bankInfo.bankName
                                            }
                                        </p>
                                        <button
                                            type="button"
                                            class="text-primary font-bold hover:underline shrink-0"
                                            data-copy={bankInfo.bankName}
                                            >Copiar</button
                                        >
                                    </div>
                                    <div
                                        class="flex items-center justify-between gap-3"
                                    >
                                        <p class="truncate">
                                            <strong>Titular:</strong> {
                                                bankInfo.accountHolder
                                            }
                                        </p>
                                        <button
                                            type="button"
                                            class="text-primary font-bold hover:underline shrink-0"
                                            data-copy={bankInfo.accountHolder}
                                            >Copiar</button
                                        >
                                    </div>
                                    <div
                                        class="flex items-center justify-between gap-3"
                                    >
                                        <p class="truncate">
                                            <strong>No. Cuenta:</strong> {
                                                bankInfo.accountNumber
                                            }
                                        </p>
                                        <button
                                            type="button"
                                            class="text-primary font-bold hover:underline shrink-0"
                                            data-copy={bankInfo.accountNumber}
                                            >Copiar</button
                                        >
                                    </div>
                                    <div
                                        class="flex items-center justify-between gap-3"
                                    >
                                        <p class="truncate">
                                            <strong>CLABE:</strong> {bankInfo.clabe}
                                        </p>
                                        <button
                                            type="button"
                                            class="text-primary font-bold hover:underline shrink-0"
                                            data-copy={bankInfo.clabe}
                                            >Copiar</button
                                        >
                                    </div>
                                    {
                                        bankInfo.swiftCode && (
                                            <div class="flex items-center justify-between gap-3">
                                                <p class="truncate">
                                                    <strong>SWIFT:</strong>{" "}
                                                    {bankInfo.swiftCode}
                                                </p>
                                                <button
                                                    type="button"
                                                    class="text-primary font-bold hover:underline shrink-0"
                                                    data-copy={bankInfo.swiftCode}
                                                >
                                                    Copiar
                                                </button>
                                            </div>
                                        )
                                    }
                                    <p class="pt-3 mt-3 border-t border-gray-200 text-xs text-gray-600">
                                        <strong>Referencia:</strong>
                                        <span
                                            id="post-wire-reference-preview"
                                            class="font-mono text-gray-900"
                                        ></span>
                                    </p>
                                </div>
                            </div>

                            <div class="p-6 bg-white rounded-2xl border border-gray-200">
                                <h4 class="font-bold text-gray-900 mb-2">
                                    Comprobante de pago
                                </h4>
                                <p class="text-xs text-gray-600 mb-4">
                                    Sube tu comprobante de transferencia. Tu pago
                                    quedará en revisión.
                                </p>
                                <label
                                    class="block text-sm font-semibold text-gray-700 mb-2"
                                    >Comprobante de transferencia *</label
                                >
                                <input
                                    type="file"
                                    name="paymentProof"
                                    id="post-wire-payment-proof"
                                    required
                                    accept=".pdf,image/*"
                                    class="w-full text-sm"
                                />
                            </div>

                            <div class="p-4 bg-white rounded-xl border border-gray-100">
                                <label
                                    class="block text-sm font-bold text-primary mb-3"
                                    >¿Requiere factura? *</label
                                >
                                <div class="flex flex-wrap gap-6">
                                    <label
                                        class="flex items-center gap-2 cursor-pointer"
                                    >
                                        <input
                                            type="radio"
                                            name="requiresInvoice"
                                            value="Sí"
                                            class="w-5 h-5 text-primary"
                                        />
                                        <span class="font-medium">Sí</span>
                                    </label>
                                    <label
                                        class="flex items-center gap-2 cursor-pointer"
                                    >
                                        <input
                                            type="radio"
                                            name="requiresInvoice"
                                            value="No"
                                            checked
                                            class="w-5 h-5 text-primary"
                                        />
                                        <span class="font-medium">No</span>
                                    </label>
                                </div>
                            </div>

                            <div
                                id="post-wire-invoice-fields"
                                class="hidden space-y-4 p-4 bg-white rounded-xl border border-gray-200"
                            >
                                <p class="text-xs text-gray-600">
                                    Adjunta tu <strong>CSF</strong> y el correo
                                    para facturación (mismo criterio que pago con
                                    tarjeta).
                                </p>
                                <div
                                    class="grid grid-cols-1 md:grid-cols-2 gap-6"
                                >
                                    <div>
                                        <label
                                            class="block text-sm font-semibold text-gray-700 mb-2"
                                            >Constancia de situación fiscal (CSF)
                                            *</label
                                        >
                                        <input
                                            type="file"
                                            name="fiscalConstancy"
                                            id="post-wire-fiscal"
                                            accept=".pdf,image/*"
                                            class="w-full text-sm"
                                        />
                                        <p class="text-xs text-gray-500 mt-1">
                                            PDF o imagen clara del documento.
                                        </p>
                                    </div>
                                    <div>
                                        <label
                                            class="block text-sm font-semibold text-gray-700 mb-2"
                                            >Correo para recibir factura *</label
                                        >
                                        <input
                                            type="email"
                                            name="invoiceEmail"
                                            id="post-wire-invoice-email"
                                            class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                            placeholder="facturacion@empresa.com"
                                        />
                                    </div>
                                </div>
                            </div>

                            <button
                                type="submit"
                                id="post-wire-submit-btn"
                                class="w-full bg-primary text-white font-bold py-4 px-6 rounded-xl hover:bg-blue-900 transition-all shadow-lg"
                            >
                                Enviar comprobante
                            </button>
                        </form>

                        <div
                            id="post-wire-success"
                            class="hidden text-center text-green-800 bg-green-50 border border-green-200 rounded-xl p-6"
                        >
                            <p class="font-bold mb-1">Comprobante recibido</p>
                            <p class="text-sm">
                                Tu pago quedará en revisión. Te enviamos un
                                correo de confirmación.
                            </p>
                        </div>
                    </div>

                    <a
                        href={`/oferta-academica/${programSlug}`}
                        class="inline-block text-primary font-semibold hover:underline"
                    >
                        ← Volver al programa
                    </a>
                </div>
            </div>
        </section>
    </main>
</Layout>

<script>
    import {
        validateRequiredFieldsInContainer,
        reportStepValidationFailure,
    } from "@lib/client/multiStepFormValidation";

    const form = document.getElementById("enrollment-form") as HTMLFormElement;
    const steps = [1, 2, 3];
    let currentStep = 1;

    const stepperCard = document.getElementById("enrollment-stepper-card");
    const postSubmitPanel = document.getElementById("post-submit-panel");
    const postSubmitApplicationId = document.getElementById(
        "post-submit-application-id",
    );
    const postSubmitPaymentSection = document.getElementById(
        "post-submit-payment-section",
    );
    const postSubmitStripeBlock = document.getElementById("post-submit-stripe-block");
    const postSubmitWireForm = document.getElementById(
        "post-submit-wire-form",
    ) as HTMLFormElement | null;
    const postWireSuccess = document.getElementById("post-wire-success");

    const stepLabel = document.getElementById("step-label");
    const stepNumber = document.getElementById("step-number");
    const progressBar = document.getElementById("progress-bar");
    const statusDiv = document.getElementById("form-status");
    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null;
    const spinner = document.getElementById("loading-spinner");

    const stepTitles = [
        "Paso 1 de 3: Información Personal",
        "Paso 2 de 3: Formación Académica",
        "Paso 3 de 3: Documentos",
    ];

    type PostPayload = {
        applicationId: string;
        email: string;
        participantName: string;
        participantPhone: string;
        modality: string;
        programSlug: string;
    };

    let lastPostPayload: PostPayload | null = null;
    let lastCheckoutPriceId: string | null = null;

    type StripePriceIds = { presencial?: string; online?: string };

    function parseStripePriceIdsFromForm(): StripePriceIds {
        try {
            const raw = form?.dataset.stripePriceIds ?? "null";
            const parsed = JSON.parse(raw);
            if (parsed && typeof parsed === "object" && !Array.isArray(parsed)) {
                return parsed as StripePriceIds;
            }
        } catch {
            /* invalid JSON */
        }
        return {};
    }

    function priceIdIsValid(priceId: string): boolean {
        return (
            typeof priceId === "string" &&
            /^price_[a-zA-Z0-9]+$/.test(priceId) &&
            !/PLACEHOLDER|REPLACE/i.test(priceId)
        );
    }

    function generateWireReferencePost(): string {
        let bank: { referencePrefix?: string } = {};
        try {
            bank = JSON.parse(postSubmitPanel?.dataset.bankInfo || "{}");
        } catch {
            /* ignore */
        }
        const prefix = bank.referencePrefix || "CEPRIJA";
        const program = String(lastPostPayload?.programSlug || "programa")
            .toLowerCase()
            .replace(/[^a-z0-9]+/g, "-")
            .replace(/^-|-$/g, "");
        const stamp = new Date();
        const y = String(stamp.getFullYear());
        const m = String(stamp.getMonth() + 1).padStart(2, "0");
        const d = String(stamp.getDate()).padStart(2, "0");
        const t = Math.floor(stamp.getTime() / 1000) % 46656;
        const suffix = t.toString(36).toUpperCase().padStart(3, "0");
        return `${prefix}-${program}-${y}${m}${d}${suffix}`;
    }

    function applyInvoiceWireFields() {
        const wireForm = postSubmitWireForm;
        if (!wireForm) return;
        const yes = !!wireForm.querySelector(
            'input[name="requiresInvoice"][value="Sí"]:checked',
        );
        const inv = document.getElementById("post-wire-invoice-fields");
        const fiscal = document.getElementById("post-wire-fiscal") as HTMLInputElement | null;
        const invEmail = document.getElementById("post-wire-invoice-email") as HTMLInputElement | null;
        inv?.classList.toggle("hidden", !yes);
        if (fiscal) fiscal.required = yes;
        if (invEmail) invEmail.required = yes;
    }

    function applyPostPaymentMethodUI() {
        const method =
            (
                document.querySelector(
                    'input[name="postPaymentMethod"]:checked',
                ) as HTMLInputElement | null
            )?.value || "wire";
        const priceOk = !!lastCheckoutPriceId;

        postSubmitStripeBlock?.classList.toggle(
            "hidden",
            method !== "stripe" || !priceOk,
        );
        postSubmitWireForm?.classList.toggle("hidden", method !== "wire");

        const proofInput = document.getElementById(
            "post-wire-payment-proof",
        ) as HTMLInputElement | null;
        if (method === "wire") {
            const ref = generateWireReferencePost();
            const refH = document.getElementById("post-wire-reference") as HTMLInputElement | null;
            const prev = document.getElementById("post-wire-reference-preview");
            if (refH) refH.value = ref;
            if (prev) prev.textContent = ref;
            if (proofInput) proofInput.required = true;
        } else if (proofInput) {
            proofInput.required = false;
        }
    }

    function updateUI() {
        steps.forEach((s) => {
            const section = document.getElementById(`step-${s}`);
            if (section) {
                section.classList.toggle("hidden", s !== currentStep);
            }
        });

        if (stepLabel) stepLabel.textContent = stepTitles[currentStep - 1];
        if (stepNumber) stepNumber.textContent = `${Math.round((currentStep / 3) * 100)}% completado`;
        if (progressBar) progressBar.style.width = `${(currentStep / 3) * 100}%`;
    }

    document.getElementById("next-step-1")?.addEventListener("click", () => {
        const section = document.getElementById("step-1");
        if (!section) return;
        const result = validateRequiredFieldsInContainer(section);
        if (!result.ok) {
            reportStepValidationFailure(stepTitles[0], result);
            return;
        }
        currentStep = 2;
        updateUI();
        window.scrollTo({ top: 0, behavior: "smooth" });
    });

    document.getElementById("prev-step-2")?.addEventListener("click", () => {
        currentStep = 1;
        updateUI();
        window.scrollTo({ top: 0, behavior: "smooth" });
    });

    document.getElementById("next-step-2")?.addEventListener("click", () => {
        const section = document.getElementById("step-2");
        if (!section) return;
        const result = validateRequiredFieldsInContainer(section);
        if (!result.ok) {
            reportStepValidationFailure(stepTitles[1], result);
            return;
        }
        currentStep = 3;
        updateUI();
        window.scrollTo({ top: 0, behavior: "smooth" });
    });

    document.getElementById("prev-step-3")?.addEventListener("click", () => {
        currentStep = 2;
        updateUI();
        window.scrollTo({ top: 0, behavior: "smooth" });
    });

    function applyPostStripeInvoiceFields() {
        const yes = !!document.querySelector(
            'input[name="stripeRequiresInvoice"][value="Sí"]:checked',
        );
        document
            .getElementById("post-stripe-invoice-fields")
            ?.classList.toggle("hidden", !yes);
    }

    postSubmitPaymentSection?.addEventListener("change", (e) => {
        const t = e.target as HTMLInputElement;
        if (t.name === "postPaymentMethod") applyPostPaymentMethodUI();
        if (t.name === "requiresInvoice") applyInvoiceWireFields();
        if (t.name === "stripeRequiresInvoice") applyPostStripeInvoiceFields();
    });

    postSubmitPaymentSection?.addEventListener("click", async (e) => {
        const btn = (e.target as HTMLElement).closest("[data-copy]");
        if (!btn) return;
        const value = btn.getAttribute("data-copy") || "";
        try {
            await navigator.clipboard.writeText(value);
        } catch {
            const ta = document.createElement("textarea");
            ta.value = value;
            document.body.appendChild(ta);
            ta.select();
            document.execCommand("copy");
            ta.remove();
        }
    });

    postSubmitWireForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (postSubmitWireForm) {
            const wireCheck = validateRequiredFieldsInContainer(postSubmitWireForm);
            if (!wireCheck.ok) {
                reportStepValidationFailure("Comprobante de transferencia", wireCheck);
                return;
            }
        }
        const btn = document.getElementById("post-wire-submit-btn") as HTMLButtonElement | null;
        if (btn) btn.disabled = true;
        try {
            const fd = new FormData(postSubmitWireForm);
            const res = await fetch("/api/payments/wire-proof", {
                method: "POST",
                body: fd,
            });
            const data = await res.json().catch(() => ({}));
            if (!res.ok) {
                throw new Error(
                    typeof data.error === "string" ? data.error : "Error al enviar el comprobante",
                );
            }
            postSubmitWireForm.classList.add("hidden");
            postWireSuccess?.classList.remove("hidden");
            window.scrollTo({ top: postWireSuccess?.offsetTop ?? 0, behavior: "smooth" });
        } catch (err) {
            console.error(err);
            alert(
                err instanceof Error
                    ? err.message
                    : "No se pudo enviar el comprobante. Intenta de nuevo.",
            );
        } finally {
            if (btn) btn.disabled = false;
        }
    });

    function showPostSubmitPaymentOptions(payload: PostPayload) {
        lastPostPayload = payload;

        const stripeIds = parseStripePriceIdsFromForm();
        const priceId =
            payload.modality === "Presencial"
                ? stripeIds.presencial
                : stripeIds.online;
        const priceOk = typeof priceId === "string" && priceIdIsValid(priceId);
        lastCheckoutPriceId = priceOk ? priceId : null;

        if (postSubmitApplicationId) {
            postSubmitApplicationId.textContent = payload.applicationId
                ? `ID de solicitud: ${payload.applicationId}`
                : "";
        }

        const titleEl = document.getElementById("post-wire-program-title") as HTMLInputElement | null;
        const nameEl = document.getElementById("post-wire-name") as HTMLInputElement | null;
        const emailEl = document.getElementById("post-wire-email") as HTMLInputElement | null;
        const phoneEl = document.getElementById("post-wire-phone") as HTMLInputElement | null;
        const pidEl = document.getElementById("post-wire-program-id") as HTMLInputElement | null;
        const modEl = document.getElementById("post-wire-modality") as HTMLInputElement | null;
        const appEl = document.getElementById("post-wire-application-id") as HTMLInputElement | null;

        if (titleEl) titleEl.value = postSubmitPanel?.dataset.programTitle ?? "";
        if (nameEl) nameEl.value = payload.participantName;
        if (emailEl) emailEl.value = payload.email;
        if (phoneEl) phoneEl.value = payload.participantPhone;
        if (pidEl) pidEl.value = payload.programSlug;
        if (modEl) modEl.value = payload.modality;
        if (appEl) appEl.value = payload.applicationId;

        postWireSuccess?.classList.add("hidden");

        const payProof = document.getElementById(
            "post-wire-payment-proof",
        ) as HTMLInputElement | null;
        const fiscalClear = document.getElementById("post-wire-fiscal") as HTMLInputElement | null;
        const invMailClear = document.getElementById(
            "post-wire-invoice-email",
        ) as HTMLInputElement | null;
        if (payProof) payProof.value = "";
        if (fiscalClear) fiscalClear.value = "";
        if (invMailClear) invMailClear.value = "";

        const stripeRadio = document.getElementById("post-pay-stripe") as HTMLInputElement | null;
        const wireRadio = document.getElementById("post-pay-wire") as HTMLInputElement | null;
        const stripeUnavailable = document.getElementById("post-pay-stripe-unavailable");
        const stripeLabel = document.getElementById("post-pay-stripe-label");

        if (priceOk) {
            stripeUnavailable?.classList.add("hidden");
            if (stripeRadio) stripeRadio.disabled = false;
            stripeLabel?.classList.remove("opacity-50", "cursor-not-allowed", "pointer-events-none");
            if (stripeRadio) stripeRadio.checked = true;
        } else {
            stripeUnavailable?.classList.remove("hidden");
            if (stripeRadio) stripeRadio.disabled = true;
            stripeLabel?.classList.add("opacity-50", "cursor-not-allowed", "pointer-events-none");
            if (wireRadio) wireRadio.checked = true;
        }

        const invYesEl = postSubmitWireForm?.querySelector(
            'input[name="requiresInvoice"][value="Sí"]',
        ) as HTMLInputElement | null;
        const invNoEl = postSubmitWireForm?.querySelector(
            'input[name="requiresInvoice"][value="No"]',
        ) as HTMLInputElement | null;
        if (invYesEl) invYesEl.checked = false;
        if (invNoEl) invNoEl.checked = true;
        applyInvoiceWireFields();

        const stInvYes = document.querySelector(
            'input[name="stripeRequiresInvoice"][value="Sí"]',
        ) as HTMLInputElement | null;
        const stInvNo = document.querySelector(
            'input[name="stripeRequiresInvoice"][value="No"]',
        ) as HTMLInputElement | null;
        if (stInvYes) stInvYes.checked = false;
        if (stInvNo) stInvNo.checked = true;
        const stMail = document.getElementById(
            "post-stripe-invoice-email",
        ) as HTMLInputElement | null;
        const stFis = document.getElementById("post-stripe-fiscal") as HTMLInputElement | null;
        if (stMail) stMail.value = "";
        if (stFis) stFis.value = "";
        applyPostStripeInvoiceFields();

        postSubmitPaymentSection?.classList.remove("hidden");

        const stripeBtn = document.getElementById(
            "stripe-after-enrollment-btn",
        ) as HTMLButtonElement | null;
        if (stripeBtn && priceOk) {
            const fresh = stripeBtn.cloneNode(true) as HTMLButtonElement;
            stripeBtn.replaceWith(fresh);
            fresh.addEventListener("click", async () => {
                if (!lastCheckoutPriceId || !lastPostPayload) return;

                const needsInv = !!document.querySelector(
                    'input[name="stripeRequiresInvoice"][value="Sí"]:checked',
                );
                const invEmailEl = document.getElementById(
                    "post-stripe-invoice-email",
                ) as HTMLInputElement | null;
                const fiscalEl = document.getElementById(
                    "post-stripe-fiscal",
                ) as HTMLInputElement | null;
                const invEmail = (invEmailEl?.value ?? "").trim();

                if (needsInv) {
                    if (!invEmail) {
                        alert("Indica el correo para recibir la factura.");
                        return;
                    }
                    const f = fiscalEl?.files?.[0];
                    if (!f) {
                        alert("Adjunta la constancia de situación fiscal (CSF).");
                        return;
                    }
                    fresh.disabled = true;
                    fresh.textContent = "Enviando datos fiscales…";
                    try {
                        const fd = new FormData();
                        fd.append("invoiceEmail", invEmail);
                        fd.append("programSlug", lastPostPayload.programSlug);
                        fd.append(
                            "programTitle",
                            postSubmitPanel?.dataset.programTitle ?? "",
                        );
                        fd.append("participantName", lastPostPayload.participantName);
                        fd.append("participantPhone", lastPostPayload.participantPhone);
                        fd.append("modality", lastPostPayload.modality);
                        fd.append("customerEmail", lastPostPayload.email);
                        if (lastPostPayload.applicationId) {
                            fd.append("applicationId", lastPostPayload.applicationId);
                        }
                        fd.append("fiscalConstancy", f);
                        const pre = await fetch("/api/stripe/fiscal-preflight", {
                            method: "POST",
                            body: fd,
                        });
                        const preJson = await pre.json().catch(() => ({}));
                        if (!pre.ok) {
                            throw new Error(
                                typeof preJson.error === "string"
                                    ? preJson.error
                                    : "No se pudo enviar la CSF",
                            );
                        }
                    } catch (err) {
                        console.error(err);
                        alert(
                            err instanceof Error
                                ? err.message
                                : "Error al enviar datos fiscales.",
                        );
                        fresh.disabled = false;
                        fresh.textContent = "Continuar al pago seguro (Stripe)";
                        return;
                    }
                }

                fresh.disabled = true;
                fresh.textContent = "Redirigiendo a Stripe…";
                try {
                    const res = await fetch("/api/stripe/create-checkout-session", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({
                            priceId: lastCheckoutPriceId,
                            customerEmail: lastPostPayload.email,
                            programSlug: lastPostPayload.programSlug,
                            participantName: lastPostPayload.participantName,
                            participantPhone: lastPostPayload.participantPhone,
                            modality: lastPostPayload.modality,
                            requiresInvoice: needsInv ? "Sí" : "No",
                            invoiceEmail: needsInv ? invEmail : "",
                            ...(lastPostPayload.applicationId
                                ? { applicationId: lastPostPayload.applicationId }
                                : {}),
                        }),
                    });
                    const data = await res.json();
                    if (data.url) {
                        window.location.href = data.url;
                    } else {
                        throw new Error(data.error || "No se pudo iniciar el pago");
                    }
                } catch (err) {
                    console.error(err);
                    alert(
                        err instanceof Error
                            ? err.message
                            : "Error al iniciar el pago. Intenta de nuevo o contacta soporte.",
                    );
                    fresh.disabled = false;
                    fresh.textContent = "Continuar al pago seguro (Stripe)";
                }
            });
        }

        applyPostPaymentMethodUI();

        stepperCard?.classList.add("hidden");
        form?.classList.add("hidden");
        postSubmitPanel?.classList.remove("hidden");
        window.scrollTo({ top: 0, behavior: "smooth" });
    }

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();

        for (let s = 1; s <= 3; s++) {
            const section = document.getElementById(`step-${s}`);
            if (!section) continue;
            const result = validateRequiredFieldsInContainer(section);
            if (!result.ok) {
                currentStep = s;
                updateUI();
                reportStepValidationFailure(stepTitles[s - 1], result);
                window.scrollTo({ top: 0, behavior: "smooth" });
                return;
            }
        }

        if (statusDiv) {
            statusDiv.classList.add("hidden");
            statusDiv.className = "hidden mt-6 p-4 rounded-xl text-sm max-w-4xl mx-auto";
        }

        if (submitBtn && spinner) {
            submitBtn.disabled = true;
            spinner.classList.remove("hidden");
        }

        const formData = new FormData(form);
        const email = String(formData.get("email") ?? "").trim();
        const nombre = String(formData.get("nombre") ?? "").trim();
        const apellidos = String(formData.get("apellidos") ?? "").trim();
        const telefono = String(formData.get("telefono") ?? "").trim();
        const modalityEl = form.querySelector(
            'input[name="modality"]:checked',
        ) as HTMLInputElement | null;
        const modality = String(modalityEl?.value ?? "").trim();
        const programSlug = String(form.dataset.programSlug ?? "").trim();
        const participantName = `${nombre} ${apellidos}`.trim();

        try {
            const response = await fetch("/api/enrollment", {
                method: "POST",
                body: formData,
            });

            const result = await response.json();

            if (response.ok) {
                const applicationId =
                    typeof result.applicationId === "string" ? result.applicationId : "";
                form.reset();
                currentStep = 1;
                updateUI();
                showPostSubmitPaymentOptions({
                    applicationId,
                    email,
                    participantName,
                    participantPhone: telefono,
                    modality,
                    programSlug,
                });
            } else {
                throw new Error(result.message || result.error || "Error al enviar la solicitud");
            }
        } catch (error) {
            if (statusDiv) {
                statusDiv.textContent =
                    "Hubo un error al enviar tu solicitud. Por favor verifica los archivos e intenta nuevamente, o contáctanos directamente.";
                statusDiv.classList.remove("hidden");
                statusDiv.classList.add("bg-red-100", "text-red-800", "border", "border-red-200");
            }
            console.error("Error submitting enrollment:", error);
        } finally {
            if (submitBtn && spinner) {
                submitBtn.disabled = false;
                spinner.classList.add("hidden");
            }
        }
    });
</script>
