<script>
    import {
        validateStepSection,
        reportStepValidationFailure,
        formatStepValidationMessage,
    } from "@lib/client/multiStepFormValidation";
    import { wireReferenceFromSessionId } from "@lib/wireReference";

    const form = document.getElementById("enrollment-form") as HTMLFormElement;

    /**
     * Step orchestration is data-driven so we can prepend an optional Variant
     * Selection step (only present when the program defines `variantOptions`)
     * without sprinkling conditionals across the navigation handlers.
     * Each entry's `id` matches its `<section id="step-...">`.
     */
    type StepEntry = { id: string; baseTitle: string };
    const hasVariantStep = form?.dataset.hasVariantStep === "1";
    const requiresDegreeSteps = form?.dataset.requiresDegreeSteps === "1";
    const requiresExtendedProfile = form?.dataset.requiresExtendedProfile === "1";
    const stepEntries: StepEntry[] = [
        ...(hasVariantStep
            ? [{ id: "step-variant", baseTitle: "Opciones del programa" }]
            : []),
        { id: "step-1", baseTitle: "Información Personal" },
        ...(requiresExtendedProfile
            ? [
                  {
                      id: "step-profile-personal",
                      baseTitle: "Datos personales adicionales",
                  },
                  {
                      id: "step-profile-address",
                      baseTitle: "Dirección particular",
                  },
                  {
                      id: "step-profile-emergency",
                      baseTitle: "Contacto de emergencia",
                  },
                  {
                      id: "step-profile-health",
                      baseTitle: "Información de salud",
                  },
              ]
            : []),
        ...(requiresDegreeSteps
            ? [{ id: "step-2", baseTitle: "Formación Académica" }]
            : []),
        { id: "step-3", baseTitle: "Documentos" },
    ];
    const totalSteps = stepEntries.length;
    let currentStep = 1;

    const stepperCard = document.getElementById("enrollment-stepper-card");
    const postSubmitPanel = document.getElementById("post-submit-panel");
    const postSubmitApplicationId = document.getElementById(
        "post-submit-application-id",
    );
    const postSubmitPaymentSection = document.getElementById(
        "post-submit-payment-section",
    );
    const postSubmitStripeBlock = document.getElementById("post-submit-stripe-block");
    const postSubmitWireForm = document.getElementById(
        "post-submit-wire-form",
    ) as HTMLFormElement | null;
    const postWireSuccess = document.getElementById("post-wire-success");

    const stepLabel = document.getElementById("step-label");
    const stepNumber = document.getElementById("step-number");
    const progressBar = document.getElementById("progress-bar");
    const statusDiv = document.getElementById("form-status");
    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null;
    const spinner = document.getElementById("loading-spinner");

    function stepTitle(index: number): string {
        const entry = stepEntries[index - 1];
        return entry
            ? `Paso ${index} de ${totalSteps}: ${entry.baseTitle}`
            : `Paso ${index} de ${totalSteps}`;
    }

    // ---------------------------------------------------------------
    // Dynamic multi-degree management
    //
    // Each degree in Step 2 has a matching documents block in Step 3
    // identified by the same index. The indices are *stable*: when a
    // user removes a degree in the middle of the list, the remaining
    // ones keep their original indices so we never have to rewrite
    // field names or lose already-uploaded files. This means the
    // index is not the same as the visual position; a small helper
    // recomputes the position (`#1`, `#2`, ...) on every render.
    // ---------------------------------------------------------------
    type DegreeGrado = "Licenciatura" | "Especialidad" | "Maestría" | "Doctorado";
    type InitialDegree = { grado: DegreeGrado; locked?: boolean };

    const programNivelDataset = (form?.dataset.programNivel ?? "").trim();
    const DEGREE_ORDER: Record<DegreeGrado, number> = {
        Licenciatura: 1,
        Especialidad: 2,
        Maestría: 2,
        Doctorado: 3,
    };

    function parseInitialDegrees(): InitialDegree[] {
        try {
            const raw = form?.dataset.initialDegrees ?? "[]";
            const parsed = JSON.parse(raw);
            if (Array.isArray(parsed)) {
                return parsed.filter(
                    (d): d is InitialDegree =>
                        !!d &&
                        typeof d === "object" &&
                        typeof d.grado === "string" &&
                        d.grado in DEGREE_ORDER,
                );
            }
        } catch {
            /* malformed JSON falls back to empty list */
        }
        return [];
    }

    /**
     * Tracks insertion order so field names stay stable across adds/removes.
     * Only used to allocate fresh indices; the DOM is the source of truth
     * for the current list of entries.
     */
    let nextDegreeIndex = 0;

    const degreesContainer = document.getElementById("degrees-container");
    const degreeTemplate = document.getElementById(
        "degree-entry-template",
    ) as HTMLTemplateElement | null;
    const degreeDocumentsContainer = document.getElementById(
        "degree-documents-container",
    );
    const degreeDocumentsTemplate = document.getElementById(
        "degree-documents-template",
    ) as HTMLTemplateElement | null;
    const addDegreeBtn = document.getElementById("add-degree-btn");
    const degreeRequirementsList = document.getElementById(
        "degree-requirements-list",
    );

    type DegreeSnapshot = {
        index: number;
        grado: string;
        carrera: string;
        institucion: string;
        cedulaNum: string;
        locked: boolean;
    };

    function getDegreesFromDom(): DegreeSnapshot[] {
        if (!degreesContainer) return [];
        const entries = Array.from(
            degreesContainer.querySelectorAll<HTMLElement>(".degree-entry"),
        );
        return entries.map((entry) => {
            const index = Number(entry.dataset.degreeIndex ?? "0");
            const grado = (
                entry.querySelector<HTMLSelectElement>(".degree-grado")?.value ?? ""
            ).trim();
            const carrera = (
                entry.querySelector<HTMLInputElement>(".degree-carrera")?.value ?? ""
            ).trim();
            const institucion = (
                entry.querySelector<HTMLInputElement>(".degree-institucion")?.value ?? ""
            ).trim();
            const cedulaNum = (
                entry.querySelector<HTMLInputElement>(".degree-cedula-num")?.value ?? ""
            ).trim();
            const locked = entry.dataset.locked === "1";
            return { index, grado, carrera, institucion, cedulaNum, locked };
        });
    }

    function renderRequirementsList() {
        if (!degreeRequirementsList) return;
        const messages: string[] = [];
        if (programNivelDataset === "doctorado") {
            messages.push("Al menos 1 Licenciatura");
            messages.push("Al menos 1 Maestría");
        } else if (
            programNivelDataset === "maestria" ||
            programNivelDataset === "especialidad"
        ) {
            messages.push("Al menos 1 Licenciatura");
        }
        if (messages.length === 0) {
            const info = document.getElementById("degree-requirements-info");
            info?.classList.add("hidden");
            return;
        }
        degreeRequirementsList.innerHTML = messages
            .map((m) => `<li>${m}</li>`)
            .join("");
    }

    /**
     * Renumbers visible positions and toggles the "eliminar" buttons so
     * locked entries (the program's minimum) can't be removed. Safe to
     * call after any add/remove.
     */
    function updateDegreePositions() {
        if (!degreesContainer) return;
        const entries = Array.from(
            degreesContainer.querySelectorAll<HTMLElement>(".degree-entry"),
        );
        entries.forEach((entry, i) => {
            const numEl = entry.querySelector<HTMLElement>(".degree-entry-number");
            if (numEl) numEl.textContent = `#${i + 1}`;
            const removeBtn = entry.querySelector<HTMLButtonElement>(
                ".remove-degree-btn",
            );
            if (removeBtn) {
                const locked = entry.dataset.locked === "1";
                removeBtn.disabled = locked;
                removeBtn.title = locked
                    ? "Este grado es requerido por el programa"
                    : "";
            }
        });
    }

    function updateDocumentsPositions() {
        if (!degreeDocumentsContainer) return;
        const docs = Array.from(
            degreeDocumentsContainer.querySelectorAll<HTMLElement>(
                ".degree-documents",
            ),
        );
        docs.forEach((doc, i) => {
            const title = doc.querySelector<HTMLElement>(
                ".degree-documents-title",
            );
            const entry = degreesContainer?.querySelector<HTMLElement>(
                `.degree-entry[data-degree-index="${doc.dataset.degreeIndex}"]`,
            );
            const grado = entry
                ?.querySelector<HTMLSelectElement>(".degree-grado")
                ?.value?.trim();
            const carrera = entry
                ?.querySelector<HTMLInputElement>(".degree-carrera")
                ?.value?.trim();
            if (title) {
                const parts = [`Documentos del grado #${i + 1}`];
                if (grado) parts.push(grado);
                if (carrera) parts.push(carrera);
                title.textContent = parts.join(" · ");
            }
        });
    }

    function instantiateTemplate(
        tpl: HTMLTemplateElement,
        index: number,
        position: number,
    ): HTMLElement | null {
        // Templates use `{{INDEX}}`/`{{POSITION}}` placeholders (preserved in
        // attribute values by the HTML parser) so we can render both slots
        // without running a full templating library client-side.
        const html = tpl.innerHTML
            .replace(/\{\{INDEX\}\}/g, String(index))
            .replace(/\{\{POSITION\}\}/g, String(position));
        const wrap = document.createElement("div");
        wrap.innerHTML = html.trim();
        return wrap.firstElementChild as HTMLElement | null;
    }

    function addDegreeEntry(opts: { grado?: string; locked?: boolean } = {}) {
        if (!degreesContainer || !degreeTemplate) return;
        const index = nextDegreeIndex++;
        const position =
            degreesContainer.querySelectorAll(".degree-entry").length + 1;
        const node = instantiateTemplate(degreeTemplate, index, position);
        if (!node) return;
        if (opts.locked) node.dataset.locked = "1";
        if (opts.grado) {
            const select = node.querySelector<HTMLSelectElement>(".degree-grado");
            if (select) select.value = opts.grado;
        }
        degreesContainer.appendChild(node);

        if (degreeDocumentsContainer && degreeDocumentsTemplate) {
            const docNode = instantiateTemplate(
                degreeDocumentsTemplate,
                index,
                position,
            );
            if (docNode) degreeDocumentsContainer.appendChild(docNode);
        }

        updateDegreePositions();
        updateDocumentsPositions();
    }

    function removeDegreeEntry(index: number) {
        if (!degreesContainer) return;
        const entry = degreesContainer.querySelector<HTMLElement>(
            `.degree-entry[data-degree-index="${index}"]`,
        );
        if (!entry || entry.dataset.locked === "1") return;
        entry.remove();
        const docEntry = degreeDocumentsContainer?.querySelector<HTMLElement>(
            `.degree-documents[data-degree-index="${index}"]`,
        );
        docEntry?.remove();
        updateDegreePositions();
        updateDocumentsPositions();
    }

    function initDegreesFromDataset() {
        renderRequirementsList();
        const initial = parseInitialDegrees();
        if (initial.length === 0) {
            // Niveles without prerequisites (e.g. a hypothetical future
            // application-flow diplomado) still need at least one entry.
            addDegreeEntry({ locked: false });
            return;
        }
        initial.forEach((d) => addDegreeEntry({ grado: d.grado, locked: d.locked }));
    }

    degreesContainer?.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(
            ".remove-degree-btn",
        );
        if (!btn) return;
        const idx = Number(btn.dataset.index ?? "");
        if (!Number.isFinite(idx)) return;
        removeDegreeEntry(idx);
    });

    // Keep the documents-step titles in sync with the degree labels so the
    // user immediately sees which file belongs to which grado/carrera.
    degreesContainer?.addEventListener("input", () => {
        updateDocumentsPositions();
    });
    degreesContainer?.addEventListener("change", () => {
        updateDocumentsPositions();
    });

    addDegreeBtn?.addEventListener("click", () => {
        addDegreeEntry({ locked: false });
    });

    if (requiresDegreeSteps) {
        initDegreesFromDataset();
    }

    /**
     * Minimum-degree check enforced before leaving Step 2 and on submit.
     * Mirrors the server-side rule in `validateMinimumDegrees`.
     */
    function validateMinimumDegrees(): string | null {
        const degrees = getDegreesFromDom();
        const licenciaturas = degrees.filter(
            (d) => d.grado === "Licenciatura",
        ).length;
        const maestrias = degrees.filter((d) => d.grado === "Maestría").length;
        if (
            programNivelDataset === "maestria" ||
            programNivelDataset === "especialidad"
        ) {
            if (licenciaturas === 0) {
                return "Este programa requiere al menos una Licenciatura.";
            }
        }
        if (programNivelDataset === "doctorado") {
            if (licenciaturas === 0 || maestrias === 0) {
                return "El Doctorado requiere al menos una Licenciatura y una Maestría.";
            }
        }
        return null;
    }

    /**
     * Chronological-order check: degrees should be added in non-decreasing
     * rank (Licenciatura -> Especialidad/Maestría -> Doctorado). Two degrees
     * at the same tier (two Licenciaturas, or Maestría+Especialidad) are
     * allowed in any order.
     */
    function validateChronologicalOrder(): string | null {
        const degrees = getDegreesFromDom();
        for (let i = 1; i < degrees.length; i++) {
            const prev = DEGREE_ORDER[degrees[i - 1].grado as DegreeGrado];
            const curr = DEGREE_ORDER[degrees[i].grado as DegreeGrado];
            if (prev === undefined || curr === undefined) continue;
            if (curr < prev) {
                return "Los grados deben estar en orden cronológico (Licenciatura → Especialidad/Maestría → Doctorado).";
            }
        }
        return null;
    }

    /** Cédula SEP: 7 u 8 dígitos para la fila de grado «Doctorado». */
    function validateDoctoradoCedulas(): string | null {
        if (programNivelDataset !== "doctorado") return null;
        const entries =
            degreesContainer?.querySelectorAll<HTMLElement>(".degree-entry") ??
            [];
        for (const entry of entries) {
            const grado =
                entry.querySelector<HTMLSelectElement>(".degree-grado")?.value ??
                "";
            if (grado !== "Doctorado") continue;
            const ced = (
                entry.querySelector<HTMLInputElement>(".degree-cedula-num")
                    ?.value ?? ""
            ).trim();
            if (!/^\d{7,8}$/.test(ced)) {
                return "La cédula profesional del grado Doctorado debe ser numérica de 7 u 8 dígitos.";
            }
        }
        return null;
    }

    type PostPayload = {
        applicationId: string;
        email: string;
        participantName: string;
        participantPhone: string;
        modality: string;
        programSlug: string;
        selectedModule: string;
        selectedDate: string;
    };

    let lastPostPayload: PostPayload | null = null;
    let lastCheckoutPriceId: string | null = null;

    type StripePriceIds = { presencial?: string; online?: string };

    type VariantOption = {
        id: string;
        label: string;
        description?: string;
        stripePriceIds?: StripePriceIds;
    };
    type ParsedVariantOptions = {
        moduleSelection?: { label: string; required?: boolean; options: VariantOption[] };
        dateSelection?: {
            label: string;
            required?: boolean;
            options: { id: string; label: string; description?: string }[];
        };
    };

    function parseStripePriceIdsFromForm(): StripePriceIds {
        try {
            const raw = form?.dataset.stripePriceIds ?? "null";
            const parsed = JSON.parse(raw);
            if (parsed && typeof parsed === "object" && !Array.isArray(parsed)) {
                return parsed as StripePriceIds;
            }
        } catch {
            /* invalid JSON */
        }
        return {};
    }

    function parseVariantOptionsFromForm(): ParsedVariantOptions | null {
        try {
            const raw = form?.dataset.variantOptions ?? "";
            if (!raw) return null;
            const parsed = JSON.parse(raw);
            if (parsed && typeof parsed === "object" && !Array.isArray(parsed)) {
                return parsed as ParsedVariantOptions;
            }
        } catch {
            /* invalid JSON */
        }
        return null;
    }

    /**
     * Picks the right Stripe price for a variant-driven program based on the
     * selected module and the modality chosen in step 1. Returns `null` when
     * no usable price is available so the caller can fall back to wire transfer.
     */
    function resolveVariantPriceId(
        variants: ParsedVariantOptions | null,
        moduleId: string,
        modality: string,
    ): string | null {
        if (!variants?.moduleSelection || !moduleId) return null;
        const opt = variants.moduleSelection.options.find((o) => o.id === moduleId);
        const candidate =
            modality === "Presencial"
                ? opt?.stripePriceIds?.presencial
                : opt?.stripePriceIds?.online;
        return candidate && priceIdIsValid(candidate) ? candidate : null;
    }

    function getCurrentSelectedModule(): string {
        const sel = document.getElementById(
            "variant-module-select",
        ) as HTMLSelectElement | null;
        return (sel?.value ?? "").trim();
    }
    function getCurrentSelectedDate(): string {
        const sel = document.getElementById(
            "variant-date-select",
        ) as HTMLSelectElement | null;
        return (sel?.value ?? "").trim();
    }
    function getCurrentSelectedModuleLabel(): string {
        const sel = document.getElementById(
            "variant-module-select",
        ) as HTMLSelectElement | null;
        if (!sel) return "";
        return sel.options[sel.selectedIndex]?.dataset.label ?? "";
    }
    function getCurrentSelectedDateLabel(): string {
        const sel = document.getElementById(
            "variant-date-select",
        ) as HTMLSelectElement | null;
        if (!sel) return "";
        return sel.options[sel.selectedIndex]?.dataset.label ?? "";
    }

    function priceIdIsValid(priceId: string): boolean {
        return (
            typeof priceId === "string" &&
            /^price_[a-zA-Z0-9]+$/.test(priceId)
        );
    }

    function generateWireReferencePost(): string {
        const id = String(lastPostPayload?.applicationId ?? "").trim();
        if (id) return wireReferenceFromSessionId(id);
        return "CEPRIJA-PENDING";
    }

    function applyInvoiceWireFields() {
        const wireForm = postSubmitWireForm;
        if (!wireForm) return;
        const yes = !!wireForm.querySelector(
            'input[name="requiresInvoice"][value="Sí"]:checked',
        );
        const inv = document.getElementById("post-wire-invoice-fields");
        const fiscal = document.getElementById("post-wire-fiscal") as HTMLInputElement | null;
        const invEmail = document.getElementById("post-wire-invoice-email") as HTMLInputElement | null;
        inv?.classList.toggle("hidden", !yes);
        if (fiscal) fiscal.required = yes;
        if (invEmail) invEmail.required = yes;
    }

    function applyPostPaymentMethodUI() {
        const method =
            (
                document.querySelector(
                    'input[name="postPaymentMethod"]:checked',
                ) as HTMLInputElement | null
            )?.value || "wire";
        const priceOk = !!lastCheckoutPriceId;

        postSubmitStripeBlock?.classList.toggle(
            "hidden",
            method !== "stripe" || !priceOk,
        );
        postSubmitWireForm?.classList.toggle("hidden", method !== "wire");

        const proofInput = document.getElementById(
            "post-wire-payment-proof",
        ) as HTMLInputElement | null;
        if (method === "wire") {
            const ref = generateWireReferencePost();
            const refH = document.getElementById("post-wire-reference") as HTMLInputElement | null;
            const prev = document.getElementById("post-wire-reference-preview");
            if (refH) refH.value = ref;
            if (prev) prev.textContent = ref;
            if (proofInput) proofInput.required = true;
        } else if (proofInput) {
            proofInput.required = false;
        }
    }

    function updateUI() {
        stepEntries.forEach((entry, idx) => {
            const section = document.getElementById(entry.id);
            if (section) {
                section.classList.toggle("hidden", idx + 1 !== currentStep);
            }
        });

        const percent = (currentStep / totalSteps) * 100;
        if (stepLabel) stepLabel.textContent = stepTitle(currentStep);
        if (stepNumber)
            stepNumber.textContent = `${Math.round(percent)}% completado`;
        if (progressBar) progressBar.style.width = `${percent}%`;
    }

    function goToStep(targetIdx: number) {
        const clamped = Math.max(1, Math.min(totalSteps, targetIdx));
        currentStep = clamped;
        updateUI();
        window.scrollTo({ top: 0, behavior: "smooth" });
    }

    function attemptAdvance(fromIdx: number) {
        const entry = stepEntries[fromIdx - 1];
        const section = entry ? document.getElementById(entry.id) : null;
        if (!section) return;
        // Validate required fields + format rules (phone, CURP, CP, email, etc.)
        // so users see inline feedback before moving on, rather than hitting
        // a silent server-side rejection at submit time.
        const result = validateStepSection(section);
        if (!result.ok) {
            reportStepValidationFailure(stepTitle(fromIdx), result);
            return;
        }
        // Step-2 (academic background) has extra rules beyond "all fields filled":
        // the chronological order and the per-nivel minimum set must hold before
        // the user can see the documents step (otherwise they could upload files
        // for an invalid set of degrees).
        if (entry?.id === "step-2") {
            const chronoErr = validateChronologicalOrder();
            if (chronoErr) {
                alert(chronoErr);
                return;
            }
            const minErr = validateMinimumDegrees();
            if (minErr) {
                alert(minErr);
                return;
            }
            const cedErr = validateDoctoradoCedulas();
            if (cedErr) {
                alert(cedErr);
                return;
            }
        }
        goToStep(fromIdx + 1);
    }

    /**
     * The variant step (when present) is index 1, so the personal/academic/document
     * steps shift by +1. We resolve indices via `stepEntries` so the same handlers
     * work whether the variant step is rendered or not.
     */
    function indexOfStep(id: string): number {
        return stepEntries.findIndex((e) => e.id === id) + 1;
    }

    document.getElementById("next-step-variant")?.addEventListener("click", () => {
        const idx = indexOfStep("step-variant");
        if (idx > 0) attemptAdvance(idx);
    });

    document.getElementById("next-step-1")?.addEventListener("click", () => {
        const idx = indexOfStep("step-1");
        if (idx > 0) attemptAdvance(idx);
    });

    // Bind navigation for each of the 4 extended-profile sub-steps using a
    // shared handler so we avoid copy-pasting four near-identical blocks.
    const PROFILE_STEP_IDS = [
        "step-profile-personal",
        "step-profile-address",
        "step-profile-emergency",
        "step-profile-health",
    ] as const;

    for (const sid of PROFILE_STEP_IDS) {
        document
            .getElementById(`next-${sid}`)
            ?.addEventListener("click", () => {
                const idx = indexOfStep(sid);
                if (idx > 0) attemptAdvance(idx);
            });
        document
            .getElementById(`prev-${sid}`)
            ?.addEventListener("click", () => {
                const idx = indexOfStep(sid);
                if (idx > 0) goToStep(idx - 1);
            });
    }

    // Health step: show/hide the detail textarea based on the matching Sí/No
    // radio. Required follows visibility so the form-level required check
    // doesn't block when the user selected "No".
    document
        .querySelectorAll<HTMLInputElement>(".health-toggle")
        .forEach((radio) => {
            radio.addEventListener("change", () => {
                const target = radio.dataset.target;
                if (!target) return;
                const ta = document.querySelector<HTMLTextAreaElement>(
                    `textarea[name="${target}"]`,
                );
                if (!ta) return;
                const show = radio.value === "Sí" && radio.checked;
                ta.classList.toggle("hidden", !show);
                ta.required = show;
                if (!show) ta.value = "";
            });
        });

    // CURP must be uppercase. CSS text-transform only affects display, so
    // mutate the value too to keep client/server validation consistent.
    document
        .querySelectorAll<HTMLInputElement>('input[name="curp"]')
        .forEach((el) => {
            el.addEventListener("input", () => {
                el.value = el.value.toUpperCase();
            });
        });

    document.getElementById("prev-step-2")?.addEventListener("click", () => {
        const idx = indexOfStep("step-2");
        if (idx > 0) goToStep(idx - 1);
    });

    document.getElementById("next-step-2")?.addEventListener("click", () => {
        const idx = indexOfStep("step-2");
        if (idx > 0) attemptAdvance(idx);
    });

    document.getElementById("prev-step-3")?.addEventListener("click", () => {
        const idx = indexOfStep("step-3");
        if (idx > 0) goToStep(idx - 1);
    });

    function applyPostStripeInvoiceFields() {
        const yes = !!document.querySelector(
            'input[name="stripeRequiresInvoice"][value="Sí"]:checked',
        );
        document
            .getElementById("post-stripe-invoice-fields")
            ?.classList.toggle("hidden", !yes);
    }

    postSubmitPaymentSection?.addEventListener("change", (e) => {
        const t = e.target as HTMLInputElement;
        if (t.name === "postPaymentMethod") applyPostPaymentMethodUI();
        if (t.name === "requiresInvoice") applyInvoiceWireFields();
        if (t.name === "stripeRequiresInvoice") applyPostStripeInvoiceFields();
    });

    postSubmitPaymentSection?.addEventListener("click", async (e) => {
        const btn = (e.target as HTMLElement).closest("[data-copy]");
        if (!btn) return;
        const value = btn.getAttribute("data-copy") || "";
        try {
            await navigator.clipboard.writeText(value);
        } catch {
            const ta = document.createElement("textarea");
            ta.value = value;
            document.body.appendChild(ta);
            ta.select();
            document.execCommand("copy");
            ta.remove();
        }
    });

    postSubmitWireForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (postSubmitWireForm) {
            const wireCheck = validateStepSection(postSubmitWireForm);
            if (!wireCheck.ok) {
                reportStepValidationFailure("Comprobante de transferencia", wireCheck);
                return;
            }
        }
        const btn = document.getElementById("post-wire-submit-btn") as HTMLButtonElement | null;
        if (btn) btn.disabled = true;
        try {
            const fd = new FormData(postSubmitWireForm);
            const res = await fetch("/api/payments/wire-proof", {
                method: "POST",
                body: fd,
            });
            const data = await res.json().catch(() => ({}));
            if (!res.ok) {
                throw new Error(
                    typeof data.error === "string" ? data.error : "Error al enviar el comprobante",
                );
            }
            postSubmitWireForm.classList.add("hidden");
            postWireSuccess?.classList.remove("hidden");
            window.scrollTo({ top: postWireSuccess?.offsetTop ?? 0, behavior: "smooth" });
        } catch (err) {
            console.error(err);
            alert(
                err instanceof Error
                    ? err.message
                    : "No se pudo enviar el comprobante. Intenta de nuevo.",
            );
        } finally {
            if (btn) btn.disabled = false;
        }
    });

    function showPostSubmitPaymentOptions(payload: PostPayload) {
        lastPostPayload = payload;

        // Variant-driven programs override the program-level stripePriceIds with
        // the price tied to the chosen module (still keyed by modality). For
        // standard programs we keep the previous behaviour.
        const variants = parseVariantOptionsFromForm();
        let priceId: string | undefined;
        if (variants?.moduleSelection && payload.selectedModule) {
            priceId =
                resolveVariantPriceId(
                    variants,
                    payload.selectedModule,
                    payload.modality,
                ) ?? undefined;
        } else {
            const stripeIds = parseStripePriceIdsFromForm();
            priceId =
                payload.modality === "Presencial"
                    ? stripeIds.presencial
                    : stripeIds.online;
        }
        const priceOk =
            typeof priceId === "string" && priceId.length > 0 && priceIdIsValid(priceId);
        lastCheckoutPriceId = priceOk ? (priceId as string) : null;

        if (postSubmitApplicationId) {
            postSubmitApplicationId.textContent = payload.applicationId
                ? `ID de solicitud: ${payload.applicationId}`
                : "";
        }

        const titleEl = document.getElementById("post-wire-program-title") as HTMLInputElement | null;
        const nameEl = document.getElementById("post-wire-name") as HTMLInputElement | null;
        const emailEl = document.getElementById("post-wire-email") as HTMLInputElement | null;
        const phoneEl = document.getElementById("post-wire-phone") as HTMLInputElement | null;
        const pidEl = document.getElementById("post-wire-program-id") as HTMLInputElement | null;
        const modEl = document.getElementById("post-wire-modality") as HTMLInputElement | null;
        const appEl = document.getElementById("post-wire-application-id") as HTMLInputElement | null;

        if (titleEl) titleEl.value = postSubmitPanel?.dataset.programTitle ?? "";
        if (nameEl) nameEl.value = payload.participantName;
        if (emailEl) emailEl.value = payload.email;
        if (phoneEl) phoneEl.value = payload.participantPhone;
        if (pidEl) pidEl.value = payload.programSlug;
        if (modEl) modEl.value = payload.modality;
        if (appEl) appEl.value = payload.applicationId;

        postWireSuccess?.classList.add("hidden");

        const payProof = document.getElementById(
            "post-wire-payment-proof",
        ) as HTMLInputElement | null;
        const fiscalClear = document.getElementById("post-wire-fiscal") as HTMLInputElement | null;
        const invMailClear = document.getElementById(
            "post-wire-invoice-email",
        ) as HTMLInputElement | null;
        if (payProof) payProof.value = "";
        if (fiscalClear) fiscalClear.value = "";
        if (invMailClear) invMailClear.value = "";

        const stripeRadio = document.getElementById("post-pay-stripe") as HTMLInputElement | null;
        const wireRadio = document.getElementById("post-pay-wire") as HTMLInputElement | null;
        const stripeUnavailable = document.getElementById("post-pay-stripe-unavailable");
        const stripeLabel = document.getElementById("post-pay-stripe-label");

        if (priceOk) {
            stripeUnavailable?.classList.add("hidden");
            if (stripeRadio) stripeRadio.disabled = false;
            stripeLabel?.classList.remove("opacity-50", "cursor-not-allowed", "pointer-events-none");
            if (stripeRadio) stripeRadio.checked = true;
        } else {
            stripeUnavailable?.classList.remove("hidden");
            if (stripeRadio) stripeRadio.disabled = true;
            stripeLabel?.classList.add("opacity-50", "cursor-not-allowed", "pointer-events-none");
            if (wireRadio) wireRadio.checked = true;
        }

        const invYesEl = postSubmitWireForm?.querySelector(
            'input[name="requiresInvoice"][value="Sí"]',
        ) as HTMLInputElement | null;
        const invNoEl = postSubmitWireForm?.querySelector(
            'input[name="requiresInvoice"][value="No"]',
        ) as HTMLInputElement | null;
        if (invYesEl) invYesEl.checked = false;
        if (invNoEl) invNoEl.checked = true;
        applyInvoiceWireFields();

        const stInvYes = document.querySelector(
            'input[name="stripeRequiresInvoice"][value="Sí"]',
        ) as HTMLInputElement | null;
        const stInvNo = document.querySelector(
            'input[name="stripeRequiresInvoice"][value="No"]',
        ) as HTMLInputElement | null;
        if (stInvYes) stInvYes.checked = false;
        if (stInvNo) stInvNo.checked = true;
        const stMail = document.getElementById(
            "post-stripe-invoice-email",
        ) as HTMLInputElement | null;
        const stFis = document.getElementById("post-stripe-fiscal") as HTMLInputElement | null;
        if (stMail) stMail.value = "";
        if (stFis) stFis.value = "";
        applyPostStripeInvoiceFields();

        postSubmitPaymentSection?.classList.remove("hidden");

        const stripeBtn = document.getElementById(
            "stripe-after-enrollment-btn",
        ) as HTMLButtonElement | null;
        if (stripeBtn && priceOk) {
            const fresh = stripeBtn.cloneNode(true) as HTMLButtonElement;
            stripeBtn.replaceWith(fresh);
            fresh.addEventListener("click", async () => {
                if (!lastCheckoutPriceId || !lastPostPayload) return;

                const needsInv = !!document.querySelector(
                    'input[name="stripeRequiresInvoice"][value="Sí"]:checked',
                );
                const invEmailEl = document.getElementById(
                    "post-stripe-invoice-email",
                ) as HTMLInputElement | null;
                const fiscalEl = document.getElementById(
                    "post-stripe-fiscal",
                ) as HTMLInputElement | null;
                const invEmail = (invEmailEl?.value ?? "").trim();

                if (needsInv) {
                    if (!invEmail) {
                        alert("Indica el correo para recibir la factura.");
                        return;
                    }
                    const f = fiscalEl?.files?.[0];
                    if (!f) {
                        alert("Adjunta la constancia de situación fiscal (CSF).");
                        return;
                    }
                    fresh.disabled = true;
                    fresh.textContent = "Enviando datos fiscales…";
                    try {
                        const fd = new FormData();
                        fd.append("invoiceEmail", invEmail);
                        fd.append("programSlug", lastPostPayload.programSlug);
                        fd.append(
                            "programTitle",
                            postSubmitPanel?.dataset.programTitle ?? "",
                        );
                        fd.append("participantName", lastPostPayload.participantName);
                        fd.append("participantPhone", lastPostPayload.participantPhone);
                        fd.append("modality", lastPostPayload.modality);
                        fd.append("customerEmail", lastPostPayload.email);
                        if (lastPostPayload.applicationId) {
                            fd.append("applicationId", lastPostPayload.applicationId);
                        }
                        fd.append("fiscalConstancy", f);
                        const pre = await fetch("/api/stripe/fiscal-preflight", {
                            method: "POST",
                            body: fd,
                        });
                        const preJson = await pre.json().catch(() => ({}));
                        if (!pre.ok) {
                            throw new Error(
                                typeof preJson.error === "string"
                                    ? preJson.error
                                    : "No se pudo enviar la CSF",
                            );
                        }
                    } catch (err) {
                        console.error(err);
                        alert(
                            err instanceof Error
                                ? err.message
                                : "Error al enviar datos fiscales.",
                        );
                        fresh.disabled = false;
                        fresh.textContent = "Continuar al pago seguro (Stripe)";
                        return;
                    }
                }

                fresh.disabled = true;
                fresh.textContent = "Redirigiendo a Stripe…";
                try {
                    const res = await fetch("/api/stripe/create-checkout-session", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({
                            priceId: lastCheckoutPriceId,
                            customerEmail: lastPostPayload.email,
                            programSlug: lastPostPayload.programSlug,
                            participantName: lastPostPayload.participantName,
                            participantPhone: lastPostPayload.participantPhone,
                            modality: lastPostPayload.modality,
                            requiresInvoice: needsInv ? "Sí" : "No",
                            invoiceEmail: needsInv ? invEmail : "",
                            ...(lastPostPayload.applicationId
                                ? { applicationId: lastPostPayload.applicationId }
                                : {}),
                            ...(lastPostPayload.selectedModule
                                ? { selectedModule: lastPostPayload.selectedModule }
                                : {}),
                            ...(lastPostPayload.selectedDate
                                ? { selectedDate: lastPostPayload.selectedDate }
                                : {}),
                        }),
                    });
                    const data = await res.json();
                    if (data.url) {
                        window.location.href = data.url;
                    } else {
                        throw new Error(data.error || "No se pudo iniciar el pago");
                    }
                } catch (err) {
                    console.error(err);
                    alert(
                        err instanceof Error
                            ? err.message
                            : "Error al iniciar el pago. Intenta de nuevo o contacta soporte.",
                    );
                    fresh.disabled = false;
                    fresh.textContent = "Continuar al pago seguro (Stripe)";
                }
            });
        }

        applyPostPaymentMethodUI();

        stepperCard?.classList.add("hidden");
        form?.classList.add("hidden");
        postSubmitPanel?.classList.remove("hidden");
        window.scrollTo({ top: 0, behavior: "smooth" });
    }

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();

        for (let i = 1; i <= totalSteps; i++) {
            const entry = stepEntries[i - 1];
            const section = entry ? document.getElementById(entry.id) : null;
            if (!section) continue;
            // Ensure the step is visible before validating. Otherwise the
            // `.hidden` class on non-current steps bubbles up through
            // `isHiddenInFormTree` and the validator silently skips every
            // required field in that step, which let bad data reach the
            // server.
            currentStep = i;
            updateUI();
            // validateStepSection = required fields + format checks. Without
            // the format pass, a bad CURP/phone/CP would slip past the client
            // and the server would reject silently (the user reports
            // "nothing happens" when clicking Enviar Solicitud).
            const result = validateStepSection(section);
            if (!result.ok) {
                reportStepValidationFailure(stepTitle(i), result);
                // No `scrollTo(0)` aquí: anula el `scrollIntoView` de
                // `reportStepValidationFailure` y parece que «Enviar» no hace nada.
                alert(formatStepValidationMessage(stepTitle(i), result.missingLabels));
                return;
            }
            if (entry?.id === "step-2") {
                const chronoErr = validateChronologicalOrder();
                if (chronoErr) {
                    currentStep = i;
                    updateUI();
                    alert(chronoErr);
                    window.scrollTo({ top: 0, behavior: "smooth" });
                    return;
                }
                const minErr = validateMinimumDegrees();
                if (minErr) {
                    currentStep = i;
                    updateUI();
                    alert(minErr);
                    window.scrollTo({ top: 0, behavior: "smooth" });
                    return;
                }
                const cedErr = validateDoctoradoCedulas();
                if (cedErr) {
                    currentStep = i;
                    updateUI();
                    alert(cedErr);
                    window.scrollTo({ top: 0, behavior: "smooth" });
                    return;
                }
            }
        }

        if (statusDiv) {
            statusDiv.classList.add("hidden");
            statusDiv.className = "hidden mt-6 p-4 rounded-xl text-sm max-w-4xl mx-auto";
        }

        if (submitBtn && spinner) {
            submitBtn.disabled = true;
            spinner.classList.remove("hidden");
        }

        const formData = new FormData(form);
        const email = String(formData.get("email") ?? "").trim();
        const nombre = String(formData.get("nombre") ?? "").trim();
        const apellidos = String(formData.get("apellidos") ?? "").trim();
        const telefono = String(formData.get("telefono") ?? "").trim();
        const modalityEl = form.querySelector(
            'input[name="modality"]:checked',
        ) as HTMLInputElement | null;
        const modality = String(modalityEl?.value ?? "").trim();
        const programSlug = String(form.dataset.programSlug ?? "").trim();
        const participantName = `${nombre} ${apellidos}`.trim();

        // Variant fields (selectedModule / selectedDate) are only present when
        // the program defines variantOptions. They go in the multipart payload
        // automatically (the dropdowns live inside `<form>`); we capture the
        // labels here so we can show them in the post-submit panel.
        const selectedModule = String(formData.get("selectedModule") ?? "").trim();
        const selectedDate = String(formData.get("selectedDate") ?? "").trim();
        const selectedModuleLabel = getCurrentSelectedModuleLabel();
        const selectedDateLabel = getCurrentSelectedDateLabel();
        if (selectedModuleLabel) {
            formData.set("selectedModuleLabel", selectedModuleLabel);
        }
        if (selectedDateLabel) {
            formData.set("selectedDateLabel", selectedDateLabel);
        }

        try {
            const response = await fetch("/api/enrollment", {
                method: "POST",
                body: formData,
            });

            const result = (await response.json().catch(() => null)) as
                | { applicationId?: string; message?: string; error?: string }
                | null;
            const serverMsg =
                (result && typeof result.message === "string" && result.message) ||
                (result && typeof result.error === "string" && result.error) ||
                "";

            if (response.ok) {
                const applicationId =
                    result && typeof result.applicationId === "string"
                        ? result.applicationId
                        : "";
                form.reset();
                currentStep = 1;
                updateUI();
                showPostSubmitPaymentOptions({
                    applicationId,
                    email,
                    participantName,
                    participantPhone: telefono,
                    modality,
                    programSlug,
                    selectedModule,
                    selectedDate,
                });
            } else {
                throw new Error(
                    serverMsg ||
                        `No se pudo enviar la solicitud (${response.status}). Intenta de nuevo.`,
                );
            }
        } catch (error) {
            if (statusDiv) {
                const detail =
                    error instanceof Error && error.message
                        ? error.message
                        : "Hubo un error al enviar tu solicitud.";
                statusDiv.textContent = `${detail} Verifica los archivos (PDF o imagen) o contáctanos.`;
                statusDiv.classList.remove("hidden");
                statusDiv.classList.add("bg-red-100", "text-red-800", "border", "border-red-200");
                statusDiv.scrollIntoView({ behavior: "smooth", block: "nearest" });
            }
            console.error("Error submitting enrollment:", error);
        } finally {
            if (submitBtn && spinner) {
                submitBtn.disabled = false;
                spinner.classList.add("hidden");
            }
        }
    });

    updateUI();
</script>

<!-- Flatpickr: rendered AFTER the main module script so the date-picker input
     already exists in the DOM by the time we initialize it. `altInput` keeps a
     user-friendly DD/MM/YYYY visible input while the hidden original input
     holds the backend-friendly ISO (YYYY-MM-DD) value that the API expects
     (see birth-date parsing in /api/enrollment.ts). -->
<script is:inline src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script is:inline src="https://npmcdn.com/flatpickr/dist/l10n/es.js"></script>
<script is:inline>
    (function initDatePickers() {
        if (typeof flatpickr !== "function") return;
        document.querySelectorAll(".date-picker").forEach(function (el) {
            var minDate = el.getAttribute("data-min-date") || "1900-01-01";
            var maxDate = el.getAttribute("data-max-date") || undefined;
            flatpickr(el, {
                locale: "es",
                dateFormat: "Y-m-d",
                altInput: true,
                altFormat: "d/m/Y",
                allowInput: true,
                disableMobile: true,
                minDate: minDate,
                maxDate: maxDate,
                onReady: function (_dates, _str, instance) {
                    if (instance.altInput) {
                        instance.altInput.removeAttribute("required");
                    }
                },
            });
        });
    })();
</script>
