---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { getProgramPathSlug, validateUniqueSlugs } from "@lib/programPaths";
import { getEnrollmentFlow } from "@lib/enrollmentRouting";
import { getVariantOptions } from "@lib/programVariants";
import { getInitialDegreesForNivel } from "@lib/enrollmentDegrees";
import {
    requiresAcademicDegreeSteps,
    requiresExtendedApplicantProfile,
} from "@lib/enrollmentAdmissionFlags";
import VariantSelectionStep from "@components/enrollment/VariantSelectionStep.astro";
import bankInfo from "../../data/bank-info.json";
import {
    civilStates,
    genres,
    nationalities,
    relatives,
    sources,
    states as mexicanStates,
    yesNo,
} from "@data/forms/inscription-options.js";

export async function getStaticPaths() {
    const programs = await getCollection("programas");
    validateUniqueSlugs(programs);
    // Only generate pages for programs requiring application flow
    return programs
        .filter((program) => getEnrollmentFlow(program) === "application")
        .map((program) => ({
            params: { slug: getProgramPathSlug(program) },
            props: { program },
        }));
}

const { program } = Astro.props;
const programSlug = getProgramPathSlug(program);

const rawStripe = program.data.stripePriceIds;
const stripePriceIdsForClient =
    rawStripe &&
    typeof rawStripe === "object" &&
    !Array.isArray(rawStripe)
        ? rawStripe
        : null;

const variantOptions = getVariantOptions(program);
const hasVariantStep = variantOptions !== null;

// Multi-degree scaffolding: `initialDegrees` is the minimum list the form should
// render (e.g. 1 Licenciatura for Maestría/Especialidad, Licenciatura + Maestría
// for Doctorado). The client script hydrates from this array and lets users add
// more degrees. `nivel` is passed along so client-side validation can enforce
// the per-program minimums without re-deriving the rule.
const programNivel = program.data.nivel;
const requiresDegreeSteps = requiresAcademicDegreeSteps(programNivel);
const requiresExtendedProfile = requiresExtendedApplicantProfile(programNivel);
const initialDegrees = requiresDegreeSteps ? getInitialDegreesForNivel(programNivel) : [];

// Extended profile splits into 4 sub-steps (personal, address, emergency, health)
// for maestría/doctorado/especialidad to mirror the historical inscription form.
const EXTENDED_PROFILE_STEPS = 4;
const stepCount =
    (hasVariantStep ? 1 : 0) +
    1 +
    (requiresExtendedProfile ? EXTENDED_PROFILE_STEPS : 0) +
    (requiresDegreeSteps ? 1 : 0) +
    1;
const firstStepPct = Math.round((1 / stepCount) * 100);

// Birth date bounds for the Flatpickr date picker. We compute them at render
// time so the 18+ check stays correct across deploys without touching the
// template. The server re-validates (`age >= 18 && age <= 120`) in
// `/api/enrollment`.
const birthDateToday = new Date();
const birthDateMax = new Date(
    birthDateToday.getFullYear() - 18,
    birthDateToday.getMonth(),
    birthDateToday.getDate(),
);
const birthDateMin = new Date(
    birthDateToday.getFullYear() - 120,
    birthDateToday.getMonth(),
    birthDateToday.getDate(),
);
const toIsoDate = (d: Date) => d.toISOString().slice(0, 10);
const birthDateMaxIso = toIsoDate(birthDateMax);
const birthDateMinIso = toIsoDate(birthDateMin);

const seo = {
    title: `Solicitud de Admisión - ${program.data.title} | CEPRIJA`,
    description: `Complete su solicitud de admisión para ${program.data.title} en CEPRIJA.`,
};
---

<Layout seo={seo}>
    <!-- Flatpickr calendar (used for Fecha de nacimiento). We reuse the same
         CDN + branding tokens as InscriptionForm so the picker matches the
         rest of the site without bundling another dependency. -->
    <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css"
    />
    <style>
        .flatpickr-calendar {
            font-family: inherit;
            border: 2px solid #f3f4f6;
            border-radius: 1rem;
            box-shadow:
                0 10px 25px -5px rgba(0, 0, 0, 0.1),
                0 8px 10px -6px rgba(0, 0, 0, 0.1);
        }
        .flatpickr-day.selected,
        .flatpickr-day.startRange,
        .flatpickr-day.endRange,
        .flatpickr-day.selected.inRange,
        .flatpickr-day.startRange.inRange,
        .flatpickr-day.endRange.inRange,
        .flatpickr-day.selected:focus,
        .flatpickr-day.startRange:focus,
        .flatpickr-day.endRange:focus,
        .flatpickr-day.selected:hover,
        .flatpickr-day.startRange:hover,
        .flatpickr-day.endRange:hover,
        .flatpickr-day.selected.prevMonthDay,
        .flatpickr-day.startRange.prevMonthDay,
        .flatpickr-day.endRange.prevMonthDay,
        .flatpickr-day.selected.nextMonthDay,
        .flatpickr-day.startRange.nextMonthDay,
        .flatpickr-day.endRange.nextMonthDay {
            background: #1e3a8a;
            border-color: #1e3a8a;
        }
    </style>
    <main class="bg-gray-50 min-h-screen pb-20">
        <!-- Header -->
        <section class="bg-primary text-white py-12">
            <div class="container mx-auto px-6">
                <a
                    href={`/oferta-academica/${programSlug}`}
                    class="inline-flex items-center text-blue-100 hover:text-white mb-6 transition-colors"
                >
                    <svg
                        class="w-5 h-5 mr-2"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M15 19l-7-7 7-7"></path>
                    </svg>
                    Volver al programa
                </a>
                <h1 class="text-3xl md:text-4xl font-bold font-serif mb-2">
                    Solicitud de Admisión
                </h1>
                <p class="text-xl text-blue-100">{program.data.title}</p>
            </div>
        </section>

        <!-- Progress Stepper -->
        <section class="container mx-auto px-6 -mt-6 relative z-20">
            <div
                id="enrollment-stepper-card"
                class="bg-white rounded-2xl shadow-xl p-6 md:p-8 mb-8"
            >
                <div class="flex items-center justify-between mb-4">
                    <h2
                        class="text-xl font-bold text-primary font-serif"
                        id="step-label"
                    >
                        {
                            `Paso 1 de ${stepCount}: ${hasVariantStep ? "Opciones del programa" : "Información Personal"}`
                        }
                    </h2>
                    <span class="text-sm font-semibold text-gray-500" id="step-number"
                        >{firstStepPct}% completado</span
                    >
                </div>
                <div class="w-full bg-gray-100 h-3 rounded-full overflow-hidden">
                    <div
                        id="progress-bar"
                        class="bg-secondary h-full transition-all duration-500 ease-out shadow-sm"
                        style={`width: ${firstStepPct}%`}
                    >
                    </div>
                </div>
            </div>

            <!-- Form Container -->
            <form
                id="enrollment-form"
                class="bg-white rounded-2xl shadow-xl overflow-hidden"
                data-program-slug={programSlug}
                data-program-title={String(program.data.title)}
                data-program-nivel={programNivel}
                data-initial-degrees={JSON.stringify(initialDegrees)}
                data-stripe-price-ids={JSON.stringify(stripePriceIdsForClient)}
                data-has-variant-step={hasVariantStep ? "1" : "0"}
                data-requires-degree-steps={requiresDegreeSteps ? "1" : "0"}
                data-requires-extended-profile={requiresExtendedProfile ? "1" : "0"}
                data-variant-options={
                    hasVariantStep ? JSON.stringify(variantOptions) : ""
                }
            >
                <!-- Hidden fields -->
                <input type="hidden" name="programSlug" value={programSlug} />
                <input type="hidden" name="programTitle" value={String(program.data.title)} />

                {
                    hasVariantStep && variantOptions && (
                        <VariantSelectionStep variants={variantOptions} />
                    )
                }

                <!-- Step 1: Personal Information -->
                <div
                    class:list={[
                        "step-section p-8 md:p-12",
                        hasVariantStep && "hidden",
                    ]}
                    id="step-1"
                >
                    <div class="mb-8 text-center">
                        <div
                            class="inline-block p-4 bg-blue-50 rounded-2xl mb-4 text-primary"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-8 w-8"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                                ></path>
                            </svg>
                        </div>
                        <p class="text-gray-600 text-sm max-w-2xl mx-auto">
                            Complete su información personal para iniciar el proceso de admisión.
                        </p>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">
                                Nombre(s) *
                            </label>
                            <input
                                type="text"
                                name="nombre"
                                required
                                class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                placeholder="Tu nombre"
                            />
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">
                                Apellidos *
                            </label>
                            <input
                                type="text"
                                name="apellidos"
                                required
                                class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                placeholder="Tus apellidos"
                            />
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">
                                Correo Electrónico *
                            </label>
                            <input
                                type="email"
                                name="email"
                                required
                                class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                placeholder="tu@email.com"
                            />
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">
                                Teléfono / WhatsApp *
                            </label>
                            <input
                                type="tel"
                                name="telefono"
                                required
                                class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                placeholder="33 1234 5678"
                            />
                        </div>

                        <div class="md:col-span-2">
                            <label class="block text-sm font-semibold text-gray-700 mb-2">
                                Modalidad de Estudio *
                            </label>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <label class="flex items-center gap-3 p-4 border-2 border-gray-100 rounded-2xl cursor-pointer hover:bg-gray-50 transition-all has-[:checked]:border-primary has-[:checked]:bg-blue-50">
                                    <input
                                        type="radio"
                                        name="modality"
                                        value="Presencial"
                                        required
                                        checked
                                        class="w-5 h-5 text-primary focus:ring-primary"
                                    />
                                    <div class="flex flex-col">
                                        <span class="font-bold text-gray-900">Presencial</span>
                                        <span class="text-xs text-gray-500">Asistencia en campus</span>
                                    </div>
                                </label>
                                <label class="flex items-center gap-3 p-4 border-2 border-gray-100 rounded-2xl cursor-pointer hover:bg-gray-50 transition-all has-[:checked]:border-primary has-[:checked]:bg-blue-50">
                                    <input
                                        type="radio"
                                        name="modality"
                                        value="En línea"
                                        required
                                        class="w-5 h-5 text-primary focus:ring-primary"
                                    />
                                    <div class="flex flex-col">
                                        <span class="font-bold text-gray-900">En línea</span>
                                        <span class="text-xs text-gray-500">Vía videoconferencia</span>
                                    </div>
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="flex justify-end mt-8 max-w-4xl mx-auto">
                        <button
                            type="button"
                            id="next-step-1"
                            class="px-8 py-3 bg-secondary hover:bg-secondary/90 text-white font-bold rounded-xl transition-all shadow-lg hover:shadow-xl"
                        >
                            Siguiente
                        </button>
                    </div>
                </div>

                {
                    requiresExtendedProfile && (
                        <>
                            {/* PROFILE STEP 1: Personal data */}
                            <div
                                class="step-section p-8 md:p-12 hidden"
                                id="step-profile-personal"
                            >
                                <div class="mb-8 text-center">
                                    <div class="inline-block p-4 bg-blue-50 rounded-2xl mb-4 text-primary">
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            class="h-8 w-8"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke="currentColor"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                                            />
                                        </svg>
                                    </div>
                                    <p class="text-gray-600 text-sm max-w-2xl mx-auto">
                                        Datos personales adicionales requeridos para tu
                                        expediente académico.
                                    </p>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
                                    <div>
                                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                                            Género *
                                        </label>
                                        <select
                                            name="genero"
                                            required
                                            class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                        >
                                            <option value="">Selecciona…</option>
                                            {genres.map((g: string) => (
                                                <option value={g}>{g}</option>
                                            ))}
                                        </select>
                                    </div>

                                    <div>
                                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                                            Fecha de nacimiento *
                                        </label>
                                        <input
                                            type="text"
                                            name="fechaNacimiento"
                                            required
                                            placeholder="DD/MM/AAAA"
                                            aria-label="Fecha de nacimiento"
                                            data-min-date={birthDateMinIso}
                                            data-max-date={birthDateMaxIso}
                                            class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all date-picker bg-white"
                                        />
                                    </div>

                                    <div>
                                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                                            CURP *
                                        </label>
                                        <input
                                            type="text"
                                            name="curp"
                                            required
                                            maxlength="18"
                                            minlength="18"
                                            pattern="[A-Z0-9]{18}"
                                            title="18 caracteres en mayúsculas (alfanuméricos)"
                                            class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all uppercase"
                                            placeholder="18 caracteres"
                                            style="text-transform: uppercase;"
                                        />
                                    </div>

                                    <div>
                                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                                            Nacionalidad *
                                        </label>
                                        <select
                                            name="nacionalidad"
                                            required
                                            class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                        >
                                            <option value="">Selecciona…</option>
                                            {nationalities.map((n: string) => (
                                                <option value={n}>{n}</option>
                                            ))}
                                        </select>
                                    </div>

                                    <div>
                                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                                            Estado civil *
                                        </label>
                                        <select
                                            name="estadoCivil"
                                            required
                                            class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                        >
                                            <option value="">Selecciona…</option>
                                            {civilStates.map((s: string) => (
                                                <option value={s}>{s}</option>
                                            ))}
                                        </select>
                                    </div>

                                    <div>
                                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                                            Entidad de nacimiento *
                                        </label>
                                        <select
                                            name="entidadNacimiento"
                                            required
                                            class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                        >
                                            <option value="">Selecciona…</option>
                                            {mexicanStates.map((s: string) => (
                                                <option value={s}>{s}</option>
                                            ))}
                                        </select>
                                    </div>

                                    <div>
                                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                                            Ocupación actual *
                                        </label>
                                        <input
                                            type="text"
                                            name="ocupacion"
                                            required
                                            maxlength="100"
                                            class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                            placeholder="Tu ocupación o profesión"
                                        />
                                    </div>

                                    <div>
                                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                                            ¿Habla lengua indígena? *
                                        </label>
                                        <select
                                            name="lenguaIndigena"
                                            required
                                            class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                        >
                                            <option value="">Selecciona…</option>
                                            {yesNo.map((v: string) => (
                                                <option value={v}>{v}</option>
                                            ))}
                                        </select>
                                    </div>

                                    <div class="md:col-span-2">
                                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                                            ¿Cómo se enteró de nosotros? *
                                        </label>
                                        <select
                                            name="origen"
                                            required
                                            class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                        >
                                            <option value="">Selecciona…</option>
                                            {sources.map((s: string) => (
                                                <option value={s}>{s}</option>
                                            ))}
                                        </select>
                                    </div>
                                </div>

                                <div class="flex justify-between mt-8 max-w-4xl mx-auto">
                                    <button
                                        type="button"
                                        id="prev-step-profile-personal"
                                        class="px-8 py-3 bg-gray-200 hover:bg-gray-300 text-gray-700 font-bold rounded-xl transition-all"
                                    >
                                        Anterior
                                    </button>
                                    <button
                                        type="button"
                                        id="next-step-profile-personal"
                                        class="px-8 py-3 bg-secondary hover:bg-secondary/90 text-white font-bold rounded-xl transition-all shadow-lg hover:shadow-xl"
                                    >
                                        Siguiente
                                    </button>
                                </div>
                            </div>

                            {/* PROFILE STEP 2: Address */}
                            <div
                                class="step-section p-8 md:p-12 hidden"
                                id="step-profile-address"
                            >
                                <div class="mb-8 text-center">
                                    <div class="inline-block p-4 bg-blue-50 rounded-2xl mb-4 text-primary">
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            class="h-8 w-8"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke="currentColor"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                            />
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                                            />
                                        </svg>
                                    </div>
                                    <p class="text-gray-600 text-sm max-w-2xl mx-auto">
                                        Tu dirección particular para envíos y notificaciones
                                        oficiales.
                                    </p>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
                                    <div class="md:col-span-2">
                                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                                            Calle y número *
                                        </label>
                                        <input
                                            type="text"
                                            name="calle"
                                            required
                                            maxlength="200"
                                            class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                            placeholder="Ej: Av. Reforma #123"
                                        />
                                    </div>

                                    <div>
                                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                                            Colonia *
                                        </label>
                                        <input
                                            type="text"
                                            name="colonia"
                                            required
                                            maxlength="120"
                                            class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                        />
                                    </div>

                                    <div>
                                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                                            Código Postal *
                                        </label>
                                        <input
                                            type="text"
                                            name="cp"
                                            required
                                            maxlength="5"
                                            minlength="5"
                                            pattern="[0-9]{5}"
                                            inputmode="numeric"
                                            title="5 dígitos numéricos"
                                            class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                            placeholder="44500"
                                        />
                                    </div>

                                    <div>
                                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                                            Ciudad / Municipio *
                                        </label>
                                        <input
                                            type="text"
                                            name="ciudad"
                                            required
                                            maxlength="120"
                                            class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                        />
                                    </div>

                                    <div>
                                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                                            Estado *
                                        </label>
                                        <select
                                            name="estadoDireccion"
                                            required
                                            class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                        >
                                            <option value="">Selecciona…</option>
                                            {mexicanStates.map((s: string) => (
                                                <option value={s}>{s}</option>
                                            ))}
                                        </select>
                                    </div>
                                </div>

                                <div class="flex justify-between mt-8 max-w-4xl mx-auto">
                                    <button
                                        type="button"
                                        id="prev-step-profile-address"
                                        class="px-8 py-3 bg-gray-200 hover:bg-gray-300 text-gray-700 font-bold rounded-xl transition-all"
                                    >
                                        Anterior
                                    </button>
                                    <button
                                        type="button"
                                        id="next-step-profile-address"
                                        class="px-8 py-3 bg-secondary hover:bg-secondary/90 text-white font-bold rounded-xl transition-all shadow-lg hover:shadow-xl"
                                    >
                                        Siguiente
                                    </button>
                                </div>
                            </div>

                            {/* PROFILE STEP 3: Emergency contact */}
                            <div
                                class="step-section p-8 md:p-12 hidden"
                                id="step-profile-emergency"
                            >
                                <div class="mb-8 text-center">
                                    <div class="inline-block p-4 bg-blue-50 rounded-2xl mb-4 text-primary">
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            class="h-8 w-8"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke="currentColor"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                                            />
                                        </svg>
                                    </div>
                                    <p class="text-gray-600 text-sm max-w-2xl mx-auto">
                                        Persona a contactar en caso de emergencia.
                                    </p>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
                                    <div class="md:col-span-2">
                                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                                            Contacto de emergencia (nombre completo) *
                                        </label>
                                        <input
                                            type="text"
                                            name="contactoEmergencia"
                                            required
                                            maxlength="200"
                                            class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                            placeholder="Nombre completo"
                                        />
                                    </div>

                                    <div>
                                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                                            Parentesco *
                                        </label>
                                        <select
                                            name="parentesco"
                                            required
                                            class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                        >
                                            <option value="">Selecciona…</option>
                                            {relatives.map((r: string) => (
                                                <option value={r}>{r}</option>
                                            ))}
                                        </select>
                                    </div>

                                    <div>
                                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                                            Teléfono de emergencia *
                                        </label>
                                        <input
                                            type="tel"
                                            name="telEmergencia"
                                            required
                                            maxlength="25"
                                            class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                            placeholder="10 dígitos o formato internacional"
                                        />
                                    </div>
                                </div>

                                <div class="flex justify-between mt-8 max-w-4xl mx-auto">
                                    <button
                                        type="button"
                                        id="prev-step-profile-emergency"
                                        class="px-8 py-3 bg-gray-200 hover:bg-gray-300 text-gray-700 font-bold rounded-xl transition-all"
                                    >
                                        Anterior
                                    </button>
                                    <button
                                        type="button"
                                        id="next-step-profile-emergency"
                                        class="px-8 py-3 bg-secondary hover:bg-secondary/90 text-white font-bold rounded-xl transition-all shadow-lg hover:shadow-xl"
                                    >
                                        Siguiente
                                    </button>
                                </div>
                            </div>

                            {/* PROFILE STEP 4: Health */}
                            <div
                                class="step-section p-8 md:p-12 hidden"
                                id="step-profile-health"
                            >
                                <div class="mb-8 text-center">
                                    <div class="inline-block p-4 bg-blue-50 rounded-2xl mb-4 text-primary">
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            class="h-8 w-8"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke="currentColor"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
                                            />
                                        </svg>
                                    </div>
                                    <p class="text-gray-600 text-sm max-w-2xl mx-auto">
                                        Información de salud para fines administrativos y
                                        de seguridad. Solo se usa internamente.
                                    </p>
                                </div>

                                <div class="space-y-5 max-w-4xl mx-auto">
                                    <div class="p-5 bg-gray-50 rounded-2xl border border-gray-100">
                                        <label class="block font-semibold text-gray-800 mb-3">
                                            ¿Presenta alguna capacidad diferente? *
                                        </label>
                                        <div class="flex gap-6 mb-3">
                                            {yesNo.map((v: string) => (
                                                <label class="flex items-center gap-2 cursor-pointer">
                                                    <input
                                                        type="radio"
                                                        name="capacidadDif"
                                                        value={v}
                                                        required
                                                        class="w-5 h-5 accent-primary health-toggle"
                                                        data-target="detalleCapacidad"
                                                    />
                                                    <span>{v}</span>
                                                </label>
                                            ))}
                                        </div>
                                        <textarea
                                            name="detalleCapacidad"
                                            data-detail-for="capacidadDif"
                                            placeholder="Especifique cuál(es)…"
                                            rows={2}
                                            maxlength="500"
                                            class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all hidden"
                                        />
                                    </div>

                                    <div class="p-5 bg-gray-50 rounded-2xl border border-gray-100">
                                        <label class="block font-semibold text-gray-800 mb-3">
                                            ¿Padece alguna enfermedad crónica? *
                                        </label>
                                        <div class="flex gap-6 mb-3">
                                            {yesNo.map((v: string) => (
                                                <label class="flex items-center gap-2 cursor-pointer">
                                                    <input
                                                        type="radio"
                                                        name="enfCronica"
                                                        value={v}
                                                        required
                                                        class="w-5 h-5 accent-primary health-toggle"
                                                        data-target="detalleEnf"
                                                    />
                                                    <span>{v}</span>
                                                </label>
                                            ))}
                                        </div>
                                        <textarea
                                            name="detalleEnf"
                                            data-detail-for="enfCronica"
                                            placeholder="Describa la enfermedad y si requiere medicación…"
                                            rows={2}
                                            maxlength="500"
                                            class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all hidden"
                                        />
                                    </div>

                                    <div class="p-5 bg-gray-50 rounded-2xl border border-gray-100">
                                        <label class="block font-semibold text-gray-800 mb-3">
                                            ¿Padece alguna alergia? *
                                        </label>
                                        <div class="flex gap-6 mb-3">
                                            {yesNo.map((v: string) => (
                                                <label class="flex items-center gap-2 cursor-pointer">
                                                    <input
                                                        type="radio"
                                                        name="alergia"
                                                        value={v}
                                                        required
                                                        class="w-5 h-5 accent-primary health-toggle"
                                                        data-target="detalleAlergia"
                                                    />
                                                    <span>{v}</span>
                                                </label>
                                            ))}
                                        </div>
                                        <textarea
                                            name="detalleAlergia"
                                            data-detail-for="alergia"
                                            placeholder="Describa la alergia y cuidados…"
                                            rows={2}
                                            maxlength="500"
                                            class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all hidden"
                                        />
                                    </div>

                                    <div class="p-5 bg-gray-50 rounded-2xl border border-gray-100">
                                        <label class="block font-semibold text-gray-800 mb-3">
                                            ¿Está bajo tratamiento médico controlado? *
                                        </label>
                                        <div class="flex gap-6 mb-3">
                                            {yesNo.map((v: string) => (
                                                <label class="flex items-center gap-2 cursor-pointer">
                                                    <input
                                                        type="radio"
                                                        name="tratamiento"
                                                        value={v}
                                                        required
                                                        class="w-5 h-5 accent-primary health-toggle"
                                                        data-target="detalleTratamiento"
                                                    />
                                                    <span>{v}</span>
                                                </label>
                                            ))}
                                        </div>
                                        <textarea
                                            name="detalleTratamiento"
                                            data-detail-for="tratamiento"
                                            placeholder="Especifique medicamentos y dosis…"
                                            rows={2}
                                            maxlength="500"
                                            class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all hidden"
                                        />
                                    </div>
                                </div>

                                <div class="flex justify-between mt-8 max-w-4xl mx-auto">
                                    <button
                                        type="button"
                                        id="prev-step-profile-health"
                                        class="px-8 py-3 bg-gray-200 hover:bg-gray-300 text-gray-700 font-bold rounded-xl transition-all"
                                    >
                                        Anterior
                                    </button>
                                    <button
                                        type="button"
                                        id="next-step-profile-health"
                                        class="px-8 py-3 bg-secondary hover:bg-secondary/90 text-white font-bold rounded-xl transition-all shadow-lg hover:shadow-xl"
                                    >
                                        Siguiente
                                    </button>
                                </div>
                            </div>
                        </>
                    )
                }

                <!-- Step 2: Academic Background (dynamic multi-degree) -->
                {requiresDegreeSteps && (
                <div class="step-section p-8 md:p-12 hidden" id="step-2">
                    <div class="mb-8 text-center">
                        <div
                            class="inline-block p-4 bg-blue-50 rounded-2xl mb-4 text-primary"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-8 w-8"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    d="M12 14l9-5-9-5-9 5 9 5z"></path>
                                <path
                                    d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"
                                ></path>
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"
                                ></path>
                            </svg>
                        </div>
                        <p class="text-gray-600 text-sm max-w-2xl mx-auto">
                            Agregue todos sus grados académicos relevantes en orden cronológico.
                        </p>
                    </div>

                    <div class="max-w-4xl mx-auto">
                        <div
                            id="degree-requirements-info"
                            class="mb-6 p-4 bg-blue-50 border border-blue-200 rounded-xl text-sm text-blue-900"
                        >
                            <p class="font-semibold mb-1">
                                Requisitos mínimos para este programa:
                            </p>
                            <ul
                                id="degree-requirements-list"
                                class="list-disc ml-5"
                            >
                            </ul>
                        </div>

                        <div id="degrees-container" class="space-y-6">
                        </div>

                        <button
                            type="button"
                            id="add-degree-btn"
                            class="mt-6 inline-flex items-center gap-2 px-5 py-2.5 bg-blue-50 hover:bg-blue-100 text-primary font-semibold rounded-xl border-2 border-dashed border-primary/30 hover:border-primary/50 transition-all"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-5 w-5"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 4v16m8-8H4"></path>
                            </svg>
                            Agregar otro grado académico
                        </button>
                    </div>

                    <div class="flex justify-between mt-8 max-w-4xl mx-auto">
                        <button
                            type="button"
                            id="prev-step-2"
                            class="px-8 py-3 bg-gray-200 hover:bg-gray-300 text-gray-700 font-bold rounded-xl transition-all"
                        >
                            Anterior
                        </button>
                        <button
                            type="button"
                            id="next-step-2"
                            class="px-8 py-3 bg-secondary hover:bg-secondary/90 text-white font-bold rounded-xl transition-all shadow-lg hover:shadow-xl"
                        >
                            Siguiente
                        </button>
                    </div>
                </div>
                )}

                <!--
                    Degree entry template: cloned by the client script for each
                    degree row. `{{INDEX}}` is replaced with the 0-based index so
                    every field gets a stable, indexed name (`degree_0_grado`,
                    `degree_1_carrera`, etc.) that the API can enumerate.
                -->
                <template id="degree-entry-template">
                    <div
                        class="degree-entry p-6 bg-gray-50 border border-gray-200 rounded-2xl"
                        data-degree-index="{{INDEX}}"
                    >
                        <div
                            class="flex items-center justify-between mb-4 gap-4"
                        >
                            <h3 class="font-bold text-primary text-lg font-serif">
                                Grado académico <span
                                    class="degree-entry-number">{"#{{POSITION}}"}</span
                                >
                            </h3>
                            <button
                                type="button"
                                class="remove-degree-btn text-red-600 hover:text-red-800 text-sm font-semibold transition-colors inline-flex items-center gap-1 disabled:opacity-40 disabled:cursor-not-allowed"
                                data-index="{{INDEX}}"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-4 w-4"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3"
                                    ></path>
                                </svg>
                                Eliminar
                            </button>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label
                                    class="block text-sm font-semibold text-gray-700 mb-2"
                                    >Grado *</label
                                >
                                <select
                                    name="degree_{{INDEX}}_grado"
                                    required
                                    class="degree-grado w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                >
                                    <option value="">Seleccione...</option>
                                    <option value="Licenciatura"
                                        >Licenciatura</option
                                    >
                                    <option value="Especialidad"
                                        >Especialidad</option
                                    >
                                    <option value="Maestría">Maestría</option>
                                    <option value="Doctorado">Doctorado</option>
                                </select>
                            </div>

                            <div>
                                <label
                                    class="block text-sm font-semibold text-gray-700 mb-2"
                                    >Carrera o Programa *</label
                                >
                                <input
                                    type="text"
                                    name="degree_{{INDEX}}_carrera"
                                    required
                                    class="degree-carrera w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                    placeholder="Ej: Licenciatura en Derecho"
                                />
                            </div>

                            <div>
                                <label
                                    class="block text-sm font-semibold text-gray-700 mb-2"
                                    >Institución *</label
                                >
                                <input
                                    type="text"
                                    name="degree_{{INDEX}}_institucion"
                                    required
                                    class="degree-institucion w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                    placeholder="Nombre de la universidad"
                                />
                            </div>

                            <div>
                                <label
                                    class="block text-sm font-semibold text-gray-700 mb-2"
                                    >Número de Cédula Profesional *</label
                                >
                                <input
                                    type="text"
                                    name="degree_{{INDEX}}_cedulaNum"
                                    required
                                    maxlength="8"
                                    pattern="[0-9]{7,8}"
                                    inputmode="numeric"
                                    title="7 u 8 dígitos numéricos"
                                    class="degree-cedula-num w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all"
                                    placeholder="Ej: 12345678"
                                />
                            </div>
                        </div>
                    </div>
                </template>

                <!-- Step 3: Documents Upload (dynamic per-degree) -->
                <div class="step-section p-8 md:p-12 hidden" id="step-3">
                    <div class="mb-8 text-center">
                        <div
                            class="inline-block p-4 bg-blue-50 rounded-2xl mb-4 text-primary"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-8 w-8"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                                ></path>
                            </svg>
                        </div>
                        <p class="text-gray-600 text-sm max-w-2xl mx-auto">
                            {
                                requiresDegreeSteps ? (
                                    <>
                                        Adjunte los documentos requeridos. Se
                                        generará una sección por cada grado que
                                        agregó en el paso anterior.
                                    </>
                                ) : (
                                    <>
                                        Adjunte únicamente su curriculum vitae (CV)
                                        en el formato indicado.
                                    </>
                                )
                            }
                        </p>
                    </div>

                    <div class="max-w-4xl mx-auto space-y-8">
                        <div>
                            <h3 class="font-bold text-primary text-lg font-serif mb-3">
                                Documentos generales
                            </h3>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">
                                Curriculum Vitae (CV) *
                            </label>
                            <input
                                type="file"
                                name="cv"
                                required
                                accept=".pdf,.jpg,.jpeg,.png,.heic,.heif"
                                class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-primary hover:file:bg-blue-100"
                            />
                            <p class="text-xs text-gray-500 mt-1">
                                Formatos aceptados: PDF, JPG, PNG, HEIC (máx. 10 MB)
                            </p>
                        </div>

                        <div id="degree-documents-container" class="space-y-6">
                        </div>
                    </div>

                    <div id="form-status" class="hidden mt-6 p-4 rounded-xl text-sm max-w-4xl mx-auto"></div>

                    <!--
                        Per-degree documents template: cloned once for every degree
                        entry. Field names use the same `degree_{index}_...` prefix
                        as Step 2 so the API can correlate text fields with file
                        uploads by index.
                    -->
                    <template id="degree-documents-template">
                        <div
                            class="degree-documents p-6 bg-gray-50 border border-gray-200 rounded-2xl"
                            data-degree-index="{{INDEX}}"
                        >
                            <h4
                                class="font-bold text-primary text-base font-serif mb-4 degree-documents-title"
                            >
                                {"Documentos del grado #{{POSITION}}"}
                            </h4>

                            <div class="space-y-4">
                                <div>
                                    <label class="block text-sm font-semibold text-gray-700 mb-2">
                                        Título Profesional *
                                    </label>
                                    <input
                                        type="file"
                                        name="degree_{{INDEX}}_titulo"
                                        required
                                        accept=".pdf,.jpg,.jpeg,.png,.heic,.heif"
                                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-primary hover:file:bg-blue-100"
                                    />
                                    <p class="text-xs text-gray-500 mt-1">
                                        Formatos aceptados: PDF, JPG, PNG, HEIC (máx. 10 MB)
                                    </p>
                                </div>

                                <div>
                                    <label class="block text-sm font-semibold text-gray-700 mb-2">
                                        Cédula Profesional *
                                    </label>
                                    <input
                                        type="file"
                                        name="degree_{{INDEX}}_cedula"
                                        required
                                        accept=".pdf,.jpg,.jpeg,.png,.heic,.heif"
                                        class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-primary hover:file:bg-blue-100"
                                    />
                                    <p class="text-xs text-gray-500 mt-1">
                                        Formatos aceptados: PDF, JPG, PNG, HEIC (máx. 10 MB)
                                    </p>
                                </div>
                            </div>
                        </div>
                    </template>

                    <div class="flex justify-between mt-8 max-w-4xl mx-auto">
                        <button
                            type="button"
                            id="prev-step-3"
                            class="px-8 py-3 bg-gray-200 hover:bg-gray-300 text-gray-700 font-bold rounded-xl transition-all"
                        >
                            Anterior
                        </button>
                        <button
                            type="submit"
                            id="submit-btn"
                            class="px-8 py-3 bg-secondary hover:bg-secondary/90 text-white font-bold rounded-xl transition-all shadow-lg hover:shadow-xl flex items-center gap-2"
                        >
                            <span>Enviar Solicitud</span>
                            <svg
                                class="animate-spin h-5 w-5 text-white hidden"
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                id="loading-spinner"
                            >
                                <circle
                                    class="opacity-25"
                                    cx="12"
                                    cy="12"
                                    r="10"
                                    stroke="currentColor"
                                    stroke-width="4"></circle>
                                <path
                                    class="opacity-75"
                                    fill="currentColor"
                                    d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                                ></path>
