---
import Layout from "../../layouts/Layout.astro";
import { render } from "astro:content";
import IconList from "../../components/faculty/IconList.astro";
import {
    getFacultyMembers,
    getFacultySlug,
    type FacultyEntry,
} from "../../lib/faculty";

export async function getStaticPaths() {
    const members = await getFacultyMembers();
    return members.map((member) => ({
        params: { id: getFacultySlug(member) },
        props: { member },
    }));
}

interface Props {
    member: FacultyEntry;
}

const { member } = Astro.props;
const { Content } = await render(member);

const {
    name,
    degree,
    bio,
    fullBio,
    cargo_intro,
    area_especialidad,
    hito_profesional,
    trayectoria_academica,
    trayectoria_titulo,
    position_laboral,
    education,
    experience_institutional,
    image,
} = member.data;

/** Nuevo layout por bloques editoriales; basta con que exista cualquiera de estos campos. */
const usesStructuredProfile = Boolean(
    cargo_intro ||
    area_especialidad ||
    hito_profesional ||
    trayectoria_academica,
);

const trayectoriaHeading =
    (trayectoria_titulo && String(trayectoria_titulo).trim()) ||
    "Trayectoria Académica";

const hasMarkdownBody = (member.body ?? "").trim().length > 0;

const areaDisplay = area_especialidad ?? position_laboral;
const hitoFromSingleExperience =
    !hito_profesional && experience_institutional?.length === 1
        ? experience_institutional[0]
        : undefined;
const hitoDisplay = hito_profesional ?? hitoFromSingleExperience;
const hideExperienceListInStructured =
    Boolean(hito_profesional) || Boolean(hitoFromSingleExperience);

const seo = {
    title: `${name} | Docentes CEPRIJA`,
    description: cargo_intro || area_especialidad || fullBio || bio,
    image,
};
---

<Layout seo={seo}>
    <main class="py-20 bg-gray-50">
        <div class="container mx-auto px-6">
            <div
                class="max-w-4xl mx-auto bg-white rounded-2xl shadow-lg overflow-hidden"
            >
                <div class="md:grid md:grid-cols-12 md:items-stretch md:gap-0">
                    <div
                        class="relative h-96 w-full overflow-hidden border-b border-gray-100 md:col-span-4 md:h-full md:min-h-0 md:border-b-0 md:border-r"
                        data-animate="zoom-in"
                        data-delay="100"
                    >
                        <img
                            src={image}
                            alt={name}
                            class="h-full w-full object-cover object-top"
                        />
                    </div>
                    <div class="md:col-span-8 p-8 md:p-12">
                        <h1
                            class="text-3xl md:text-4xl font-bold text-primary mb-2 font-serif"
                            data-animate="fade-up"
                        >
                            {name}
                        </h1>
                        {
                            degree.trim().length > 0 && (
                                <p
                                    class="text-xl text-secondary font-medium mb-6"
                                    data-animate="fade-up"
                                    data-delay="100"
                                >
                                    {degree}
                                </p>
                            )
                        }

                        {
                            usesStructuredProfile ? (
                                <>
                                    {cargo_intro && (
                                        <p
                                            class="text-gray-600 leading-relaxed text-lg mb-8"
                                            data-animate="fade-up"
                                            data-delay="150"
                                        >
                                            {cargo_intro}
                                        </p>
                                    )}

                                    {areaDisplay && (
                                        <div
                                            class="mb-8"
                                            data-animate="fade-up"
                                            data-delay="200"
                                        >
                                            <h2 class="text-lg font-bold text-gray-800 mb-3 border-b pb-2 font-serif">
                                                Área de Especialidad
                                            </h2>
                                            <p class="text-gray-600 leading-relaxed text-lg">
                                                {areaDisplay}
                                            </p>
                                        </div>
                                    )}

                                    {hitoDisplay && (
                                        <div
                                            class="mb-8"
                                            data-animate="fade-up"
                                            data-delay="250"
                                        >
                                            <h2 class="text-lg font-bold text-gray-800 mb-3 border-b pb-2 font-serif">
                                                Hito Profesional
                                            </h2>
                                            <p class="text-gray-600 leading-relaxed text-lg">
                                                {hitoDisplay}
                                            </p>
                                        </div>
                                    )}

                                    <div
                                        class="mb-8"
                                        data-animate="fade-up"
                                        data-delay="300"
                                    >
                                        <h2 class="text-lg font-bold text-gray-800 mb-3 border-b pb-2 font-serif">
                                            {trayectoriaHeading}
                                        </h2>
                                        {trayectoria_academica ? (
                                            <p class="text-gray-600 leading-relaxed text-lg whitespace-pre-line">
                                                {trayectoria_academica}
                                            </p>
                                        ) : hasMarkdownBody ? (
                                            <div class="prose prose-lg max-w-none text-gray-600 leading-relaxed">
                                                <Content />
                                            </div>
                                        ) : (
                                            <p class="text-gray-600 leading-relaxed text-lg">
                                                {fullBio || bio}
                                            </p>
                                        )}
                                    </div>

                                    {education && education.length > 0 && (
                                        <IconList
                                            title="Formación Académica"
                                            items={education}
                                        />
                                    )}

                                    {experience_institutional &&
                                        experience_institutional.length > 0 &&
                                        !hideExperienceListInStructured && (
                                            <IconList
                                                title="Docencia en"
                                                items={experience_institutional}
                                            />
                                        )}
                                </>
                            ) : (
                                <>
                                    <div
                                        class="mb-8"
                                        data-animate="fade-up"
                                        data-delay="200"
                                    >
                                        <h2 class="text-lg font-bold text-gray-800 mb-3 border-b pb-2 font-serif">
                                            Trayectoria
                                        </h2>
                                        {hasMarkdownBody ? (
                                            <div class="prose prose-lg max-w-none text-gray-600 leading-relaxed">
                                                <Content />
                                            </div>
                                        ) : (
                                            <p class="text-gray-600 leading-relaxed text-lg">
                                                {fullBio || bio}
                                            </p>
                                        )}
                                    </div>

                                    {position_laboral && (
                                        <div
                                            data-animate="fade-up"
                                            data-delay="200"
                                        >
                                            <h2 class="text-lg font-bold text-gray-800 mb-3 border-b pb-2 font-serif">
                                                Cargo
                                            </h2>
                                            <p class="text-gray-600 leading-relaxed text-lg mb-8">
                                                {position_laboral}
                                            </p>
                                        </div>
                                    )}

                                    {education && education.length > 0 && (
                                        <IconList
                                            title="Formación Académica"
                                            items={education}
                                        />
                                    )}

                                    {experience_institutional &&
                                        experience_institutional.length > 0 && (
                                            <IconList
                                                title="Docencia en"
                                                items={experience_institutional}
                                            />
                                        )}
                                </>
                            )
                        }

                        <div
                            class="mt-10 pt-6 border-t border-gray-100"
                            data-animate="fade-up"
                            data-delay="400"
                        >
                            <a
                                href="/docentes"
                                class="inline-flex items-center text-primary font-medium hover:text-secondary transition-colors"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-5 w-5 mr-2"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    aria-hidden="true"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                                </svg>
                                Volver a Docentes
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</Layout>
