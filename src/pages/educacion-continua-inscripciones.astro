---
/**
 * Entrada histórica al hub de EC. Flujo canónico: /oferta-academica → ficha del programa.
 * Mantiene enlaces viejos: ?id=<slug> → ficha; ?programa=<slug o título> → ficha si coincide;
 * sin query → índice de oferta.
 */
export const prerender = false;

import { getCollection } from "astro:content";
import { programIsPublished } from "@lib/programPublished";
import { getProgramPathSlug } from "@lib/programPaths";

const id = Astro.url.searchParams.get("id")?.trim() ?? "";
const programa = Astro.url.searchParams.get("programa")?.trim() ?? "";

const programs =
    id || programa ? await getCollection("programas") : [];

if (id) {
    const byId = programs.find((p) => getProgramPathSlug(p) === id);
    if (byId && programIsPublished(byId)) {
        return Astro.redirect(
            `/oferta-academica/${encodeURIComponent(getProgramPathSlug(byId))}`,
            301,
        );
    }
    return Astro.redirect("/oferta-academica", 301);
}

if (programa) {
    const bySlug = programs.find((p) => getProgramPathSlug(p) === programa);
    if (bySlug && programIsPublished(bySlug)) {
        return Astro.redirect(`/oferta-academica/${encodeURIComponent(getProgramPathSlug(bySlug))}`, 301);
    }
    const normalize = (s: string) =>
        s
            .toLowerCase()
            .normalize("NFD")
            .replace(/\p{M}/gu, "")
            .replace(/\s+/g, " ")
            .trim();
    const q = normalize(programa);
    const byTitle = programs.find((p) => normalize(p.data.title) === q);
    if (byTitle && programIsPublished(byTitle)) {
        return Astro.redirect(`/oferta-academica/${encodeURIComponent(getProgramPathSlug(byTitle))}`, 301);
    }
}

return Astro.redirect("/oferta-academica", 301);
---
