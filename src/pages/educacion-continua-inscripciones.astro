---
/**
 * Entrada histórica al hub de EC. Flujo canónico: /oferta-academica → ficha del programa.
 * Mantiene enlaces viejos: ?id=<slug> → ficha; ?programa=<slug o título> → ficha si coincide;
 * sin query → índice de oferta.
 */
export const prerender = false;

import { getCollection } from "astro:content";

const id = Astro.url.searchParams.get("id")?.trim() ?? "";
const programa = Astro.url.searchParams.get("programa")?.trim() ?? "";

if (id) {
    return Astro.redirect(`/oferta-academica/${encodeURIComponent(id)}`, 301);
}

if (programa) {
    const programs = await getCollection("programas");
    const bySlug = programs.find((p) => p.slug === programa);
    if (bySlug) {
        return Astro.redirect(`/oferta-academica/${encodeURIComponent(bySlug.slug)}`, 301);
    }
    const normalize = (s: string) =>
        s
            .toLowerCase()
            .normalize("NFD")
            .replace(/\p{M}/gu, "")
            .replace(/\s+/g, " ")
            .trim();
    const q = normalize(programa);
    const byTitle = programs.find((p) => normalize(p.data.title) === q);
    if (byTitle) {
        return Astro.redirect(`/oferta-academica/${encodeURIComponent(byTitle.slug)}`, 301);
    }
}

return Astro.redirect("/oferta-academica", 301);
---
