---
import Layout from "../layouts/Layout.astro";

const programs = [
  {
    title: "Capacitación Empresarial",
    description:
      "Programas diseñados para fortalecer habilidades técnicas y humanas dentro de las organizaciones.",
    icon: "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10",
  },
  {
    title: "Cursos In Company",
    description:
      "Formación personalizada para equipos de trabajo adaptada a las necesidades de cada empresa.",
    icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
  },
  {
    title: "Liderazgo y Desarrollo",
    description:
      "Entrenamientos orientados al crecimiento de líderes y mandos estratégicos.",
    icon: "M13 7h8m0 0v8m0-8l-8 8-4-4-6 6",
  },
  {
    title: "Certificaciones",
    description:
      "Programas certificados con enfoque práctico y aplicación inmediata.",
    icon: "M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z",
  },
];
---

<Layout title="Educación Corporativa | CEPRIJA">
  <main>
    {/* HERO */}
    <section class="bg-primary text-white py-24">
      <div class="container mx-auto px-6 text-center">
        <h1 class="text-5xl font-bold font-serif mb-6" data-animate="fade-up">
          Educación Corporativa
        </h1>

        <p
          class="max-w-3xl mx-auto text-lg text-white/90"
          data-animate="fade-up"
          data-delay="100"
        >
          Impulsamos el desarrollo profesional de empresas y organizaciones
          mediante programas de formación innovadores, prácticos y adaptados a
          los retos actuales del mercado.
        </p>
      </div>
    </section>

    {/* INTRO */}
    <section class="py-20 bg-white">
      <div class="container mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          {/* IMAGE */}
          <div data-animate="fade-right">
            <img
              src="/images/branding/corporateEducation/corporate1.jpg"
              alt="Formación empresarial"
              class="w-full h-[450px] object-cover rounded-2xl shadow-lg"
            />
          </div>

          {/* CONTENT */}
          <div data-animate="fade-left">
            <h2 class="text-3xl font-bold text-primary font-serif mb-6">
              Formación diseñada para transformar equipos
            </h2>

            <p class="text-gray-600 leading-relaxed text-lg mb-6">
              En CEPRIJA desarrollamos experiencias de aprendizaje enfocadas en
              resultados reales. Nuestros programas combinan metodología
              práctica, innovación y acompañamiento especializado para potenciar
              el talento dentro de las organizaciones.
            </p>

            <p class="text-gray-600 leading-relaxed">
              Creamos soluciones flexibles para empresas que buscan fortalecer
              competencias, liderazgo y desempeño en un entorno competitivo y en
              constante evolución.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* PROGRAMS */}
    <section class="py-20 bg-gray-50">
      <div class="container mx-auto px-6">
        <div class="text-center mb-14">
          <h2
            class="text-3xl font-bold text-primary font-serif"
            data-animate="fade-up"
          >
            Nuestros Programas
          </h2>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {
            programs.map((program, index) => (
              <div
                class="bg-white rounded-2xl p-8 shadow hover:shadow-xl transition"
                data-animate="fade-up"
                data-delay={index * 100}
              >
                <div
                  class="w-14 h-14 bg-blue-50 rounded-full flex items-center justify-center mb-4"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-7 w-7 text-primary"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d={program.icon}
                    />
                  </svg>
                </div>

                <h3 class="text-xl font-bold text-primary mb-3">
                  {program.title}
                </h3>

                <p class="text-gray-600 text-sm leading-relaxed">
                  {program.description}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    {/* BENEFITS */}
    <section class="py-20 bg-white">
      <div class="container mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div data-animate="fade-right">
            <img
              src="/images/branding/site/ceprija_02.webp"
              alt="Educación Corporativa"
              class="rounded-2xl shadow-lg object-cover w-full"
            />
          </div>

          <div data-animate="fade-left">
            <h2 class="text-3xl font-bold text-primary font-serif mb-6">
              ¿Por qué elegirnos?
            </h2>

            <ul class="space-y-5 text-gray-700">
              <li class="flex items-start gap-3">
                <span class="text-primary text-xl">✔</span>
                <span
                  >Programas personalizados según las necesidades de la empresa.</span
                >
              </li>

              <li class="flex items-start gap-3">
                <span class="text-primary text-xl">✔</span>
                <span
                  >Docentes y especialistas con experiencia profesional.</span
                >
              </li>

              <li class="flex items-start gap-3">
                <span class="text-primary text-xl">✔</span>
                <span>Metodologías prácticas y orientadas a resultados.</span>
              </li>

              <li class="flex items-start gap-3">
                <span class="text-primary text-xl">✔</span>
                <span>Modalidades presencial, híbrida y virtual.</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* CTA */}
    <section class="py-24 bg-primary text-white">
      <div class="container mx-auto px-6 text-center">
        <h2 class="text-4xl font-bold font-serif mb-6" data-animate="fade-up">
          Lleva la capacitación de tu empresa al siguiente nivel
        </h2>

        <p
          class="max-w-2xl mx-auto text-white/90 mb-10"
          data-animate="fade-up"
          data-delay="100"
        >
          Contáctanos y diseñemos juntos un programa de formación alineado con
          los objetivos de tu organización.
        </p>

        <a
          href="/contacto"
          class="inline-flex items-center justify-center bg-white text-primary font-bold px-8 py-4 rounded-full hover:bg-gray-100 transition"
          data-animate="fade-up"
          data-delay="200"
        >
          Solicitar información
        </a>
      </div>
    </section>
  </main>
</Layout>
