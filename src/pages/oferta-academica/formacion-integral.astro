---
import Layout from "../../layouts/Layout.astro";
import Button from "@components/ui/Button.astro";
import SchoolAreaProgramList from "@components/program/SchoolAreaProgramList.astro";
import SchoolAreaCover from "@components/program/SchoolAreaCover.astro";
---

<Layout pageId="integral">
    <main class="bg-gray-50 min-h-screen py-12">
        <div class="container mx-auto px-6">
            <div class="text-center mb-16" data-animate="fade-up">
                <span
                    class="text-secondary font-bold tracking-wider uppercase text-sm"
                    >Excelencia Académica</span
                >
                <h1
                    class="text-4xl md:text-5xl font-bold text-primary mt-2 mb-6 font-serif"
                >
                    Formación Integral
                </h1>
                <p class="text-xl text-gray-600 max-w-2xl mx-auto">
                    Cursos, talleres y seminarios para complementar tu perfil
                    profesional y humano.
                </p>
            </div>

            <SchoolAreaProgramList
                escuela="integral"
                emptyHint="No hay programas con escuela “integral” en el CMS. Revisa el frontmatter `escuela: integral` en `src/content/programas/`. En condiciones normales esta área solo publica el seminario de psicometría y el taller de redacción de contratos."
            />

            <div class="mt-20 text-center">
                <p class="text-gray-600 mb-6">
                    ¿Te interesa algún curso o taller en específico?
                </p>
                <Button
                    href="/contacto"
                    id="submit-btn-integral"
                    variant="primary"
                    class="inline-block bg-primary text-white font-bold py-3 px-8 hover:bg-blue-900 transition-colors shadow-lg hover:shadow-xl"
                >
                    Contáctanos
                </Button>
            </div>
        </div>
    </main>
</Layout>
