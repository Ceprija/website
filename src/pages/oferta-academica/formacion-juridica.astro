---
import Layout from "../../layouts/Layout.astro";
import Button from "@components/ui/Button.astro";
import SchoolAreaProgramList from "@components/program/SchoolAreaProgramList.astro";
import SchoolAreaCover from "@components/program/SchoolAreaCover.astro";
---

<Layout pageId="juridica">
    <main class="bg-gray-50 min-h-screen py-12">
        <div class="container mx-auto px-6">
            <div class="text-center mb-16" data-animate="fade-up">
                <span
                    class="text-secondary font-bold tracking-wider uppercase text-sm"
                    >Excelencia Académica</span
                >
                <h1
                    class="text-5xl font-bold text-primary mt-2 mb-6 font-serif"
                >
                    Formación Jurídica
                </h1>
                <p class="text-xl text-gray-600 max-w-2xl mx-auto">
                    Programas diseñados para el mundo real, combinando teoría
                    rigurosa con práctica profesional. Listado desde el mismo
                    contenido que las fichas.
                </p>
            </div>

            <SchoolAreaProgramList
                escuela="juridica"
                emptyHint="No hay programas con escuela “juridica” en el CMS. Revisa `escuela: juridica` en `src/content/programas/`."
                sectionGroups={[
                    {
                        title: "Educación continua",
                        niveles: ["diplomado", "curso", "taller"],
                    },
                    {
                        title: "Posgrados",
                        niveles: ["maestria", "doctorado", "especialidad"],
                    },
                ]}
            />

            <div class="mt-20 text-center">
                <p class="text-gray-600 mb-6">
                    ¿No encuentras lo que buscas? Contáctanos para asesoría
                    personalizada.
                </p>
                <Button
                    href="/contacto"
                    id="submit-btn-juridica"
                    variant="primary"
                    class="inline-block bg-primary text-white font-bold py-3 px-8 hover:bg-blue-900 transition-colors shadow-lg hover:shadow-xl"
                >
                    Hablar con un asesor
                </Button>
            </div>
        </div>
    </main>
</Layout>
