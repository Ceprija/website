---
import Layout from "../../layouts/Layout.astro";
import Button from "@components/ui/Button.astro";
import SchoolAreaProgramList from "@components/program/SchoolAreaProgramList.astro";
import SchoolAreaCover from "@components/program/SchoolAreaCover.astro";
---

<Layout pageId="administrativa">
    <main class="bg-gray-50 min-h-screen py-12">
        <div class="container mx-auto px-6">
            <div class="text-center mb-16" data-animate="fade-up">
                <span
                    class="text-secondary font-bold tracking-wider uppercase text-sm"
                    >Excelencia Académica</span
                >
                <h1
                    class="text-4xl md:text-5xl font-bold text-primary mt-2 mb-6 font-serif"
                >
                    Formación Económico-Administrativa
                </h1>
                <p class="text-xl text-gray-600 max-w-2xl mx-auto">
                    Desarrolla habilidades gerenciales, fiscales y estratégicas
                    con visión ética y productiva. Listado alimentado por el
                    mismo contenido que las fichas de programa.
                </p>
            </div>

            <SchoolAreaProgramList
                escuela="economica"
                emptyHint="No hay programas con escuela “economica” en el CMS. Asigna `escuela: economica` en `src/content/programas/` para cursos de esta área (fiscal, finanzas, SAT, etc.). Esta vista ya no usa archivos estáticos en `src/data/`."
            />

            <div class="mt-20 text-center">
                <p class="text-gray-600 mb-6">
                    ¿Dudas sobre cuál es el mejor programa para ti?
                </p>
                <Button
                    href="/contacto"
                    id="submit-btn-admin"
                    variant="primary"
                    class="inline-block bg-primary text-white font-bold py-3 px-8 hover:bg-blue-900 transition-colors shadow-lg hover:shadow-xl"
                >
                    Hablar con un asesor
                </Button>
            </div>
        </div>
    </main>
</Layout>
