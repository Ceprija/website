---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import ContactForm from "@components/forms/ContactForm.astro";
import ContinuousEducationForm from "@components/forms/ContinuousEducationForm.astro";
import ProgramEnrollmentAsideCard from "@components/program/ProgramEnrollmentAsideCard.astro";
import { getProgramPathSlug, validateUniqueSlugs } from "@lib/programPaths";
import { getEnrollmentFlow } from "@lib/enrollmentRouting";
import { getVariantOptions } from "@lib/programVariants";
import { programMetaDescriptionSuffix } from "../../data/config/seo.js";
import { filterPublishedPrograms } from "@lib/programPublished";
import { 
    getPaymentOptions, 
    getStripePriceIds, 
    getDisplayPrices,
    getProgramStatus,
    formatPrice 
} from "@lib/programPayments";

export async function getStaticPaths() {
    const programs = await getCollection("programas");
    validateUniqueSlugs(programs);
    return filterPublishedPrograms(programs).map((program) => ({
        params: { slug: getProgramPathSlug(program) },
        props: { program },
    }));
}

const { program } = Astro.props;

const programStatus = getProgramStatus(program);
const enrollmentFlow = getEnrollmentFlow(program);
const programSlug = getProgramPathSlug(program);

/** Narrow optional arrays/objects so Astro/TS templates stay type-safe when schema inference is loose. */
type CurriculumPeriod = {
    period: string;
    subjects: string[];
    description?: string;
    professors?: string[];
};
const data = program.data;
const curriculumItems: CurriculumPeriod[] = Array.isArray(data.curriculum)
    ? (data.curriculum as CurriculumPeriod[])
    : [];
const includesItems: string[] = Array.isArray(data.includes)
    ? (data.includes as string[])
    : [];
const prerequisitesItems: string[] = Array.isArray(data.prerequisites)
    ? (data.prerequisites as string[])
    : [];
// Extract payment data using new helper functions (with backward compatibility)
const paymentOptions = getPaymentOptions(program);
const stripePriceIdsForCheckout = getStripePriceIds(program);
const continuousEducationPrices = getDisplayPrices(program);
const programAddress =
    typeof data.address === "string" ? data.address : undefined;
const programRequiresVerification = Boolean(data.requiresVerification);
const registroAcademico =
    typeof data.registroAcademico === "string"
        ? data.registroAcademico.trim()
        : "";
const variantOptions = getVariantOptions(program);
const variantModuleOptions = variantOptions?.moduleSelection?.options ?? [];

const descriptionPlain = String(data.description ?? "").trim();
const seo = {
    title: `${String(data.title)} | CEPRIJA`,
    description:
        descriptionPlain.length > 0
            ? `${descriptionPlain}${programMetaDescriptionSuffix}`
            : descriptionPlain,
};
/** Encuadre del hero con cover; sin `imagePosition` equivale al comportamiento por defecto del navegador (`center center`). */
const heroObjectPosition =
    typeof data.imagePosition === "string" &&
    data.imagePosition.trim().length > 0
        ? data.imagePosition.trim()
        : "center center";
---

<Layout seo={seo}>
    <main class="bg-gray-50 min-h-screen">
        <!-- Hero Section -->
        <section
            class="relative text-white py-20 min-h-[400px] flex items-center"
        >
            <div class="absolute inset-0 z-0">
                <img
                    src={String(data.image)}
                    alt={String(data.title)}
                    class="w-full h-full object-cover"
                    style={`object-position: ${heroObjectPosition}`}
                />
            </div>
            <!-- Gradiente: más opaco arriba (zona de título) para sostener texto blanco sobre fotos claras. -->
            <div
                class="absolute inset-0 z-0 pointer-events-none bg-gradient-to-b from-blue-950/90 via-blue-950/72 to-blue-950/50"
                aria-hidden="true"
            />
            <div class="container mx-auto px-6 relative z-10">
                <div class="max-w-4xl">
                    <span
                        class="bg-black/35 ring-1 ring-white/25 backdrop-blur-sm text-white text-sm font-bold px-4 py-2 rounded-full uppercase tracking-wide inline-block mb-4 shadow-sm"
                        data-animate="fade-up"
                    >
                        {program.data.nivel}
                    </span>
                    <h1
                        class="text-4xl font-bold mb-6 font-serif text-white drop-shadow-[0_2px_16px_rgba(0,0,0,0.45)]"
                        data-animate="fade-up"
                        data-delay="100"
                    >
                        {program.data.title}
                    </h1>
                    <p
                        class="text-xl text-gray-100 mb-8 drop-shadow-[0_1px_8px_rgba(0,0,0,0.4)]"
                        data-animate="fade-up"
                        data-delay="200"
                    >
                        {program.data.description}
                    </p>

                    <div
                        class="flex flex-wrap gap-6 text-sm drop-shadow-[0_1px_8px_rgba(0,0,0,0.35)]"
                        data-animate="fade-up"
                        data-delay="300"
                    >
                        {
                            program.data.rvoe && (
                                <div class="flex items-center gap-2">
                                    <span>RVOE: </span>
                                    <span class="italic font-bold">
                                        {program.data.rvoe}
                                    </span>
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-5 w-5"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                        />
                                    </svg>
                                </div>
                            )
                        }

                        {
                            registroAcademico && (
                                <div class="flex items-center gap-2">
                                    <span>Registro: </span>
                                    <span class="italic font-bold">
                                        {registroAcademico}
                                    </span>
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-5 w-5"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                        />
                                    </svg>
                                </div>
                            )
                        }

                        {
                            program.data.startDate && (
                                <div class="flex items-center gap-2">
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-5 w-5"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                                        />
                                    </svg>
                                    <span class="font-bold">
                                        {program.data.startDate}
                                    </span>
                                </div>
                            )
                        }

                        <div class="flex items-center gap-2">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-5 w-5"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path>
                            </svg>
                            <span>{program.data.duracion}</span>
                        </div>

                        {
                            program.data.horario && (
                                <div class="flex items-center gap-2">
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-5 w-5"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                        />
                                    </svg>
                                    <span>{program.data.horario}</span>
                                </div>
                            )
                        }

                        <div class="flex items-center gap-2">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-5 w-5"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                ></path>
                            </svg>
                            <span>{program.data.modalidad}</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Content Section: información del programa a ancho legible -->
        <section class="py-16">
            <div class="container mx-auto px-6 max-w-4xl">
                <div class="space-y-12">
                    <!-- Plan de Estudios -->
                    {
                        curriculumItems.length > 0 && (
                            <div
                                class="bg-white rounded-2xl shadow-sm p-8"
                                data-animate="fade-up"
                                data-delay="100"
                            >
                                <h2 class="text-3xl font-bold text-primary mb-6 font-serif flex items-center gap-3">
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-8 w-8 text-secondary"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                                        />
                                    </svg>
                                    {program.data.curriculumTitle ||
                                        "Plan de Estudios"}
                                </h2>
                                <div class="space-y-4">
                                    {curriculumItems.map(
                                        (semester, modIndex) => {
                                            const profs = Array.isArray(
                                                semester.professors,
                                            )
                                                ? semester.professors.filter(
                                                      (p) =>
                                                          typeof p ===
                                                              "string" &&
                                                          p.trim(),
                                                  )
                                                : [];
                                            return (
                                                <details
                                                    class="group border border-gray-200 rounded-xl bg-gray-50/80 shadow-sm overflow-hidden open:shadow-md transition-shadow"
                                                    open={modIndex === 0}
                                                >
                                                    <summary class="cursor-pointer list-none flex items-center justify-between gap-4 px-5 py-4 font-serif text-lg md:text-xl font-bold text-primary hover:bg-white/80 transition-colors [&::-webkit-details-marker]:hidden">
                                                        <span class="text-left">
                                                            {semester.period}
                                                        </span>
                                                        <svg
                                                            xmlns="http://www.w3.org/2000/svg"
                                                            class="h-6 w-6 text-secondary shrink-0 transition-transform duration-200 group-open:rotate-180"
                                                            fill="none"
                                                            viewBox="0 0 24 24"
                                                            stroke="currentColor"
                                                            aria-hidden="true"
                                                        >
                                                            <path
                                                                stroke-linecap="round"
                                                                stroke-linejoin="round"
                                                                stroke-width="2"
                                                                d="M19 9l-7 7-7-7"
                                                            />
                                                        </svg>
                                                    </summary>
                                                    <div class="px-5 pb-5 pt-0 border-t border-gray-200/80 bg-white space-y-5">
                                                        {semester.description?.trim() && (
                                                            <p class="text-gray-700 leading-relaxed text-base pt-4">
                                                                {semester.description.trim()}
                                                            </p>
                                                        )}
                                                        {profs.length > 0 && (
                                                            <div>
                                                                <h4 class="text-xs font-bold text-primary uppercase tracking-wider mb-2">
                                                                    Docentes
                                                                </h4>
                                                                <ul class="space-y-1.5 text-gray-700">
                                                                    {profs.map(
                                                                        (p) => (
                                                                            <li class="flex items-start gap-2">
                                                                                <span
                                                                                    class="mt-1.5 h-1.5 w-1.5 rounded-full bg-secondary shrink-0"
                                                                                    aria-hidden="true"
                                                                                />
                                                                                <span>
                                                                                    {p.trim()}
                                                                                </span>
                                                                            </li>
                                                                        ),
                                                                    )}
                                                                </ul>
                                                            </div>
                                                        )}
                                                        <div>
                                                            <h4 class="text-xs font-bold text-primary uppercase tracking-wider mb-3">
                                                                Temas
                                                            </h4>
                                                            <div class="grid md:grid-cols-2 gap-3">
                                                                {semester.subjects.map(
                                                                    (
                                                                        subject,
                                                                        subIndex,
                                                                    ) => (
                                                                        <div class="flex items-start gap-3 p-3 bg-gray-50 rounded-lg border border-gray-100 hover:border-secondary/30 hover:bg-blue-50/50 transition-colors">
                                                                            <span class="flex-shrink-0 w-6 h-6 bg-secondary text-primary rounded-full flex items-center justify-center text-xs font-bold">
                                                                                {subIndex +
                                                                                    1}
                                                                            </span>
                                                                            <span class="flex flex-col gap-1.5 text-sm md:text-base leading-snug">
                                                                                {subject.includes(
                                                                                    "\n",
                                                                                ) ? (
                                                                                    subject
                                                                                        .split(
                                                                                            "\n",
                                                                                        )
                                                                                        .map(
                                                                                            (
                                                                                                line,
                                                                                            ) =>
                                                                                                line.trim(),
                                                                                        )
                                                                                        .filter(
                                                                                            Boolean,
                                                                                        )
                                                                                        .map(
                                                                                            (
                                                                                                line,
                                                                                                lineIdx,
                                                                                            ) => (
                                                                                                <span
                                                                                                    class:list={[
                                                                                                        lineIdx ===
                                                                                                        0
                                                                                                            ? "font-bold text-primary"
                                                                                                            : "text-gray-700 font-medium",
                                                                                                    ]}
                                                                                                >
                                                                                                    {
                                                                                                        line
                                                                                                    }
                                                                                                </span>
                                                                                            ),
                                                                                        )
                                                                                ) : (
                                                                                    <span class="text-gray-700 font-medium">
                                                                                        {
                                                                                            subject
                                                                                        }
                                                                                    </span>
                                                                                )}
                                                                            </span>
                                                                        </div>
                                                                    ),
                                                                )}
                                                            </div>
                                                        </div>
                                                    </div>
                                                </details>
                                            );
                                        },
                                    )}
                                </div>
                            </div>
                        )
                    }
                    <!-- Perfil del Egresado -->
                    {
                        program.data.profile && (
                            <div
                                class="bg-white rounded-2xl shadow-sm p-8"
                                data-animate="fade-up"
                                data-delay="200"
                            >
                                <h2 class="text-3xl font-bold text-primary mb-6 font-serif flex items-center gap-3">
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-8 w-8 text-secondary"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                                        />
                                    </svg>
                                    Perfil del Egresado
                                </h2>
                                <p class="text-gray-700 leading-relaxed text-lg">
                                    {program.data.profile}
                                </p>
                            </div>
                        )
                    }
                    <!-- Dirigido a -->
                    {
                        program.data.profileAudience && (
                            <div
                                class="bg-white rounded-2xl shadow-sm p-8"
                                data-animate="fade-up"
                                data-delay="200"
                            >
                                <h2 class="text-3xl font-bold text-primary mb-6 font-serif flex items-center gap-3">
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-8 w-8 text-secondary"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                                        />
                                    </svg>
                                    Dirigido a
                                </h2>
                                <p class="text-gray-700 leading-relaxed text-lg">
                                    {program.data.profileAudience}
                                </p>
                            </div>
                        )
                    }

                    <!-- Campo Laboral -->
                    {
                        program.data.fieldOfWork && (
                            <div
                                class="bg-white rounded-2xl shadow-sm p-8"
                                data-animate="fade-up"
                                data-delay="300"
                            >
                                <h2 class="text-3xl font-bold text-primary mb-6 font-serif flex items-center gap-3">
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-8 w-8 text-secondary"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                        />
                                    </svg>
                                    Campo Laboral
                                </h2>
                                <p class="text-gray-700 leading-relaxed text-lg">
                                    {program.data.fieldOfWork}
                                </p>
                            </div>
                        )
                    }

                    {
                        (paymentOptions.length > 0 || program.data.price) && (
                            <div
                                class="bg-white rounded-2xl shadow-sm p-8"
                                data-animate="fade-up"
                                data-delay="400"
                            >
                                <h2 class="text-3xl font-bold text-primary mb-6 font-serif flex items-center gap-3">
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-8 w-8 text-secondary"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                                        />
                                    </svg>
                                    Inversión
                                </h2>
                                {paymentOptions.length > 0 ? (
                                    <div class="space-y-4">
                                        {paymentOptions.map((option) => (
                                            <div class="flex justify-between items-center border-b border-gray-100 pb-2">
                                                <span class="text-gray-600 font-medium">
                                                    {option.label}:
                                                </span>
                                                <span class="text-primary font-bold text-lg">
                                                    {formatPrice(option.price)}
                                                </span>
                                            </div>
                                        ))}
                                    </div>
                                ) : typeof program.data.price === "object" ? (
                                    <div class="space-y-4">
                                        {Object.entries(program.data.price).map(
                                            ([key, value]) => (
                                                <div class="flex justify-between items-center border-b border-gray-100 pb-2">
                                                    <span class="text-gray-600 font-medium capitalize">
                                                        {key}:
                                                    </span>
                                                    <span class="text-primary font-bold text-lg">
                                                        {value}
                                                    </span>
                                                </div>
                                            ),
                                        )}
                                    </div>
                                ) : (
                                    <p class="text-primary font-bold text-2xl">
                                        ${program.data.price}
                                    </p>
                                )}
                                {variantModuleOptions.length > 0 && (
                                    <p class="mt-6 text-sm text-gray-600 leading-relaxed">
                                        Selecciona el módulo o paquete y la
                                        fecha de inicio durante el proceso de
                                        inscripción.
                                    </p>
                                )}
                            </div>
                        )
                    }

                    {
                        includesItems.length > 0 && (
                            <div
                                class="bg-white rounded-2xl shadow-sm p-8"
                                data-animate="fade-up"
                                data-delay="500"
                            >
                                <h2 class="text-3xl font-bold text-primary mb-6 font-serif flex items-center gap-3">
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-8 w-8 text-secondary"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                        />
                                    </svg>
                                    Incluye
                                </h2>
                                <ul class="space-y-2">
                                    {includesItems.map((item) => (
                                        <li class="flex items-center gap-2 text-gray-700">
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                class="h-5 w-5 text-secondary"
                                                viewBox="0 0 20 20"
                                                fill="currentColor"
                                            >
                                                <path
                                                    fill-rule="evenodd"
                                                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                                    clip-rule="evenodd"
                                                />
                                            </svg>
                                            {item}
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        )
                    }

                    {
                        prerequisitesItems.length > 0 && (
                            <div
                                class="bg-white rounded-2xl shadow-sm p-8"
                                data-animate="fade-up"
                                data-delay="550"
                            >
                                <h2 class="text-3xl font-bold text-primary mb-6 font-serif flex items-center gap-3">
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-8 w-8 text-secondary"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"
                                        />
                                    </svg>
                                    Requisitos previos
                                </h2>
                                <ul class="space-y-2">
                                    {prerequisitesItems.map((item) => (
                                        <li class="flex items-center gap-2 text-gray-700">
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                class="h-5 w-5 text-secondary"
                                                viewBox="0 0 20 20"
                                                fill="currentColor"
                                            >
                                                <path
                                                    fill-rule="evenodd"
                                                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                                    clip-rule="evenodd"
                                                />
                                            </svg>
                                            {item}
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        )
                    }
                </div>
            </div>
        </section>

        <!-- Inscripción / admisión: sin data-animate aquí — el transform del fade-up
             hace que position:fixed de descendientes se ancle al section y el pie
             del formulario desaparezca. `enrollmentFlow: inline` en el .md sigue
             gobernado por getEnrollmentFlow(). -->
        <section class="py-16 pb-20 border-t border-gray-200 bg-gray-50/80">
            <div class="container mx-auto px-6 max-w-4xl lg:max-w-5xl">
                {
                    programStatus === "waitlist" ? (
                        <div class="max-w-4xl mx-auto">
                            <div class="bg-white rounded-3xl shadow-xl p-8 md:p-12">
                                <div class="text-center mb-8">
                                    <div class="inline-block p-4 bg-amber-50 rounded-2xl mb-4">
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            class="h-12 w-12 text-amber-500"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke="currentColor"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                            />
                                        </svg>
                                    </div>
                                    <h3 class="text-2xl md:text-3xl font-bold text-primary mb-4 font-serif">
                                        Próximamente Disponible
                                    </h3>
                                    <p class="text-gray-600 text-lg leading-relaxed max-w-2xl mx-auto">
                                        Este programa no está actualmente en calendario.
                                        Déjanos tus datos y te contactaremos cuando abramos inscripciones.
                                    </p>
                                </div>
                                <ContactForm programTitle={String(data.title)} />
                            </div>
                        </div>
                    ) : enrollmentFlow === "application" ? (
                        <ProgramEnrollmentAsideCard
                            sticky={false}
                            class="shadow-xl"
                        >
                            <h3 class="text-2xl font-bold text-primary mb-2 font-serif">
                                Proceso de Admisión
                            </h3>
                            <p class="text-gray-600 mb-6 text-sm">
                                Este programa requiere un proceso formal de
                                admisión con documentación académica.
                            </p>

                            <div class="space-y-3 mb-6 text-sm">
                                <div class="flex items-start gap-2">
                                    <svg
                                        class="w-5 h-5 text-secondary mt-0.5 flex-shrink-0"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                        />
                                    </svg>
                                    <span class="text-gray-700">
                                        Curriculum Vitae
                                    </span>
                                </div>
                                <div class="flex items-start gap-2">
                                    <svg
                                        class="w-5 h-5 text-secondary mt-0.5 flex-shrink-0"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                        />
                                    </svg>
                                    <span class="text-gray-700">
                                        Título Profesional y Cédula por cada
                                        grado académico
                                    </span>
                                </div>
                            </div>

                            <a
                                href={`/enrollment/${programSlug}`}
                                class="block w-full bg-secondary hover:bg-secondary/90 text-white font-bold py-4 px-6 rounded-xl text-center transition-all shadow-lg hover:shadow-xl"
                            >
                                Iniciar Solicitud
                            </a>

                            <p class="text-xs text-gray-500 mt-4 text-center">
                                Proceso en línea • Respuesta en 48-72 horas
                            </p>
                        </ProgramEnrollmentAsideCard>
                    ) : (
                        <ContinuousEducationForm
                            programTitle={String(data.title)}
                            programId={programSlug}
                            stripePriceIds={stripePriceIdsForCheckout}
                            prices={continuousEducationPrices}
                            paymentOptions={paymentOptions}
                            address={programAddress}
                            requiresVerification={programRequiresVerification}
                            embedInAsideCard={false}
                        />
                    )
                }
            </div>
        </section>
    </main>
</Layout>
