---
import Layout from "../layouts/Layout.astro";
import { getSortedPosts } from "@lib/posts";

const posts = await getSortedPosts();
---

<Layout title="Revista | CEPRIJA">
  <main class="container mx-auto px-6 py-12">
    <h1
      class="text-4xl font-bold text-primary mb-12 font-serif text-center"
      data-animate="fade-up"
    >
      Revista Ceprija
    </h1>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        posts.map((post, index) => (
          <a
            href={`/revista/${post.slug}`}
            class="group block bg-white rounded-xl shadow hover:shadow-lg transition"
          >
            {/* Imagen */}
            {post.data.image && (
              <div class="h-48 w-full overflow-hidden relative group">
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
                <div class="absolute top-4 left-4">
                  <span class="bg-white/90 backdrop-blur-sm text-primary text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">
                    {post.data.category}
                  </span>
                </div>
              </div>
            )}

            {/* Contenido */}
            <div class="p-6 flex flex-col flex-grow">
              <p class="text-sm text-gray-500 mb-2">
                {new Date(post.data.date).toLocaleDateString()}
              </p>

              <h2 class="text-xl font-bold text-primary mt-2 mb-3 hover:text-blue-700 font-serif">
                {post.data.title}
              </h2>

              <p class="text-gray-600 text-sm mb-4 flex-grow">
                {post.data.excerpt}
              </p>
            </div>
          </a>
        ))
      }
    </div>
  </main>
</Layout>
