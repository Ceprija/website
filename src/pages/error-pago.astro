---
import Layout from "../layouts/Layout.astro";

const requestId = Astro.url.searchParams.get("request_id");

const seo = {
  title: "Error de Pago | CEPRIJA",
  description: "No pudimos completar la confirmación del pago.",
};
---

<Layout seo={seo}>
  <main class="container mx-auto px-6 py-20 min-h-screen flex items-center justify-center">
    <section class="max-w-2xl w-full text-center">
      <div class="bg-amber-50 border border-amber-200 rounded-2xl p-8 shadow-sm">
        <h1 class="text-4xl md:text-5xl font-bold text-primary mb-4 font-serif">
          Necesitamos revisar tu pago
        </h1>
        <p class="text-lg text-gray-700 mb-4 leading-relaxed">
          Si Stripe ya confirmó el cobro, tu inscripción no se pierde. Nuestro equipo puede verificarla con el ID de transacción o el ID de solicitud.
        </p>
        <p class="text-gray-600">
          Escríbenos a <a class="font-semibold text-primary underline" href="mailto:controlescolar@ceprija.edu.mx">controlescolar@ceprija.edu.mx</a>
          o llama al <strong>(33) 3826-4863</strong>.
        </p>

        {requestId && (
          <div class="bg-white rounded-xl p-4 mt-6 border border-amber-200">
            <p class="text-xs text-gray-500 mb-2">ID de solicitud:</p>
            <code class="text-xs break-all">{requestId}</code>
          </div>
        )}
      </div>

      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/oferta-academica" class="inline-block bg-primary text-white px-8 py-3 rounded-xl font-bold hover:bg-blue-900 transition-all">
          Volver a oferta académica
        </a>
        <a href="/contacto" class="inline-block bg-white text-primary border-2 border-primary px-8 py-3 rounded-xl font-bold hover:bg-blue-50 transition-all">
          Contactar soporte
        </a>
      </div>
    </section>
  </main>
</Layout>
