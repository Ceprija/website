# Configuración del Servidor SMTP (Correo)
# Reemplaza estos valores con los de tu proveedor de correo (Gmail, Outlook, SendGrid, etc.)
# Renombra este archivo a .env para que funcione en local

# Host del servidor SMTP (ej. smtp.gmail.com)
SMTP_HOST=

# Puerto del servidor SMTP (587 es común para TLS, 465 para SSL)
SMTP_PORT=

# Si el servidor usa SSL/TLS seguro (true para puerto 465, false para 587)
SMTP_SECURE=

# Usuario y contraseña para autenticación
SMTP_USER=
SMTP_PASS=

# Dirección de correo que aparecerá como remitente
SMTP_FROM=

# Dirección de correo donde llegarán las solicitudes del formulario
# Para múltiples destinatarios, sepáralos por comas (ej. correo1@dominio.com, correo2@dominio.com)
CONTACT_EMAIL=
KEY_API_BREVO=
# Controlescolar: contacto oficial en el HTML del participante y destinatario de avisos admin.
EMAIL_CONTROL_ESCOLAR=controlescolar@ceprija.edu.mx
# Remitente Brevo (debe estar verificado en Brevo). En desarrollo/pruebas suele ser desarrolloweb@.
EMAIL_SOPORTE_WEB=desarrolloweb@ceprija.edu.mx

# URL canónica del sitio (opcional). Si está definida, Checkout usa esta base para
# success_url/cancel_url en lugar del Origin del request (útil detrás de proxy o para
# coincidir siempre con producción).
SITE_URL=

# Stripe (pagos con Checkout; rutas en src/pages/api/stripe/)
# Copia este archivo a .env en la RAÍZ del proyecto ceprija_site/ (junto a package.json).
# Clave secreta: Stripe Dashboard → Developers → API keys → Secret key (sk_test_... o sk_live_...)
#
# Cada programa necesita Price IDs que EXISTAN en esta cuenta de Stripe (mismo
# modo test/live que la clave secreta). Los IDs tipo price_1Cfg... del repo son
# solo ejemplos de formato: debes sustituirlos por los que muestre el Dashboard.
# Ej. en src/content/programas/mi-programa.md:
#   stripePriceIds:
#     presencial: "price_xxxxxxxx"
#     online: "price_yyyyyyyy"
# (Catálogo de productos → precio → copiar ID price_...)
STRIPE_SECRET_KEY=
# Webhook: en local usa el whsec_ que imprime `stripe listen`; en producción el del Dashboard.
STRIPE_WEBHOOK_SECRET=
# Opcional: solo IDs de PRECIO price_... (nunca prod_...). Separados por coma. Vacío = sin allowlist.
STRIPE_ALLOWED_PRICE_IDS=

# --- Operación Stripe (checklist) ---
# - Test vs live: usa sk_test_... + precios price_... de modo prueba; en producción sk_live_...
#   y precios live. Los stripePriceIds en content/programas deben coincidir con el modo de la clave.
# - Webhook: en local, `stripe listen --forward-to localhost:4321/api/stripe/webhook` y el whsec_
#   que imprime el CLI. En producción, endpoint HTTPS al mismo path y el signing secret del Dashboard.
# - STRIPE_ALLOWED_PRICE_IDS: en producción conviene lista no vacía solo con price_... válidos
#   (se ignoran entradas que no parezcan price_*). Vacío = no hay allowlist (solo validación de formato).
# - Dedupe en disco (Node standalone): `data/stripe-enrollment-session-ids.json` y
#   `data/stripe-webhook-event-ids.json` (gitignored); persisten entre reinicios en el mismo servidor.
